/* #ifndef APP */
page {
  height: 100%;
  display: flex;
}
/* #endif */
.page-root {
  height: 100%;
  display: flex;
  flex-direction: column;
}
.msg-row-start {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}
.msg-row-end {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: flex-end;
}
.msg-content-left {
  display: flex;
  flex-direction: column;
  /* #ifndef APP */
  max-width: 70%;
  /* #endif */
  /* #ifdef APP */
  max-width: 270px;
  /* #endif */
}
.msg-content-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  /* #ifndef APP */
  max-width: 70%;
  /* #endif */
  /* #ifdef APP */
  max-width: 270px;
  /* #endif */
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.flex-row {
  display: flex;
  flex-direction: row;
}
.items-center {
  align-items: center;
}
.justify-center {
  justify-content: center;
}
.flex-1 {
  flex: 1;
}
.chat-input {
  flex: 1;
  height: 36px;
  background-color: #f1f5f9;
  color: #1e293b;
  font-size: 14px;
  border-width: 0px;
}
