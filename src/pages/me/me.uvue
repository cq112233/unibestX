  display: flex;
  flex-direction: row;
}

.status-tag {
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 20px;
  font-weight: 500;
  overflow: hidden;
}

.status-logged-in {
  background-color: #d1fae5;
  color: #065f46;
}

.status-not-logged-in {
  background-color: #f1f5f9;
  color: #64748b;
}

.info-card {
  width: 100%;
