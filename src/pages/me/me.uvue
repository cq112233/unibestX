  padding: 20px;
  margin-bottom: 24px;
  display: flex;
  flex-direction: column;
}

.info-header {
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: #f1f5f9;
  padding-bottom: 8px;
  margin-bottom: 12px;
  display: flex;
  flex-direction: row;
}

.info-title {
  font-size: 15px;
  font-weight: 600;
  color: #334155;
}

.json-scroll {
  background-color: #0f172a;
  border-radius: 8px;
  padding: 12px;
  max-height: 180px;
}

.json-text {
  font-size: 13px;
