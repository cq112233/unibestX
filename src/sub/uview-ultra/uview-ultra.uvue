function onDropdownChange(value: string | number): void {
  uni.showToast({ title: `选中值: ${value}`, icon: 'none' })
}

// Slot 示例 - 关闭方法
const uDropdownRef1 = ref(null as ComponentPublicInstance | null)
const uDropdownRef2 = ref(null as ComponentPublicInstance | null)
const uDropdownRef3 = ref(null as ComponentPublicInstance | null)
const uDropdownRefGrid1 = ref(null as ComponentPublicInstance | null)
const uDropdownRefCard = ref(null as ComponentPublicInstance | null)

function closeDropdown(refName: string): void {
  const refMap: UTSJSONObject = {
    uDropdownRef1: uDropdownRef1.value,
    uDropdownRef2: uDropdownRef2.value,
    uDropdownRef3: uDropdownRef3.value,
    uDropdownRefGrid1: uDropdownRefGrid1.value,
    uDropdownRefCard: uDropdownRefCard.value,
  }
  const comp = refMap[refName] as ComponentPublicInstance | null
  if (comp != null) {
    comp.$callMethod('close')
  }
}

// Slot 滚动选择示例
const dropdownScrollSelected = ref('暂无')
function onDropdownScrollSelect(index: number): void {
  dropdownScrollSelected.value = `选项 ${index}`
}

// 高亮控制示例
const dropdownHLValue1 = ref(1)
const dropdownHLValue2 = ref(2)
function onDropdownOpen(index: number): void {
  const comp = uDropdownRef3.value
  if (comp != null) {
    comp.$callMethod('highlight')
  }
}
function onDropdownClose(index: number): void {
  const comp = uDropdownRef3.value
  if (comp != null) {
    ;(comp.$callMethod('highlight') as Promise<any>).then(() => {
      // 高亮已取消
    })
  }
}

// 宫格布局示例
