          <up-button type="primary" text="右侧弹出" size="mini" @click="openPopup('right')"></up-button>
        </view>
      </view>

      <up-divider text="反馈组件结束"></up-divider>

      <!-- ==================== 布局组件 ==================== -->
      <text class="section-title">
