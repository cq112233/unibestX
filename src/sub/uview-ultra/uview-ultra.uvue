<script setup lang="uts">
import { computed, onMounted, reactive, ref } from 'vue'
import ThemeSwitchCard from '@/src/pages/basic/components/ThemeSwitchCard.uvue'
import DemoForm from './components/DemoForm.uvue'
import DemoFeedback from './components/DemoFeedback.uvue'
import DemoNav from './components/DemoNav.uvue'
import DemoShow from './components/DemoShow.uvue'
import mpHtml from '../../../uni_modules/mp-html/components/mp-html/mp-html.uvue'

// ==================== BackTop 回到顶部 ====================
const scrollTop = ref(0)
const scrollViewScrollTop = ref(0)
const scrollHeight = ref(0)

onMounted(() => {
  const sysInfo = uni.getWindowInfo()
  scrollHeight.value = sysInfo.windowHeight - 44
})

function onScroll(e: UniScrollEvent): void {
  const currentScrollTop = e.detail.scrollTop
  console.log('scroll-view scrollTop:', currentScrollTop)
  scrollTop.value = currentScrollTop
}
function onBackTopClick(): void {
  // 先把控制位置的变量同步为当前实际位置，然后再变回 0，强制触发 Vue 属性变更响应
  scrollViewScrollTop.value = scrollTop.value
  setTimeout(() => {
    scrollViewScrollTop.value = 0
  }, 20)
}

// ==================== Dropdown 下拉菜单 ====================
const value1 = ref(1)
const value2 = ref(2)
const options1 = ref([
  { label: '默认排序', value: 1 },
  { label: '距离优先', value: 2 },
  { label: '价格优先', value: 3 },
] as UTSJSONObject[])
const options2 = ref([
  { label: '去冰', value: 1 },
  { label: '加冰', value: 2 },
] as UTSJSONObject[])

// 自定义颜色示例
const dropdownGreenValue1 = ref(1)
const dropdownGreenValue2 = ref(1)
const dropdownRegionOptions1 = ref([
  { label: '全部', value: 1 },
  { label: '朝阳区', value: 2 },
  { label: '海淀区', value: 3 },
  { label: '西城区', value: 4 },
] as UTSJSONObject[])
const dropdownRegionOptions2 = ref([
  { label: '综合排序', value: 1 },
  { label: '评分最高', value: 2 },
  { label: '销量优先', value: 3 },
  { label: '价格最低', value: 4 },
] as UTSJSONObject[])

// 禁用示例
const dropdownDisValue1 = ref(1)

// change 事件示例
const dropdownEventValue = ref(1)
function onDropdownChange(value: string | number): void {
  uni.showToast({ title: `选中值: ${value}`, icon: 'none' })
}

// Slot 示例 - 关闭方法
const uDropdownRef1 = ref(null as ComponentPublicInstance | null)
const uDropdownRef2 = ref(null as ComponentPublicInstance | null)
const uDropdownRef3 = ref(null as ComponentPublicInstance | null)
const uDropdownRefGrid1 = ref(null as ComponentPublicInstance | null)
const uDropdownRefCard = ref(null as ComponentPublicInstance | null)

function closeDropdown(refName: string): void {
  const refMap: UTSJSONObject = {
    uDropdownRef1: uDropdownRef1.value,
    uDropdownRef2: uDropdownRef2.value,
    uDropdownRef3: uDropdownRef3.value,
    uDropdownRefGrid1: uDropdownRefGrid1.value,
    uDropdownRefCard: uDropdownRefCard.value,
  }
  const comp = refMap[refName] as ComponentPublicInstance | null
  if (comp != null) {
    comp.$callMethod('close')
  }
}

// Slot 滚动选择示例
const dropdownScrollSelected = ref('暂无')
function onDropdownScrollSelect(index: number): void {
  dropdownScrollSelected.value = `选项 ${index}`
}

// 高亮控制示例
const dropdownHLValue1 = ref(1)
const dropdownHLValue2 = ref(2)
function onDropdownOpen(index: number): void {
  const comp = uDropdownRef3.value
  if (comp != null) {
    comp.$callMethod('highlight')
  }
}
function onDropdownClose(index: number): void {
  const comp = uDropdownRef3.value
  if (comp != null) {
    ;(comp.$callMethod('highlight') as Promise<any>).then(() => {
      // 高亮已取消
    })
  }
}

// 宫格布局示例
const dropdownGridSelected = ref('暂无')
const dropdownGridItems = ref([
  { text: '美食', icon: 'star-fill', color: '#f9ae3d' },
  { text: '外卖', icon: 'car-fill', color: '#2979ff' },
  { text: '酒店', icon: 'home', color: '#19be6b' },
  { text: '电影', icon: 'play-right-fill', color: '#fa3534' },
  { text: 'KTV', icon: 'mic', color: '#9c27b0' },
  { text: '丽人', icon: 'heart-fill', color: '#ff4081' },
  { text: '周边游', icon: 'map-fill', color: '#00bcd4' },
  { text: '更多', icon: 'grid-fill', color: '#909399' },
] as UTSJSONObject[])
const dropdownGridFilterItems = ref([
  { text: '智能排序', icon: 'list-dot', color: '#2979ff' },
  { text: '离我最近', icon: 'map', color: '#19be6b' },
  { text: '好评优先', icon: 'star', color: '#f9ae3d' },
  { text: '人气最高', icon: 'fire', color: '#fa3534' },
  { text: '价格最低', icon: 'rmb-circle-fill', color: '#ff9900' },
  { text: '最新发布', icon: 'clock-fill', color: '#00bcd4' },
] as UTSJSONObject[])

function onDropdownGridSelect(text: string): void {
  dropdownGridSelected.value = text
}

// 卡片式布局示例
const dropdownCardSelected = ref('暂无')
const dropdownCardItems = ref([
  { id: '1', image: 'https://picsum.photos/400/300?random=50', title: '招牌红烧牛肉面', desc: '精选牛腱肉·慢炖8小时', price: '¥38', tag: '热卖' },
  { id: '2', image: 'https://picsum.photos/400/300?random=51', title: '海鲜至尊披萨', desc: '12寸·虾仁+鱿鱼+芝士', price: '¥88', tag: '新品' },
  { id: '3', image: 'https://picsum.photos/400/300?random=52', title: '经典珍珠奶茶', desc: '手作黑糖珍珠·鲜奶', price: '¥18', tag: '爆款' },
  { id: '4', image: 'https://picsum.photos/400/300?random=53', title: '法式提拉米苏', desc: '马斯卡彭芝士·可可粉', price: '¥32', tag: '甜品' },
] as UTSJSONObject[])
const dropdownCardItems2 = ref([
  { id: '5', image: 'https://picsum.photos/400/300?random=54', title: '日式鳗鱼饭', desc: '活鳗现烤·秘制酱汁', price: '¥68', tag: '限量' },
  { id: '6', image: 'https://picsum.photos/400/300?random=55', title: '泰式冬阴功汤', desc: '鲜虾+香茅+椰浆', price: '¥45', tag: '推荐' },
  { id: '7', image: 'https://picsum.photos/400/300?random=56', title: '美式牛肉汉堡', desc: '安格斯牛肉饼·双层', price: '¥42', tag: '大份' },
  { id: '8', image: 'https://picsum.photos/400/300?random=57', title: '冰淇淋华夫饼', desc: '香草冰淇淋·现烤华夫', price: '¥28', tag: '甜蜜' },
] as UTSJSONObject[])

function onDropdownCardSelect(title: string): void {
  dropdownCardSelected.value = title
}

// ==================== Waterfall 瀑布流 ====================
const waterfallList = ref([
  { id: '1', image: 'https://picsum.photos/400/300?random=1', title: '简约风小茶几', price: '¥299' },
  { id: '2', image: 'https://picsum.photos/400/500?random=2', title: '北欧风落地灯', price: '¥599' },
  { id: '3', image: 'https://picsum.photos/400/350?random=3', title: '日式花瓶摆件', price: '¥89' },
  { id: '4', image: 'https://picsum.photos/400/450?random=4', title: '复古台灯', price: '¥399' },
  { id: '5', image: 'https://picsum.photos/400/280?random=5', title: 'ins风挂画', price: '¥159' },
  { id: '6', image: 'https://picsum.photos/400/520?random=6', title: '实木相框组合', price: '¥129' },
] as UTSJSONObject[])

const waterfallLeftList = computed(() => waterfallList.value.filter((_: UTSJSONObject, idx: number) => idx % 2 === 0))
const waterfallRightList = computed(() => waterfallList.value.filter((_: UTSJSONObject, idx: number) => idx % 2 === 1))

function loadMoreWaterfall(): void {
  const newItems: UTSJSONObject[] = []
  const base = waterfallList.value.length + 1
  for (let i = 0; i < 4; i++) {
    const idx = base + i
    const heights = [280, 350, 420, 300, 500, 380]
    newItems.push({
      id: `${idx}`,
      image: `https://picsum.photos/400/${heights[i % heights.length]}?random=${idx}`,
      title: `商品 ${idx}`,
      price: `¥${(Math.random() * 500 + 50).toFixed(0)}`,
    } as UTSJSONObject)
  }
  waterfallList.value = waterfallList.value.concat(newItems)
}

function clearWaterfall(): void {
  waterfallList.value = [] as UTSJSONObject[]
}

