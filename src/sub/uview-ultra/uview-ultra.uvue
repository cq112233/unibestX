<template>
  <view class="page-container">
    <NavBar
      title="uview-ultra 组件演示"
      :auto-back="true"
      :safe-area-inset-top="true"
      bg-color="#ffffff"
    ></NavBar>

    <scroll-view :scroll-y="true" direction="vertical" :style="{ height: `${scrollHeight}px` }" :scroll-top="scrollViewScrollTop" :scroll-with-animation="true" @scroll="onScroll">
      <ThemeSwitchCard />

      <!-- ReadMore 展开阅读更多 -->
      <view class="demo-block">
        <text class="demo-label">
          up-read-more 展开阅读更多
        </text>
        <!-- 基本使用 -->
        <up-read-more show-height="120">
          <rich-text :nodes="readMoreContent"></rich-text>
        </up-read-more>
        <!-- 带展开/收起切换 -->
        <view class="mt-10px">
          <up-read-more :toggle="true" show-height="120" close-text="展开阅读全文" open-text="收起">
            <rich-text :nodes="readMoreContent"></rich-text>
          </up-read-more>
        </view>
        <!-- 自定义颜色和字号 -->
        <view class="mt-10px">
          <up-read-more show-height="100" color="#19be6b" :font-size="12" close-text="查看更多">
            <rich-text :nodes="readMoreContent"></rich-text>
          </up-read-more>
        </view>
      </view>

      <!-- Avatar 头像 -->
      <view class="demo-block">
        <text class="demo-label">
          up-avatar 头像
        </text>
        <!-- 图片头像：不同形状和尺寸 -->
        <view class="demo-row-start">
          <up-avatar :src="avatarSrc" size="40"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :src="avatarSrc" size="40" shape="square"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :src="avatarSrc" size="55" mode="aspectFill"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar src="/invalid-path.png" size="40" default-url="/static/logo.png"></up-avatar>
        </view>
        <!-- 文字头像 -->
        <view class="demo-row-start mt-10px">
          <up-avatar text="U" size="40" bg-color="#2979ff"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar text="A" size="40" bg-color="#19be6b"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :random-bg-color="true" text="张" size="40"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :random-bg-color="true" text="李" size="40" font-size="16"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :random-bg-color="true" text="王五" size="45" font-size="14"></up-avatar>
        </view>
        <!-- 图标头像 -->
        <view class="demo-row-start mt-10px">
          <up-avatar icon="star-fill" size="40" bg-color="#ffca28" font-size="22"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar icon="heart-fill" size="40" bg-color="#fa3534" font-size="22"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar icon="setting-fill" size="40" bg-color="#909399" font-size="22"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar icon="photo-fill" size="40" bg-color="#19be6b" font-size="22"></up-avatar>
        </view>
        <!-- 头像组 -->
        <view class="demo-row-start mt-10px items-center">
          <text class="text-12px text-[#909399] mr-10px">头像组:</text>
          <up-avatar-group :urls="avatarGroupUrls" size="35" :gap="0.4" :max-count="5" :show-more="true" @show-more="onAvatarGroupMore"></up-avatar-group>
        </view>
        <!-- 可点击头像 -->
        <view class="demo-row-start mt-10px items-center">
          <up-avatar :src="avatarSrc" size="40" @click="onAvatarClick"></up-avatar>
          <text class="text-12px text-[#909399] ml-10px">点击头像可触发事件</text>
        </view>
      </view>

      <!-- Link 超链接 -->
      <view class="demo-block">
        <text class="demo-label">
          up-link 超链接
        </text>
        <!-- 基本使用 -->
        <view class="demo-row-start">
          <up-link href="https://uview-ultra.lingyun.net" text="打开 uview-ultra UI 文档" @click="onLinkClick"></up-link>
        </view>
        <!-- 带下划线 -->
        <view class="demo-row-start mt-8px">
          <up-link href="https://uniapp.dcloud.net.cn" text="uni-app X 官方文档" :under-line="true" @click="onLinkClick"></up-link>
        </view>
        <!-- 自定义颜色 + 下划线颜色 -->
        <view class="demo-row-start mt-8px">
          <up-link href="https://github.com" text="GitHub" color="#19be6b" line-color="#19be6b" :under-line="true" font-size="16" @click="onLinkClick"></up-link>
          <view class="w-20px"></view>
          <up-link href="https://www.baidu.com" text="百度一下" color="#fa3534" line-color="#fa3534" :under-line="true" font-size="16" @click="onLinkClick"></up-link>
          <view class="w-20px"></view>
          <up-link href="https://www.zhihu.com" text="知乎" color="#ff9900" font-size="16" @click="onLinkClick"></up-link>
        </view>
        <!-- 小程序复制提示 -->
        <view class="demo-row-start mt-8px">
          <up-link href="https://uview-ultra.lingyun.net" text="小程序内打开（复制链接到浏览器）" :under-line="true" mp-tips="链接已复制，请在浏览器中打开" font-size="13" color="#909399" @click="onLinkClick"></up-link>
        </view>
      </view>

      <!-- LazyLoad 懒加载 -->
      <view class="demo-block">
        <text class="demo-label">
          up-lazy-load 懒加载
        </text>
        <!-- 基本使用 -->
        <view class="demo-row-start">
          <view class="lazy-load-item">
            <up-lazy-load
              image="https://gtd.alicdn.com/sns_logo/i1/TB124_3NXXXXXasXVXXSutbFXXX.jpg_240x240xz.jpg"
              loading-img="/static/logo.png"
              :height="1020"
              :border-radius="8"
              index="img1"
              @click="onLazyLoadClick"
              @error="onLazyLoadError"
            ></up-lazy-load>
          </view>
          <view class="lazy-load-item">
            <up-lazy-load
              image="https://picsum.photos/240/240?random=22"
              loading-img="/static/logo.png"
              :height="120"
              :border-radius="8"
              index="img2"
              @click="onLazyLoadClick"
              @error="onLazyLoadError"
            ></up-lazy-load>
          </view>
          <view class="lazy-load-item">
            <up-lazy-load
              image="https://picsum.photos/240/240?random=23"
              loading-img="/static/logo.png"
              :height="120"
              :border-radius="8"
              index="img3"
              @click="onLazyLoadClick"
              @error="onLazyLoadError"
            ></up-lazy-load>
          </view>
        </view>
        <!-- 占位图 + 错误图 -->
        <view class="demo-row-start mt-10px items-center">
          <view class="lazy-load-item">
            <up-lazy-load
              image="https://invalid-url-test/not-exist.png"
              loading-img="/static/logo.png"
              error-img="/static/logo.png"
              :height="100"
              :border-radius="8"
              index="error-img"
            ></up-lazy-load>
          </view>
          <text class="text-12px text-[#909399] ml-10px">加载失败自动展示 error-img 占位图</text>
        </view>
      </view>

      <!-- mp-html 富文本 -->
      <view class="demo-block">
        <text class="demo-label">
          mp-html 富文本
        </text>
        <mp-html
          :content="mpHtmlContent"
          :preview-img="true"
          :show-img-menu="true"
          :selectable="true"
          @load="onMpHtmlLoad"
          @linktap="onMpHtmlLinktap"
          @imgtap="onMpHtmlImgtap"
          @error="onMpHtmlError"
        ></mp-html>
      </view>

      <!-- Loadmore 加载更多 -->
      <view class="demo-block">
        <text class="demo-label">
          up-loadmore
        </text>
        <view class="flex-col items-center">
          <up-loadmore :status="loadmoreStatus" :is-dot="loadmoreIsDot" :line="true"></up-loadmore>
          <view class="demo-row mt-10px">
            <up-button type="primary" text="加载更多" size="mini" @click="loadmoreStatus = 'loadmore'; loadmoreIsDot = false"></up-button>
            <up-button type="warning" text="加载中" size="mini" @click="loadmoreStatus = 'loading'; loadmoreIsDot = false"></up-button>
            <up-button type="info" text="没有更多" size="mini" @click="loadmoreStatus = 'nomore'; loadmoreIsDot = false"></up-button>
            <up-button type="error" text="显示圆点" size="mini" @click="loadmoreStatus = 'nomore'; loadmoreIsDot = true"></up-button>
          </view>
        </view>
      </view>

      <!-- Album 相册 -->
      <view class="demo-block">
        <text class="demo-label">
          up-album
        </text>
        <up-album
          :urls="albumUrls"
          multiple-size="72"
          space="6"
          :max-count="9"
          :show-more="true"
          row-count="3"
          radius="6"
        ></up-album>
      </view>

      <!-- IndexList 索引列表 -->
      <view class="demo-block">
        <text class="demo-label">
          up-index-list
        </text>
        <view class="index-list-demo-wrapper">
          <up-index-list :index-list="indexList" :sticky="true">
            <template v-for="(item, index) in itemArr" :key="index">
              <up-index-item>
                <up-index-anchor :text="indexList[index]"></up-index-anchor>
                <view v-for="(cell, cellIndex) in item" :key="cellIndex" class="list-cell">
                  <text class="list-cell-text">{{ cell as string }}</text>
                </view>
              </up-index-item>
            </template>
          </up-index-list>
        </view>
      </view>

      <!-- Tabbar 底部导航栏 -->
      <view class="demo-block">
        <text class="demo-label">
          up-tabbar
        </text>
        <view class="tabbar-demo-wrapper">
          <up-tabbar
            :value="tabbarValue"
            :fixed="false"
            :placeholder="false"
            :safe-area-inset-bottom="false"
            @change="onTabbarChange"
          >
            <up-tabbar-item text="首页" icon="home" name="home"></up-tabbar-item>
            <up-tabbar-item text="分类" icon="search" name="search"></up-tabbar-item>
            <up-tabbar-item text="购物车" icon="heart" name="cart"></up-tabbar-item>
            <up-tabbar-item text="我的" icon="account" name="mine"></up-tabbar-item>
          </up-tabbar>
        </view>
      </view>

      <!-- Navbar 导航栏 -->
      <view class="demo-block">
        <text class="demo-label">
          up-navbar
        </text>
        <up-navbar
          title="自定义导航栏"
          :fixed="false"
          :auto-back="false"
          :safe-area-inset-top="false"
          bg-color="#2979ff"
        ></up-navbar>
        <view class="h-10px"></view>

        <up-navbar
          title="浅色主题"
          :fixed="false"
          :auto-back="false"
          :safe-area-inset-top="false"
          bg-color="#ffffff"
          :border="true"
        ></up-navbar>

        <view class="h-10px"></view>

        <up-navbar
          title="带返回按钮"
          :fixed="false"
          :auto-back="true"
          :safe-area-inset-top="false"
          bg-color="#f5f5f5"
        ></up-navbar>

        <view class="h-10px"></view>

        <up-navbar
          title="自定义标题"
          :fixed="false"
          :auto-back="false"
          :safe-area-inset-top="false"
          bg-color="#ffffff"
          :border="true"
          left-text="返回"
          right-text="更多"
        ></up-navbar>

        <view class="h-10px"></view>

        <up-navbar
          title="自定义图标"
          :fixed="false"
          :auto-back="false"
          :safe-area-inset-top="false"
          bg-color="#ffffff"
          :border="true"
          left-text="返回"
          left-icon="arrow-left"
          right-icon="setting"
        ></up-navbar>

        <view class="h-10px">
        </view>
        <up-navbar
          :fixed="false"
          left-text="返回"
          title="个人中心"
          :safe-area-inset-top="false"
        >
          <template #left>
            <view
              class="u-nav-slot"
            >
              <up-icon
                name="arrow-left"
                size="19"
              ></up-icon>
              <up-line
                direction="column"
                :hairline="false"
                length="16"
                margin="0 8px"
              ></up-line>
              <up-icon
                name="home"
                size="20"
              ></up-icon>
            </view>
          </template>
        </up-navbar>
      </view>

      <!-- Tabs 标签页 -->
      <view class="demo-block">
        <text class="demo-label">
          up-tabs
        </text>
        <up-tabs :list="tabsList" :current="tabsCurrent" @change="onTabsChange"></up-tabs>
        <view class="p-15px bg-white">
          <text class="text-14px text-[#606266]">{{ tabsList.length > tabsCurrent ? tabsList[tabsCurrent].name : '' }} 的内容区域</text>
        </view>
      </view>

      <!-- Steps 步骤条 -->
      <view class="demo-block">
        <text class="demo-label">
          up-steps
        </text>
        <up-steps :current="stepsCurrent" direction="row">
          <up-steps-item title="下单" desc="已下单"></up-steps-item>
          <up-steps-item title="出库" desc="已出库"></up-steps-item>
          <up-steps-item title="运输" desc="运输中"></up-steps-item>
          <up-steps-item title="签收" desc="已签收"></up-steps-item>
        </up-steps>
        <view class="h-10px"></view>
        <view class="demo-row">
          <up-button type="primary" text="上一步" size="mini" @click="prevStep"></up-button>
          <up-button type="primary" text="下一步" size="mini" @click="nextStep"></up-button>
        </view>
      </view>

      <!-- Subsection 分段器 -->
      <view class="demo-block">
        <text class="demo-label">
          up-subsection
        </text>
        <up-subsection :list="subsectionList" :current="subsectionCurrent" @change="onSubsectionChange"></up-subsection>
      </view>

      <!-- Waterfall 瀑布流 -->
      <view class="demo-block">
        <text class="demo-label">up-waterfall</text>
        <view class="waterfall-container">
          <view class="waterfall-column">
            <view v-for="item in waterfallLeftList" :key="item.getString('id')" class="waterfall-card">
              <image :src="item.getString('image')" mode="widthFix" class="waterfall-image"></image>
              <view class="waterfall-info">
                <text class="waterfall-title">{{ item.getString('title') }}</text>
                <text class="waterfall-price">{{ item.getString('price') }}</text>
              </view>
            </view>
          </view>
          <view class="waterfall-column waterfall-column-right">
            <view v-for="item in waterfallRightList" :key="item.getString('id')" class="waterfall-card">
              <image :src="item.getString('image')" mode="widthFix" class="waterfall-image"></image>
              <view class="waterfall-info">
                <text class="waterfall-title">{{ item.getString('title') }}</text>
                <text class="waterfall-price">{{ item.getString('price') }}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="demo-row mt-10px">
          <up-button type="primary" text="加载更多" size="mini" @click="loadMoreWaterfall"></up-button>
          <up-button type="info" text="清空" size="mini" @click="clearWaterfall"></up-button>
        </view>
      </view>

      <!-- Dropdown 下拉菜单 -->
      <view class="demo-block" style="margin-bottom: 0px;">
        <text class="demo-label">up-dropdown</text>
      </view>
      <up-dropdown>
        <up-dropdown-item v-model="value1" title="距离" :options="options1"></up-dropdown-item>
        <up-dropdown-item v-model="value2" title="温度" :options="options2"></up-dropdown-item>
      </up-dropdown>

      <!-- SwipeAction 滑动操作 -->
      <view class="demo-block">
        <text class="demo-label">
          up-swipe-action
        </text>
        <up-swipe-action :auto-close="true">
          <up-swipe-action-item
            v-for="(item, idx) in swipeActionList"
            :key="item.id as string"
            :options="swipeActionOptions"
            :name="idx"
            :close-on-click="true"
            @click="onSwipeActionClick"
          >
            <view class="swipe-action-content">
              <text class="text-14px text-[#303133]">{{ item.title as string }}</text>
            </view>
          </up-swipe-action-item>
        </up-swipe-action>
      </view>

      <!-- Swiper 轮播图 -->
      <up-swiper
        :list="swiperList"
        key-name="image"
        :indicator="true"
        indicator-mode="dot"
        :circular="true"
        :autoplay="true"
        :interval="3000"
        height="180"
        :show-title="true"
      ></up-swiper>

      <!-- ==================== 基础组件 ==================== -->
      <text class="section-title">
        基础组件
      </text>

      <!-- Button 按钮 -->
      <view class="demo-block">
        <text class="demo-label">
          up-button
        </text>
        <view class="demo-row">
          <up-button type="primary" text="主要" size="mini"></up-button>
          <up-button type="success" text="成功" size="mini"></up-button>
          <up-button type="warning" text="警告" size="mini"></up-button>
          <up-button type="error" text="错误" size="mini"></up-button>
          <up-button type="info" text="信息" size="mini"></up-button>
        </view>
        <view class="demo-row">
          <up-button type="primary" text="朴素" :plain="true" size="mini"></up-button>
          <up-button type="primary" text="细边框" :plain="true" :hairline="true" size="mini"></up-button>
          <up-button type="primary" text="圆形" shape="circle" size="mini"></up-button>
          <up-button type="primary" text="禁用" :disabled="true" size="mini"></up-button>
        </view>
        <view class="demo-row">
          <up-button type="primary" text="加载中" :loading="true" size="mini"></up-button>
          <up-button type="primary" text="自定义色" color="#7232dd" size="mini"></up-button>
        </view>
      </view>

      <!-- Icon 图标 -->
      <view class="demo-block">
        <text class="demo-label">
          up-icon
        </text>
        <view class="demo-row">
          <up-icon name="home" size="28" label="home" label-size="10" label-pos="bottom"></up-icon>
          <up-icon name="search" size="28" color="#2979ff" label="search" label-size="10" label-pos="bottom"></up-icon>
          <up-icon name="setting" size="28" color="#ff9900" label="setting" label-size="10" label-pos="bottom"></up-icon>
          <up-icon name="heart" size="28" color="#fa3534" label="heart" label-size="10" label-pos="bottom"></up-icon>
          <up-icon name="star" size="28" color="#ffca28" label="star" label-size="10" label-pos="bottom"></up-icon>
          <up-icon name="photo" size="28" color="#19be6b" label="photo" label-size="10" label-pos="bottom"></up-icon>
          <up-icon name="map" size="28" color="#909399" label="map" label-size="10" label-pos="bottom"></up-icon>
        </view>
      </view>

      <!-- Text 文本 -->
      <view class="demo-block">
        <text class="demo-label">
          up-text
        </text>
        <view class="demo-row-start">
          <up-text text="普通文本"></up-text>
          <view class="w-15px"></view>
          <up-text type="primary" text="主色文本"></up-text>
          <view class="w-15px"></view>
          <up-text type="error" text="错误提示" :bold="true"></up-text>
        </view>
        <view class="demo-row-start mt-10px">
          <up-text mode="price" text="99.9"></up-text>
          <view class="w-20px"></view>
          <up-text mode="phone" text="13800000000" format="encrypt"></up-text>
        </view>
      </view>

      <!-- Tag 标签 -->
      <view class="demo-block">
        <text class="demo-label">
          up-tag
        </text>
        <view class="demo-row">
          <up-tag text="主要" type="primary"></up-tag>
          <up-tag text="成功" type="success"></up-tag>
          <up-tag text="警告" type="warning"></up-tag>
          <up-tag text="错误" type="error"></up-tag>
          <up-tag text="信息" type="info"></up-tag>
        </view>
        <view class="demo-row">
          <up-tag text="朴素" type="primary" :plain="true"></up-tag>
          <up-tag text="圆形" type="primary" shape="circle"></up-tag>
          <up-tag text="大号" type="primary" size="large"></up-tag>
          <up-tag text="中号" type="primary" size="medium"></up-tag>
          <up-tag text="小号" type="primary" size="mini"></up-tag>
          <up-tag text="可关闭" type="error" :plain="true" :closable="true" :show="showTag" @close="showTag = false"></up-tag>
        </view>
        <view class="demo-row-start mt-10px">
          <up-tag text="图片标签" icon="/static/logo.png" size="medium" :plain="true"></up-tag>
        </view>
      </view>

      <!-- Badge 徽标 -->
      <view class="demo-block">
        <text class="demo-label">
          up-badge
        </text>
        <view class="demo-row">
          <up-badge :value="9" type="error"></up-badge>
          <up-badge :value="99" type="error"></up-badge>
          <up-badge :value="999" type="error" :max="99"></up-badge>
          <up-badge :is-dot="true" type="error"></up-badge>
          <up-badge value="new" type="error"></up-badge>
        </view>
      </view>

      <!-- Image 图片 -->
      <view class="demo-block">
        <text class="demo-label">
          up-image
        </text>
        <view class="demo-row-start">
          <up-image src="/static/logo.png" width="60px" height="60px"></up-image>
          <view class="w-15px"></view>
          <up-image src="/static/logo.png" width="60px" height="60px" shape="circle"></up-image>
          <view class="w-15px"></view>
          <up-image src="/static/logo.png" width="60px" height="60px" radius="8px"></up-image>
          <view class="w-15px"></view>
          <up-image src="https://invalid-url-test" width="60px" height="60px"></up-image>
        </view>
      </view>

      <!-- Cell 单元格 -->
      <view class="demo-block">
        <text class="demo-label">
          up-cell
        </text>
        <up-cell-group>
          <up-cell title="单元格" value="内容"></up-cell>
          <up-cell icon="setting-fill" title="个人设置"></up-cell>
          <up-cell icon="integral-fill" title="会员等级" value="新版本"></up-cell>
          <up-cell title="可点击" value="内容" is-link></up-cell>
          <up-cell title="箭头向下" value="内容" is-link arrow-direction="down"></up-cell>
        </up-cell-group>
      </view>

      <!-- LoadingIcon 加载动画 -->
      <view class="demo-block">
        <text class="demo-label">
          up-loading-icon
        </text>
        <view class="demo-row">
          <up-loading-icon mode="circle"></up-loading-icon>
          <up-loading-icon mode="spinner"></up-loading-icon>
          <up-loading-icon mode="semicircle"></up-loading-icon>
          <up-loading-icon mode="circle" text="加载中" :vertical="true"></up-loading-icon>
        </view>
      </view>

      <up-divider text="基础组件结束"></up-divider>

      <!-- ==================== 表单组件 ==================== -->
      <text class="section-title">
        表单组件
      </text>

      <!-- Input 输入框 -->
      <view class="demo-block">
        <text class="demo-label">
          up-input
        </text>
        <up-input v-model="inputValue" placeholder="请输入内容" border="surround" clearable></up-input>
        <view class="h-10px"></view>
        <up-input v-model="passwordValue" placeholder="请输入密码" :password="true" border="surround"></up-input>
        <view class="h-10px"></view>
        <up-input placeholder="带图标" prefix-icon="search" border="surround"></up-input>
      </view>

      <!-- Search 搜索 -->
      <view class="demo-block">
        <text class="demo-label">
          up-search
        </text>
        <up-search v-model="searchValue" placeholder="搜索关键字" :show-action="true" action-text="搜索"></up-search>
      </view>

      <!-- Switch 开关 -->
      <view class="demo-block">
        <text class="demo-label">
          up-switch
        </text>
        <view class="demo-row-start">
          <up-switch v-model="switchValue1"></up-switch>
          <view class="w-20px"></view>
          <up-switch v-model="switchValue2" active-color="#fa3534"></up-switch>
          <view class="w-20px"></view>
          <up-switch :disabled="true"></up-switch>
          <view class="w-20px"></view>
          <up-switch :loading="true"></up-switch>
        </view>
      </view>

      <!-- Checkbox 复选框 -->
      <view class="demo-block">
        <text class="demo-label">
          up-checkbox
        </text>
        <up-checkbox-group v-model="checkboxValue" placement="row">
          <up-checkbox name="apple" label="苹果" :checked="true"></up-checkbox>
          <up-checkbox name="banana" label="香蕉"></up-checkbox>
          <up-checkbox name="orange" label="橙子"></up-checkbox>
        </up-checkbox-group>
      </view>

      <!-- Radio 单选框 -->
      <view class="demo-block">
        <text class="demo-label">
          up-radio
        </text>
        <up-radio-group v-model="radioValue" placement="row">
          <up-radio name="male" label="男"></up-radio>
          <up-radio name="female" label="女"></up-radio>
        </up-radio-group>
      </view>

      <!-- Slider 滑块 -->
      <view class="demo-block">
        <text class="demo-label">
          up-slider
        </text>
        <up-slider v-model="sliderValue" :min="0" :max="100" :step="1" :show-value="true"></up-slider>
      </view>

      <!-- Rate 评分 -->
      <view class="demo-block">
        <text class="demo-label">
          up-rate
        </text>
        <view class="demo-row">
          <up-rate v-model="rateValue" :count="5"></up-rate>
          <text class="text-14px text-[#909399] ml-10px">{{ rateValue }} 分</text>
        </view>
      </view>

      <!-- NumberBox 步进器 -->
      <view class="demo-block">
        <text class="demo-label">
          up-number-box
        </text>
        <view class="demo-row-start">
          <up-number-box v-model="numberValue" :min="0" :max="100"></up-number-box>
        </view>
      </view>

      <!-- Form 表单 -->
      <view class="demo-block">
        <text class="demo-label">
          基础使用
        </text>
        <up-form
          ref="uForm"
          :model="formModel"
          :rules="formRules"
          label-width="80px"
          error-type="toast"
        >
          <up-form-item label="姓名" prop="name" :border-bottom="true">
            <up-input v-model="formModel.name" placeholder="请输入姓名" border="none"></up-input>
          </up-form-item>
          <up-form-item label="性别" prop="gender" :border-bottom="true" @click="genderActionShow = true">
            <view class="flex-row items-center justify-between w-full">
              <text class="text-15px" :class="formModel.gender == '' ? 'text-[#c0c4cc]' : 'text-[#303133]'">{{ formModel.gender != '' ? formModel.gender : '请选择性别' }}</text>
              <up-icon name="arrow-right" color="#c0c4cc" size="16"></up-icon>
            </view>
          </up-form-item>
          <up-form-item label="年龄" prop="age" :border-bottom="true">
            <up-input v-model="formModel.age" type="number" placeholder="请输入年龄" border="none" :custom-style="{ backgroundColor: '#f2f3f5', padding: '4px 10px', borderRadius: '4px', width: '100%' }"></up-input>
          </up-form-item>
          <up-form-item label="水果" prop="fruit" :border-bottom="true">
            <up-radio-group v-model="formModel.fruit" placement="row">
              <up-radio name="apple" label="苹果" shape="circle"></up-radio>
              <up-radio name="banana" label="香蕉" shape="circle"></up-radio>
              <up-radio name="orange" label="毒橙子" shape="circle"></up-radio>
            </up-radio-group>
          </up-form-item>
          <up-form-item label="兴趣爱好" prop="hobbies" :border-bottom="true">
            <up-checkbox-group v-model="formModel.hobbies" placement="row">
              <up-checkbox name="badminton" label="羽毛球"></up-checkbox>
              <up-checkbox name="running" label="跑步"></up-checkbox>
              <up-checkbox name="climbing" label="爬山"></up-checkbox>
            </up-checkbox-group>
          </up-form-item>
          <up-form-item label="简介" prop="intro" :border-bottom="true">
            <up-textarea v-model="formModel.intro" placeholder="不低于3个字" count maxlength="140" height="80px"></up-textarea>
          </up-form-item>
          <up-form-item label="住店时间" prop="stayTime" :border-bottom="true" @click="calendarShow = true">
            <view class="flex-row items-center justify-between w-full">
              <text class="text-15px" :class="formModel.stayTime == '' ? 'text-[#c0c4cc]' : 'text-[#303133]'">{{ formModel.stayTime != '' ? formModel.stayTime : '请选择住店和离店时间' }}</text>
              <up-icon name="arrow-right" color="#c0c4cc" size="16"></up-icon>
            </view>
          </up-form-item>
          <up-form-item label="验证码" prop="code" :border-bottom="true">
            <view class="flex-row items-center justify-between w-full">
              <up-input v-model="formModel.code" placeholder="请填写验证码" border="none" class="flex-1"></up-input>
              <up-button type="success" text="获取验证码" size="mini" :custom-style="{ backgroundColor: '#4cd964', border: 'none', color: '#fff', marginLeft: '10px' }"></up-button>
            </view>
          </up-form-item>
          <up-form-item label="生日" prop="birthday" :border-bottom="true" @click="datetimePickerShow = true">
            <view class="flex-row items-center justify-between w-full">
              <text class="text-15px" :class="formModel.birthday == '' ? 'text-[#c0c4cc]' : 'text-[#303133]'">{{ formModel.birthday != '' ? formModel.birthday : '请选择生日' }}</text>
              <up-icon name="arrow-right" color="#c0c4cc" size="16"></up-icon>
            </view>
          </up-form-item>
        </up-form>
        <view class="mt-15px flex-row justify-between">
          <up-button type="primary" text="提交" size="mini" @click="submitForm"></up-button>
          <up-button type="info" text="重置" size="mini" @click="resetForm"></up-button>
        </view>
      </view>

      <!-- Calendar 日历 -->
      <view class="demo-block">
        <text class="demo-label">
          up-calendar
        </text>
        <view class="demo-row-start items-center">
          <up-button type="primary" text="选择日期" size="mini" @click="calendarShow = true"></up-button>
          <view class="w-15px"></view>
          <text class="text-14px text-[#606266]">{{ calendarValue != '' ? `已选日期: ${calendarValue}` : '未选择日期' }}</text>
        </view>
      </view>

      <!-- Keyboard 键盘 -->
      <view class="demo-block">
        <text class="demo-label">
          up-keyboard
        </text>
        <view class="demo-row-start items-center">
          <view class="flex-1">
            <up-input v-model="keyboardValue" placeholder="通过键盘输入内容" border="surround" readonly @click="openKeyboard('number')"></up-input>
          </view>
          <view class="w-10px"></view>
          <up-button type="info" text="清空" size="mini" @click="keyboardValue = ''"></up-button>
        </view>
        <view class="demo-row-start mt-10px">
          <up-button type="primary" text="数字键盘" size="mini" @click="openKeyboard('number')"></up-button>
          <view class="w-10px"></view>
          <up-button type="primary" text="身份证键盘" size="mini" @click="openKeyboard('card')"></up-button>
          <view class="w-10px"></view>
          <up-button type="primary" text="车牌号键盘" size="mini" @click="openKeyboard('car')"></up-button>
        </view>
      </view>

      <!-- Picker 选择器 -->
      <view class="demo-block">
        <text class="demo-label">
          up-picker
        </text>
        <view class="demo-row-start items-center">
          <up-button type="primary" text="选择国家" size="mini" @click="pickerShow = true"></up-button>
          <view class="w-15px"></view>
          <text class="text-14px text-[#606266]">{{ pickerValue != '' ? `已选: ${pickerValue}` : '未选择' }}</text>
        </view>
      </view>

      <!-- DatetimePicker 时间选择器 -->
      <view class="demo-block">
        <text class="demo-label">
          up-datetime-picker
        </text>
        <view class="demo-row-start items-center">
          <up-button type="primary" text="选择日期" size="mini" @click="datetimePickerShow = true"></up-button>
          <view class="w-15px"></view>
          <text class="text-14px text-[#606266]">{{ datetimePickerLabel != '' ? `已选: ${datetimePickerLabel}` : '未选择' }}</text>
        </view>
      </view>

      <!-- Upload 上传 -->
      <view class="demo-block">
        <text class="demo-label">
          up-upload
        </text>
        <view class="demo-row-start">
          <up-upload
            :file-list="uploadList"
            :multiple="true"
            :max-count="3"
            width="80px"
            height="80px"
            @after-read="onUploadAfterRead"
            @delete="onUploadDelete"
          ></up-upload>
        </view>
      </view>

      <up-divider text="表单组件结束"></up-divider>

      <!-- ==================== 数据组件 ==================== -->
      <text class="section-title">
        数据组件
      </text>

      <!-- CountDown 倒计时 -->
      <view class="demo-block">
        <text class="demo-label">
          up-count-down
        </text>
        <up-count-down :time="30 * 60 * 1000" format="HH:mm:ss"></up-count-down>
      </view>

      <!-- CountTo 数字滚动 -->
      <view class="demo-block">
        <text class="demo-label">
          up-count-to
        </text>
        <view class="demo-row-start">
          <up-count-to :start-val="0" :end-val="9999" :duration="3000"></up-count-to>
        </view>
      </view>

      <!-- LineProgress 线形进度条 -->
      <view class="demo-block">
        <text class="demo-label">
          up-line-progress
        </text>
        <view class="flex-col gap-y-10px">
          <view class="flex-row items-center gap-x-10px">
            <text class="text-12px text-[#909399] w-40px text-right">{{ lineProgressValue1 }}%</text>
            <up-line-progress :percentage="lineProgressValue1" :show-text="true" active-color="#2979ff"></up-line-progress>
          </view>
          <view class="flex-row items-center gap-x-10px">
            <text class="text-12px text-[#909399] w-40px text-right">{{ lineProgressValue2 }}%</text>
            <up-line-progress :percentage="lineProgressValue2" :show-text="true" active-color="#19be6b"></up-line-progress>
          </view>
          <view class="flex-row items-center gap-x-10px">
            <text class="text-12px text-[#909399] w-40px text-right">{{ lineProgressValue3 }}%</text>
            <up-line-progress :percentage="lineProgressValue3" :show-text="true" active-color="#ff9900"></up-line-progress>
          </view>
          <view class="flex-row items-center gap-x-10px">
            <text class="text-12px text-[#909399] w-40px text-right">{{ lineProgressValue4 }}%</text>
            <up-line-progress :percentage="lineProgressValue4" :show-text="false" active-color="#fa3534" height="8"></up-line-progress>
          </view>
        </view>
      </view>

      <!-- Empty 空状态 -->
      <view class="demo-block">
        <text class="demo-label">
          up-empty
        </text>
        <up-empty mode="search" text="暂无搜索结果"></up-empty>
      </view>

      <up-divider text="数据组件结束"></up-divider>

      <!-- ==================== 反馈组件 ==================== -->
      <text class="section-title">
        反馈组件
      </text>

      <!-- Alert 警告提示 -->
      <view class="demo-block">
        <text class="demo-label">
          up-alert
        </text>
        <up-alert title="成功提示" type="success" :show-icon="true"></up-alert>
        <view class="h-10px"></view>
        <up-alert title="警告提示" type="warning" :show-icon="true"></up-alert>
        <view class="h-10px"></view>
        <up-alert title="错误提示" type="error" :show-icon="true"></up-alert>
        <view class="h-10px"></view>
        <up-alert title="信息提示" type="info" :show-icon="true"></up-alert>
      </view>

      <!-- NoticeBar 滚动通知 -->
      <view class="demo-block">
        <text class="demo-label">
          up-notice-bar
        </text>
        <up-notice-bar text="uview-ultra 是一款专为 uni-app X 设计的高品质 UI 组件库" mode="link"></up-notice-bar>
      </view>

      <!-- Collapse 折叠面板 -->
      <view class="demo-block">
        <text class="demo-label">
          up-collapse
        </text>
        <up-collapse :value="collapseValue" :accordion="true">
          <up-collapse-item title="第一项" name="1">
            <text class="collapse-text">uview-ultra 是基于 uview-plus 修改的 uni-app-x 版本</text>
          </up-collapse-item>
          <up-collapse-item title="第二项" name="2">
            <text class="collapse-text">支持 iOS、Android、H5、小程序等多端</text>
          </up-collapse-item>
          <up-collapse-item title="第三项" name="3">
            <text class="collapse-text">高度适配 UTS 强类型系统与原生跨端开发</text>
          </up-collapse-item>
        </up-collapse>
      </view>

      <!-- Toast 消息提示 -->
      <view class="demo-block">
        <text class="demo-label">
          up-toast
        </text>
        <view class="demo-row">
          <up-button type="primary" text="成功提示" size="mini" @click="showToast('success')"></up-button>
          <up-button type="error" text="错误提示" size="mini" @click="showToast('error')"></up-button>
          <up-button type="warning" text="警告提示" size="mini" @click="showToast('warning')"></up-button>
          <up-button type="info" text="默认提示" size="mini" @click="showToast('default')"></up-button>
        </view>
      </view>

      <!-- Notify 消息通知 -->
      <view class="demo-block">
        <text class="demo-label">
          up-notify
        </text>
        <view class="demo-row">
          <up-button type="primary" text="主要通知" size="mini" @click="showNotify('primary')"></up-button>
          <up-button type="success" text="成功通知" size="mini" @click="showNotify('success')"></up-button>
          <up-button type="warning" text="警告通知" size="mini" @click="showNotify('warning')"></up-button>
          <up-button type="error" text="错误通知" size="mini" @click="showNotify('error')"></up-button>
        </view>
      </view>

      <!-- LoadingPage 加载页 -->
      <view class="demo-block">
        <text class="demo-label">
          up-loading-page
        </text>
        <view class="demo-row-start">
          <up-button type="primary" text="触发全屏加载" size="mini" @click="triggerLoadingPage"></up-button>
        </view>
      </view>

      <!-- Overlay 遮罩层 -->
      <view class="demo-block">
        <text class="demo-label">
          up-overlay
        </text>
        <view class="demo-row">
          <up-button type="primary" text="显示遮罩" size="mini" @click="overlayShow = true"></up-button>
          <up-button type="warning" text="半透明遮罩" size="mini" @click="overlayOpacity = 0.3; overlayShow = true"></up-button>
        </view>
      </view>

      <!-- Modal 模态框 -->
      <view class="demo-block">
        <text class="demo-label">
          up-modal
        </text>
        <view class="demo-row">
          <up-button type="primary" text="弹窗提示" size="mini" @click="showModal"></up-button>
          <up-button type="warning" text="确认弹窗" size="mini" @click="showConfirmModal"></up-button>
        </view>
      </view>

      <!-- Popup 弹出层 -->
      <view class="demo-block">
        <text class="demo-label">
          up-popup
        </text>
        <view class="demo-row">
          <up-button type="primary" text="顶部弹出" size="mini" @click="openPopup('top')"></up-button>
          <up-button type="primary" text="底部弹出" size="mini" @click="openPopup('bottom')"></up-button>
          <up-button type="primary" text="左侧弹出" size="mini" @click="openPopup('left')"></up-button>
          <up-button type="primary" text="右侧弹出" size="mini" @click="openPopup('right')"></up-button>
          <up-button type="primary" text="居中弹出" size="mini" @click="openPopup('center')"></up-button>
        </view>
      </view>

      <!-- Tooltip 长按提示 -->
      <view class="demo-block">
        <text class="demo-label">
          up-tooltip
        </text>
        <view class="demo-row-start">
          <up-tooltip text="长按此处复制文本" direction="top"></up-tooltip>
          <view class="w-30px"></view>
          <up-tooltip text="长按显示操作" direction="top" :show-copy="false" :buttons="tooltipButtons"></up-tooltip>
          <view class="w-30px"></view>
          <up-tooltip text="底部弹出" direction="bottom" color="#2979ff" bg-color="#f0f5ff"></up-tooltip>
        </view>
      </view>

      <!-- NoNetwork 无网络提示 -->
      <view class="demo-block">
        <text class="demo-label">
          up-no-network
        </text>
        <text class="text-12px text-[#909399]">引入即自动监听网络状态，断网时全屏展示遮罩提示。</text>
      </view>

      <up-divider text="反馈组件结束"></up-divider>

      <!-- ==================== 布局组件 ==================== -->
      <text class="section-title">
        布局组件
      </text>

      <!-- Layout 栅格布局 -->
      <view class="demo-block">
        <text class="demo-label">
          up-row / up-col
        </text>
        <up-row justify="space-between" gutter="10">
          <up-col span="2">
            <view class="demo-layout bg-purple-light"></view>
          </up-col>
          <up-col span="4">
            <view class="demo-layout bg-purple"></view>
          </up-col>
          <up-col span="6">
            <view class="demo-layout bg-purple-dark"></view>
          </up-col>
        </up-row>
      </view>

      <!-- Grid 宫格 -->
      <view class="demo-block">
        <text class="demo-label">
          up-grid
        </text>
        <up-grid :col="4" :border="true">
          <up-grid-item>
            <up-icon name="home" :size="26"></up-icon>
            <text class="grid-text">首页</text>
          </up-grid-item>
          <up-grid-item>
            <up-icon name="search" :size="26"></up-icon>
            <text class="grid-text">搜索</text>
          </up-grid-item>
          <up-grid-item>
            <up-icon name="setting" :size="26"></up-icon>
            <text class="grid-text">设置</text>
          </up-grid-item>
          <up-grid-item>
            <up-icon name="heart" :size="26"></up-icon>
            <text class="grid-text">收藏</text>
          </up-grid-item>
          <up-grid-item>
            <up-icon name="photo" :size="26"></up-icon>
            <text class="grid-text">相册</text>
          </up-grid-item>
          <up-grid-item>
            <up-icon name="star" :size="26"></up-icon>
            <text class="grid-text">评分</text>
          </up-grid-item>
          <up-grid-item>
            <up-icon name="map" :size="26"></up-icon>
            <text class="grid-text">地图</text>
          </up-grid-item>
          <up-grid-item>
            <up-icon name="chat" :size="26"></up-icon>
            <text class="grid-text">消息</text>
          </up-grid-item>
        </up-grid>
      </view>

      <!-- Skeleton 骨架屏 -->
      <view class="demo-block">
        <text class="demo-label">
          up-skeleton
        </text>
        <up-skeleton :loading="skeletonLoading" :animate="true" :rows="3" :title="true" :avatar="true"></up-skeleton>
        <view class="h-10px"></view>
        <up-button type="primary" text="切换骨架屏状态" size="mini" @click="toggleSkeleton"></up-button>
      </view>

      <!-- Divider 分割线 -->
      <view class="demo-block">
        <text class="demo-label">
          up-divider
        </text>
        <up-divider text="分割线"></up-divider>
        <up-divider text="虚线" :dashed="true"></up-divider>
      </view>

      <up-divider text="布局组件结束"></up-divider>

      <!-- ==================== 导航组件 ==================== -->
      <text class="section-title">
        导航组件
      </text>
      <up-divider text="导航组件结束"></up-divider>

      <!-- ==================== 展示组件 ==================== -->
      <text class="section-title">
        展示组件
      </text>

      <!-- Card 卡片 -->
      <view class="demo-block">
        <text class="demo-label">
          up-card
        </text>
        <up-card title="基础卡片" sub-title="副标题" margin="0" :show-foot="false">
          <text slot="body" class="text-13px text-[#606266] leading-20px">这是卡片主体内容区域，可以放置任意内容。</text>
        </up-card>
        <view class="h-10px"></view>
        <up-card title="带缩略图" thumb="/static/logo.png" :thumb-circle="true" thumb-width="36px" margin="0">
          <text slot="body" class="text-13px text-[#606266] leading-20px">左侧缩略图为圆形，适合展示头像或图标。</text>
          <view slot="foot" class="flex-row justify-between w-full">
            <text class="text-12px text-[#909399]">底部区域</text>
            <text class="text-12px text-[#2979ff]">查看详情</text>
          </view>
        </up-card>
      </view>

      <!-- List 高性能列表 -->
      <view class="demo-block">
        <text class="demo-label">
          up-list
        </text>
        <up-list
          :height="300"
          :lower-threshold="20"
          :refresher-enabled="true"
          :refresher-triggered="listRefreshing"
          @scrolltolower="onListLoadMore"
          @refresherrefresh="onListRefresh"
        >
          <view
            v-for="(item, idx) in listItems"
            :key="idx"
            class="demo-list-cell"
          >
            <view class="demo-list-cell-avatar">
              <up-icon name="account" size="20" color="#ffffff"></up-icon>
            </view>
            <view class="demo-list-cell-content">
              <text class="text-14px font-500 text-[#303133]">{{ item.title as string }}</text>
              <text class="text-12px text-[#909399] mt-4px">{{ item.desc as string }}</text>
            </view>
          </view>
          <view v-if="listLoading" class="list-loading">
            <up-loading-icon mode="circle" size="20"></up-loading-icon>
            <text class="text-12px text-[#909399] ml-8px">加载中...</text>
          </view>
        </up-list>
      </view>

      <up-divider text="展示组件结束"></up-divider>

      <!-- BackTop 回到顶部 -->
      <view class="demo-block">
        <text class="demo-label">
          up-back-top
        </text>
        <text class="text-12px text-[#909399] mb-8px">
          滚动页面，右下角将出现回到顶部按钮
        </text>
      </view>

      <!-- 底部安全间距 -->
      <view class="h-40px"></view>

      <!-- NoNetwork 无网络组件 -->
      <up-no-network></up-no-network>

      <!-- Overlay 遮罩层 -->
      <up-overlay :show="overlayShow" :opacity="overlayOpacity" @click="overlayShow = false">
        <view class="flex-1 items-center justify-center">
          <view class="bg-white rounded-8px p-20px items-center" @click.stop="">
            <up-loading-icon mode="circle"></up-loading-icon>
            <text class="text-14px text-[#303133] mt-10px">加载中，点击遮罩关闭</text>
          </view>
        </view>
      </up-overlay>

      <!-- Toast 组件 -->
      <up-toast ref="uToast"></up-toast>

      <!-- Notify 组件 -->
      <up-notify ref="uNotify"></up-notify>

      <!-- Modal 组件 -->
      <up-modal
        :show="modalShow"
        :title="modalTitle"
        :content="modalContent"
        :show-confirm-button="true"
        :show-cancel-button="modalShowCancel"
        @confirm="onModalConfirm"
        @close="onModalClose"
      ></up-modal>

      <!-- Popup 组件 -->
      <up-popup
        :show="popupShow"
        :mode="popupMode"
        :closeable="true"
        :round="10"
        @close="onPopupClose"
      >
        <view class="p-30px items-center">
          <text class="text-16px text-[#303133]">{{ popupMode }} 弹出层内容</text>
        </view>
      </up-popup>
      <!-- LoadingPage 组件 -->
      <up-loading-page
        :loading="loadingPageShow"
        loading-text="页面正在加载中..."
        loading-mode="circle"
      ></up-loading-page>
      <!-- Calendar 组件 -->
      <up-calendar
        :show="calendarShow"
        mode="range"
        @confirm="onCalendarConfirm"
        @close="calendarShow = false"
      ></up-calendar>
      <!-- Keyboard 组件 -->
      <up-keyboard
        :show="keyboardShow"
        :mode="keyboardMode"
        @change="onKeyboardChange"
        @backspace="onKeyboardBackspace"
        @close="keyboardShow = false"
        @confirm="keyboardShow = false"
        @cancel="keyboardShow = false"
      ></up-keyboard>
      <!-- Picker 组件 -->
      <up-picker
        :show="pickerShow"
        :columns="pickerColumns"
        @confirm="onPickerConfirm"
        @cancel="pickerShow = false"
        @close="pickerShow = false"
      ></up-picker>
      <!-- DatetimePicker 组件 -->
      <up-datetime-picker
        v-model="datetimePickerValue"
        :show="datetimePickerShow"
        mode="date"
        @confirm="onDatetimePickerConfirm"
        @cancel="datetimePickerShow = false"
        @close="datetimePickerShow = false"
      ></up-datetime-picker>
      <!-- ActionSheet 性别选择 -->
      <up-action-sheet
        :show="genderActionShow"
        :actions="genderActions"
        title="请选择性别"
        @select="onGenderSelect"
        @close="genderActionShow = false"
      ></up-action-sheet>
    </scroll-view>

    <!-- BackTop 回到顶部 -->
    <up-back-top
      :scroll-top="scrollTop"
      mode="circle"
      icon="arrow-upward"
      text="顶部"
      :top="200"
      :duration="300"
      :bottom="100"
      :right="20"
      :z-index="99"
      :icon-style="{ fontSize: '20px', color: '#ffffff' }"
      :custom-style="{ backgroundColor: '#2979ff' }"
      @click="onBackTopClick"
    ></up-back-top>
  </view>
</template>

<script setup lang="uts">
import { computed, onMounted, reactive, ref } from 'vue'
import ThemeSwitchCard from '@/src/pages/basic/components/ThemeSwitchCard.uvue'
