</ol>
<h3>6. 预格式文本</h3>
<pre>function hello() {
  console.log("Hello, mp-html!")
}</pre>
<h3>7. 分割线</h3>
<hr />
<p style="text-align:center;color:#909399">以上为 mp-html 组件演示内容</p>`)

function onMpHtmlLoad(): void {
  console.log('mp-html 渲染完成')
}

function onMpHtmlLinktap(e: UTSJSONObject): void {
  console.log('链接点击:', e)
  // eslint-disable-next-line dot-notation
  const href = e['href'] as string
  if (href != null) {
    uni.showToast({ title: `链接: ${href}`, icon: 'none' })
  }
}

function onMpHtmlImgtap(e: UTSJSONObject): void {
  console.log('图片点击:', e)
}

function onMpHtmlError(e: UTSJSONObject): void {
  console.log('mp-html error:', e)
}
</script>

