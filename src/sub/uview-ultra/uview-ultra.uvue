        </up-cell>
        <up-cell title="Button 按钮" is-link @click="goToDemo('button')">
          <template #icon><up-icon name="plus-circle" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Tag 标签" is-link @click="goToDemo('tag')">
          <template #icon><up-icon name="tags" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Badge 徽标" is-link @click="goToDemo('badge')">
          <template #icon><up-icon name="info-circle" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Avatar 头像" is-link @click="goToDemo('avatar')">
          <template #icon><up-icon name="account" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Card 卡片" is-link @click="goToDemo('card')">
          <template #icon><up-icon name="map" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="List 列表" is-link @click="goToDemo('list')">
          <template #icon><up-icon name="list-dot" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Swiper 轮播图" is-link @click="goToDemo('swiper')">
          <template #icon><up-icon name="photo" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Image 图片组件" is-link @click="goToDemo('image')">
          <template #icon><up-icon name="photo" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Transition 动画过渡" is-link @click="goToDemo('transition')">
          <template #icon><up-icon name="play-circle" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
