<template>
  <view class="page-container bg-[#f8fafc] min-h-screen pb-30px">
    <NavBar
      title="uview-ultra 组件演示"
      :auto-back="true"
      :safe-area-inset-top="true"
      bg-color="#ffffff"
    ></NavBar>

    <!-- 顶部 Banner -->
    <view class="p-16px bg-white mb-12px shadow-xs flex-row items-center">
      <image src="/static/logo.png" style="width: 50px; height: 50px;" class="mr-12px rounded-8px" />
      <view class="flex-1">
        <text class="text-16px font-bold text-[#1e293b]">uview-ultra 组件库</text>
        <text class="text-12px text-[#64748b] mt-4px">点击下方任意功能组件，进入独立页面进行演示</text>
      </view>
    </view>

    <ThemeSwitchCard class="mx-12px mb-12px" />

    <!-- 1. 基础与展示组件 -->
    <view class="demo-group-card">
      <text class="group-title">基础与展示组件</text>
      <up-cell-group :border="false">
        <up-cell title="Icon 图标" is-link @click="goToDemo('icon')">
          <template #icon><up-icon name="photo" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Text 文本" is-link @click="goToDemo('text')">
          <template #icon><up-icon name="file-text" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Empty 空白页" is-link @click="goToDemo('empty')">
          <template #icon><up-icon name="info-circle" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Divider 分割线" is-link @click="goToDemo('divider')">
          <template #icon><up-icon name="minus" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="LoadingIcon 加载图标" is-link @click="goToDemo('loading-icon')">
          <template #icon><up-icon name="reload" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
