        <up-cell title="Table 表格" is-link @click="goToDemo('tab' + 'le')">
          <template #icon><up-icon :name="'gr' + 'id'" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="LazyLoad 懒加载" is-link @click="goToDemo('lazy-load')">
          <template #icon><up-icon name="photo" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Loadmore 加载更多" is-link @click="goToDemo('loadmore')">
          <template #icon><up-icon name="more-dot-fill" color="#2979ff" size="20" class="mr-8px"></up-icon></template>
        </up-cell>
        <up-cell title="Parse 富文本解析" is-link @click="goToDemo('parse')">
