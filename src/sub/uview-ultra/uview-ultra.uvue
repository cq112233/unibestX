<script setup lang="uts">
import { computed, nextTick, reactive, ref } from 'vue'
import ThemeSwitchCard from '@/src/pages/basic/components/ThemeSwitchCard.uvue'
import DemoForm from './components/DemoForm.uvue'
import DemoFeedback from './components/DemoFeedback.uvue'
import DemoShow from './components/DemoShow.uvue'
import mpHtml from '../../../uni_modules/mp-html/components/mp-html/mp-html.uvue'

// ==================== BackTop 回到顶部 ====================
const scrollTop = ref(0)
const scrollViewScrollTop = ref(0)
const scrollHeight = ref(0)

onMounted(() => {
  const sysInfo = uni.getWindowInfo()
  scrollHeight.value = sysInfo.windowHeight - 44
})

function onScroll(e: UniScrollEvent): void {
  const currentScrollTop = e.detail.scrollTop
  console.log('scroll-view scrollTop:', currentScrollTop)
  scrollTop.value = currentScrollTop
}
function onBackTopClick(): void {
  // 先把控制位置的变量同步为当前实际位置，然后再变回 0，强制触发 Vue 属性变更响应
  scrollViewScrollTop.value = scrollTop.value
  setTimeout(() => {
    scrollViewScrollTop.value = 0
  }, 20)
}

// ==================== Dropdown 下拉菜单 ====================
const value1 = ref(1)
const value2 = ref(2)
const options1 = ref([
