<template>
  <view class="page-container">
    <NavBar
      title="uview-ultra 组件演示"
      :auto-back="true"
      :safe-area-inset-top="true"
      bg-color="#ffffff"
    ></NavBar>

    <scroll-view :scroll-y="true" direction="vertical" :style="{ height: `${scrollHeight}px` }" :scroll-top="scrollViewScrollTop" :scroll-with-animation="true" @scroll="onScroll">
      <ThemeSwitchCard />

      <!-- ==================== Transition 动画过渡（置顶方便查看） ==================== -->
      <view class="demo-block">
        <text class="demo-label">up-transition 动画过渡</text>

        <!-- 1. 基本使用：fade 淡入淡出 -->
        <text class="demo-sub-label">1. 基本使用（fade 淡入淡出 + 按钮切换）</text>
        <view class="transition-demo-wrapper">
          <up-transition :show="transitionShow1" mode="fade">
            <view class="transition-demo-box transition-demo-blue">
              <text class="text-14px text-white font-500">fade 淡入淡出</text>
            </view>
          </up-transition>
          <up-button type="primary" :text="transitionShow1 ? '隐藏' : '显示'" size="mini" @click="transitionShow1 = !transitionShow1"></up-button>
        </view>

        <!-- 2. 多种动画模式 -->
        <text class="demo-sub-label mt-15px">2. 多种动画模式（fade-up / slide-down / zoom-in / fade-left）</text>
        <view class="transition-demo-grid">
          <view v-for="item in transitionModes" :key="item.getString('mode')" class="transition-demo-item">
            <text class="text-11px text-[#909399] mb-6px">{{ item.getString('mode') }}</text>
            <up-transition :show="(item.getBoolean('show') ?? false) as boolean" :mode="item.getString('mode')">
              <view class="transition-demo-box transition-demo-green">
                <text class="text-12px text-white">{{ item.getString('mode') }}</text>
              </view>
            </up-transition>
            <up-button type="primary" :text="(item.getBoolean('show') ?? false) ? '隐藏' : '显示'" size="mini" @click="toggleTransitionMode(item)"></up-button>
          </view>
        </view>

        <!-- 3. 自定义动画时长 + 缓动 -->
        <text class="demo-sub-label mt-15px">3. 自定义时长 + 缓动（duration="800" timing-function="linear"）</text>
        <view class="transition-demo-wrapper">
          <up-transition :show="transitionShow3" mode="slide-right" :duration="800" timing-function="linear">
            <view class="transition-demo-box transition-demo-orange">
              <text class="text-14px text-white font-500">slide-right · 800ms · linear</text>
            </view>
          </up-transition>
          <up-button type="warning" :text="transitionShow3 ? '隐藏' : '显示'" size="mini" @click="transitionShow3 = !transitionShow3"></up-button>
        </view>
      </view>

      <!-- ==================== QRCode 二维码（置顶方便查看） ==================== -->
      <view class="demo-block">
        <text class="demo-label">up-qrcode 二维码</text>

        <!-- 1. 基本使用 -->
        <text class="demo-sub-label">1. 基本使用（size + val）</text>
        <view class="qrcode-demo-row">
          <up-qrcode :size="180" val="https://uview-ultra.lingyun.net"></up-qrcode>
        </view>

        <!-- 2. 带 Logo 图标 -->
        <text class="demo-sub-label mt-15px">2. 带中间 Logo 图标（icon）</text>
        <view class="qrcode-demo-row">
          <up-qrcode :size="180" val="uview-ultra" icon="https://uview-ultra.jiangruyi.com/uview-ultra/common/logo.png"></up-qrcode>
        </view>

        <!-- 3. 自定义颜色 -->
        <text class="demo-sub-label mt-15px">3. 自定义颜色（background / foreground）</text>
        <view class="qrcode-demo-row">
          <up-qrcode :size="160" val="hello world" background="#19be6b" foreground="#ffffff"></up-qrcode>
        </view>

        <!-- 4. 加载状态 -->
        <text class="demo-sub-label mt-15px">4. 加载状态（showLoading + loadingText）</text>
        <view class="qrcode-demo-row">
          <up-qrcode :size="160" val="https://github.com" :show-loading="true" loading-text="生成中..." @result="onQrcodeResult"></up-qrcode>
        </view>
      </view>

      <!-- ==================== Parse 富文本解析（置顶方便查看） ==================== -->
      <view class="demo-block">
        <text class="demo-label">up-parse 富文本解析</text>

        <!-- 1. 基本使用：段落 + 图片 -->
        <text class="demo-sub-label">1. 基本使用（段落 + 图片）</text>
        <view class="parse-demo-wrapper">
          <up-parse :content="parseContent1"></up-parse>
        </view>

        <!-- 2. 富文本样式：标题、加粗、斜体、引用、代码 -->
        <text class="demo-sub-label mt-15px">2. 富文本样式（h1~h6 / b / i / blockquote / code / pre）</text>
        <view class="parse-demo-wrapper">
          <up-parse :content="parseContent2"></up-parse>
        </view>

        <!-- 3. 图片 + 链接 + 预览 -->
        <text class="demo-sub-label mt-15px">3. 图片 + 链接 + 预览（:preview-img="true" @imgTap @linkTap）</text>
        <view class="parse-demo-wrapper">
          <up-parse :content="parseContent3" :preview-img="true" @img-tap="onParseImgTap" @link-tap="onParseLinkTap"></up-parse>
        </view>

        <!-- 4. 表格渲染 -->
        <text class="demo-sub-label mt-15px">4. 表格渲染（table / tr / th / td）</text>
        <view class="parse-demo-wrapper">
          <up-parse :content="parseContent4"></up-parse>
        </view>

        <!-- 5. 自定义标签样式 + 长按复制 -->
        <text class="demo-sub-label mt-15px">5. 自定义标签样式（tagStyle）+ 长按复制（:selectable="true"）</text>
        <view class="parse-demo-wrapper">
          <up-parse :content="parseContent5" :tag-style="parseTagStyle" :selectable="true"></up-parse>
        </view>
      </view>

      <!-- ==================== Steps 步骤条（置顶方便查看） ==================== -->
      <view class="demo-block">
        <text class="demo-label">up-steps 步骤条</text>

        <!-- 1. 基本使用 -->
        <text class="demo-sub-label">1. 基本使用（current + title + desc）</text>
        <up-steps current="0">
          <up-steps-item title="已下单" desc="10:30"></up-steps-item>
          <up-steps-item title="已出库" desc="10:35"></up-steps-item>
          <up-steps-item title="运输中" desc="11:40"></up-steps-item>
        </up-steps>

        <!-- 2. 错误状态 -->
        <text class="demo-sub-label mt-15px">2. 错误状态（error="true"）</text>
        <up-steps current="1">
          <up-steps-item title="已下单" desc="10:30"></up-steps-item>
          <up-steps-item title="仓库着火" desc="10:35" :error="true"></up-steps-item>
          <up-steps-item title="破产清算" desc="11:40"></up-steps-item>
        </up-steps>

        <!-- 3. 点状模式 -->
        <text class="demo-sub-label mt-15px">3. 点状模式（dot）</text>
        <up-steps current="1" :dot="true">
          <up-steps-item title="已下单" desc="10:30"></up-steps-item>
          <up-steps-item title="已出库" desc="10:35"></up-steps-item>
          <up-steps-item title="运输中" desc="11:40"></up-steps-item>
        </up-steps>

        <!-- 4. 竖向模式 -->
        <text class="demo-sub-label mt-15px">4. 竖向模式（direction="column"）</text>
        <up-steps current="1" direction="column">
          <up-steps-item title="已下单" desc="2026-06-23 10:30"></up-steps-item>
          <up-steps-item title="已出库" desc="2026-06-23 10:35"></up-steps-item>
          <up-steps-item title="运输中" desc="2026-06-23 11:40"></up-steps-item>
        </up-steps>

        <!-- 5. 自定义图标 -->
        <text class="demo-sub-label mt-15px">5. 自定义图标（activeIcon + inactiveIcon）</text>
        <up-steps current="1" active-icon="checkmark" inactive-icon="arrow-right">
          <up-steps-item title="已下单" desc="10:30"></up-steps-item>
          <up-steps-item title="已出库" desc="10:35"></up-steps-item>
          <up-steps-item title="运输中" desc="11:40"></up-steps-item>
        </up-steps>

        <!-- 6. Slot 自定义图标 -->
        <text class="demo-sub-label mt-15px">6. Slot 自定义图标（#icon）</text>
        <up-steps current="1">
          <up-steps-item title="已下单" desc="10:30"></up-steps-item>
          <up-steps-item title="已出库" desc="10:35"></up-steps-item>
          <up-steps-item title="运输中" desc="11:40">
            <template #icon>
              <text class="steps-slot-icon">运</text>
            </template>
          </up-steps-item>
        </up-steps>

        <!-- 7. 自定义颜色 -->
        <text class="demo-sub-label mt-15px">7. 自定义颜色（activeColor / inactiveColor）</text>
        <up-steps current="2" active-color="#19be6b" inactive-color="#909399">
          <up-steps-item title="提交订单" desc="已完成"></up-steps-item>
          <up-steps-item title="商家审核" desc="已通过"></up-steps-item>
          <up-steps-item title="派送中" desc="进行中"></up-steps-item>
          <up-steps-item title="确认收货" desc="待完成"></up-steps-item>
        </up-steps>
      </view>

      <!-- ==================== NavbarMini 迷你导航栏（置顶方便查看） ==================== -->
      <view class="demo-block">
        <text class="demo-label">up-navbar-mini 迷你导航栏</text>

        <!-- 1. 基本使用：固定在顶部，安全区域适配 -->
        <text class="demo-sub-label">1. 基本使用（固定顶部 + 安全区域适配）</text>
        <view class="navbar-mini-demo-wrapper">
          <up-navbar-mini
            :fixed="false"
            :safe-area-inset-top="false"
            left-icon="arrow-left"
            bg-color="rgba(41,121,255,0.85)"
            icon-color="#ffffff"
            :icon-size="18"
            height="32px"
            @left-click="onNavbarMiniLeftClick"
            @home-click="onNavbarMiniHomeClick"
          ></up-navbar-mini>
        </view>

        <!-- 2. 自定义背景色、图标颜色 -->
        <text class="demo-sub-label mt-15px">2. 自定义背景色和图标颜色</text>
        <view class="navbar-mini-demo-row">
          <view class="navbar-mini-demo-item">
            <up-navbar-mini
              :fixed="false"
              :safe-area-inset-top="false"
              bg-color="rgba(25,190,107,0.85)"
              icon-color="#ffffff"
              :icon-size="16"
              height="30px"
            ></up-navbar-mini>
          </view>
          <view class="navbar-mini-demo-item">
            <up-navbar-mini
              :fixed="false"
              :safe-area-inset-top="false"
              bg-color="rgba(250,53,52,0.85)"
              icon-color="#ffffff"
              :icon-size="16"
              height="30px"
            ></up-navbar-mini>
          </view>
          <view class="navbar-mini-demo-item">
            <up-navbar-mini
              :fixed="false"
              :safe-area-inset-top="false"
              bg-color="rgba(156,39,176,0.85)"
              icon-color="#ffffff"
              :icon-size="16"
              height="30px"
            ></up-navbar-mini>
          </view>
        </view>

        <!-- 3. 自动返回上一页 + 自定义首页路径 -->
        <text class="demo-sub-label mt-15px">3. 自动返回上一页（:auto-back="true"）+ 自定义首页路径</text>
        <view class="navbar-mini-demo-wrapper">
          <up-navbar-mini
            :fixed="false"
            :safe-area-inset-top="false"
            :auto-back="true"
            home-url="/"
            bg-color="rgba(255,152,0,0.85)"
            icon-color="#ffffff"
            :icon-size="18"
            height="32px"
          ></up-navbar-mini>
        </view>

        <!-- 4. 自定义 slot（左侧图和中间图替换） -->
        <text class="demo-sub-label mt-15px">4. 自定义 slot 图标</text>
        <view class="navbar-mini-demo-wrapper">
          <up-navbar-mini
            :fixed="false"
            :safe-area-inset-top="false"
            bg-color="rgba(0,0,0,0.6)"
            :icon-size="18"
            height="34px"
          >
            <template #left>
              <up-icon name="arrow-left" size="18" color="#ffffff"></up-icon>
            </template>
            <template #center>
              <up-icon name="search" size="18" color="#ffffff"></up-icon>
            </template>
          </up-navbar-mini>
        </view>
      </view>

      <!-- ==================== Tabs 标签页（置顶方便查看） ==================== -->
      <view class="demo-block">
        <text class="demo-label">up-tabs 标签页</text>

        <!-- 1. 基本使用：list + @click + @change -->
        <text class="demo-sub-label">1. 基本使用（list 数组 + @click + @change）</text>
        <up-tabs :list="tabsList1" @click="onTabsClick" @change="onTabsChange"></up-tabs>

        <!-- 2. 显示徽标 + 禁用 -->
        <text class="demo-sub-label mt-15px">2. 显示徽标（badge.isDot / badge.value）+ 禁用（disabled）</text>
        <up-tabs :list="tabsList2" @click="onTabsClick"></up-tabs>

        <!-- 3. 自定义样式 -->
        <text class="demo-sub-label mt-15px">3. 自定义样式（activeStyle / inactiveStyle / itemStyle / lineWidth / lineColor）</text>
        <up-tabs
          :list="tabsList4"
          line-width="30"
          line-color="#f56c6c"
          :active-style="{ color: '#303133', fontWeight: 'bold' }"
          :inactive-style="{ color: '#606266' }"
          item-style="padding-left: 15px; padding-right: 15px; height: 34px;"
          @click="onTabsClick"
        ></up-tabs>

        <!-- 4. 不可滚动（scrollable=false） -->
        <text class="demo-sub-label mt-15px">4. 不可滚动（:scrollable="false"）- 适用于标签少的场景</text>
        <up-tabs :list="tabsList4Small" :scrollable="false" @click="onTabsClick"></up-tabs>

        <!-- 5. 右侧自定义插槽 -->
        <text class="demo-sub-label mt-15px">5. 右侧自定义插槽（#right slot）</text>
        <up-tabs :list="tabsList1">
          <template #right>
            <view class="tabs-right-slot" @tap.stop="onTabsRightClick">
              <up-icon name="list" size="21" bold></up-icon>
            </view>
          </template>
        </up-tabs>
      </view>

      <!-- ==================== Tabbar 底部导航栏（置顶方便查看） ==================== -->
      <view class="demo-block">
        <text class="demo-label">up-tabbar 底部导航栏</text>

        <!-- 1. 基本使用：value + @change + name 匹配 -->
        <text class="demo-sub-label">1. 基本使用（数字 name 匹配 value）</text>
        <view class="tabbar-demo-wrapper">
          <up-tabbar
            :value="tabbarValue1"
            :fixed="false"
            :placeholder="false"
            :safe-area-inset-bottom="false"
            @change="(e: number | string) => onTabbarChange1(e)"
          >
            <up-tabbar-item text="首页" icon="home" name="0"></up-tabbar-item>
            <up-tabbar-item text="放映厅" icon="photo" name="1"></up-tabbar-item>
            <up-tabbar-item text="直播" icon="play-right" name="2"></up-tabbar-item>
            <up-tabbar-item text="我的" icon="account" name="3"></up-tabbar-item>
          </up-tabbar>
        </view>

        <!-- 2. 徽标：dot 和 badge -->
        <text class="demo-sub-label mt-15px">2. 显示徽标（dot 小圆点 + badge 数字）</text>
        <view class="tabbar-demo-wrapper">
          <up-tabbar
            :value="tabbarValue2"
            :fixed="false"
            :placeholder="false"
            :safe-area-inset-bottom="false"
            @change="(e: number | string) => onTabbarChange2(e)"
          >
            <up-tabbar-item text="首页" icon="home" dot name="0"></up-tabbar-item>
            <up-tabbar-item text="消息" icon="chat" badge="3" name="1"></up-tabbar-item>
            <up-tabbar-item text="购物车" icon="cart" badge="99+" name="2"></up-tabbar-item>
            <up-tabbar-item text="我的" icon="account" name="3"></up-tabbar-item>
          </up-tabbar>
        </view>

        <!-- 3. 字符串 name 匹配 -->
        <text class="demo-sub-label mt-15px">3. 字符串 name 匹配</text>
        <view class="tabbar-demo-wrapper">
          <up-tabbar
            :value="tabbarValue3"
            :fixed="false"
            :placeholder="false"
            :safe-area-inset-bottom="false"
            @change="(e: number | string) => onTabbarChange3(e)"
          >
            <up-tabbar-item text="首页" icon="home" name="home"></up-tabbar-item>
            <up-tabbar-item text="分类" icon="list-dot" name="category"></up-tabbar-item>
            <up-tabbar-item text="消息" icon="chat" name="message"></up-tabbar-item>
            <up-tabbar-item text="我的" icon="account" name="mine"></up-tabbar-item>
          </up-tabbar>
        </view>

        <!-- 4. 自定义选中颜色 -->
        <text class="demo-sub-label mt-15px">4. 自定义选中颜色（active-color / inactive-color）</text>
        <view class="tabbar-demo-wrapper">
          <up-tabbar
            :value="tabbarValue4"
            :fixed="false"
            :placeholder="false"
            :safe-area-inset-bottom="false"
            active-color="#d81e06"
            inactive-color="#999999"
            @change="(e: number | string) => onTabbarChange4(e)"
          >
            <up-tabbar-item text="首页" icon="home" name="0"></up-tabbar-item>
            <up-tabbar-item text="放映厅" icon="photo" name="1"></up-tabbar-item>
            <up-tabbar-item text="直播" icon="play-right" name="2"></up-tabbar-item>
            <up-tabbar-item text="我的" icon="account" name="3"></up-tabbar-item>
          </up-tabbar>
        </view>

        <!-- 5. 自定义插槽图标（active-icon / inactive-icon slot） -->
        <text class="demo-sub-label mt-15px">5. 自定义插槽图标（active-icon / inactive-icon slot）</text>
        <view class="tabbar-demo-wrapper">
          <up-tabbar
            :value="tabbarValue5"
            :fixed="false"
            :placeholder="false"
            :safe-area-inset-bottom="false"
            active-color="#2979ff"
            @change="(e: number | string) => onTabbarChange5(e)"
          >
            <up-tabbar-item text="首页" name="0">
              <template #active-icon>
                <image
                  class="tabbar-slot-icon"
                  src="https://cdn.uviewui.com/uview/common/bell-selected.png"
                ></image>
              </template>
              <template #inactive-icon>
                <image
                  class="tabbar-slot-icon"
                  src="https://cdn.uviewui.com/uview/common/bell.png"
                ></image>
              </template>
            </up-tabbar-item>
            <up-tabbar-item text="放映厅" icon="photo" name="1"></up-tabbar-item>
            <up-tabbar-item text="直播" icon="play-right" name="2"></up-tabbar-item>
            <up-tabbar-item text="我的" icon="account" name="3"></up-tabbar-item>
          </up-tabbar>
        </view>

        <!-- 6. 移除顶部边框 -->
        <text class="demo-sub-label mt-15px">6. 移除顶部边框（:border="false"）</text>
        <view class="tabbar-demo-wrapper">
          <up-tabbar
            :value="tabbarValue6"
            :fixed="false"
            :placeholder="false"
            :safe-area-inset-bottom="false"
            :border="false"
            @change="(e: number | string) => onTabbarChange6(e)"
          >
            <up-tabbar-item text="首页" icon="home" name="0"></up-tabbar-item>
            <up-tabbar-item text="放映厅" icon="photo" name="1"></up-tabbar-item>
            <up-tabbar-item text="直播" icon="play-right" name="2"></up-tabbar-item>
            <up-tabbar-item text="我的" icon="account" name="3"></up-tabbar-item>
          </up-tabbar>
        </view>

        <!-- 7. 拦截切换（change 事件校验） -->
        <text class="demo-sub-label mt-15px">7. 拦截切换（点击"放映厅"弹 toast 拦截）</text>
        <view class="tabbar-demo-wrapper">
          <up-tabbar
            :value="tabbarValue7"
            :fixed="false"
            :placeholder="false"
            :safe-area-inset-bottom="false"
            @change="(e: number | string) => onTabbarChange7(e)"
          >
            <up-tabbar-item text="首页" icon="home" name="0"></up-tabbar-item>
            <up-tabbar-item text="放映厅" icon="photo" name="1"></up-tabbar-item>
            <up-tabbar-item text="直播" icon="play-right" name="2"></up-tabbar-item>
            <up-tabbar-item text="我的" icon="account" name="3"></up-tabbar-item>
          </up-tabbar>
        </view>
      </view>

      <!-- ReadMore 展开阅读更多 -->
      <view class="demo-block">
        <text class="demo-label">
          up-read-more 展开阅读更多
        </text>
        <!-- 基本使用 -->
        <up-read-more show-height="120">
          <rich-text :nodes="readMoreContent"></rich-text>
        </up-read-more>
        <!-- 带展开/收起切换 -->
        <view class="mt-10px">
          <up-read-more :toggle="true" show-height="120" close-text="展开阅读全文" open-text="收起">
            <rich-text :nodes="readMoreContent"></rich-text>
          </up-read-more>
        </view>
        <!-- 自定义颜色和字号 -->
        <view class="mt-10px">
          <up-read-more show-height="100" color="#19be6b" :font-size="12" close-text="查看更多">
            <rich-text :nodes="readMoreContent"></rich-text>
          </up-read-more>
        </view>
      </view>

      <!-- Avatar 头像 -->
      <view class="demo-block">
        <text class="demo-label">
          up-avatar 头像
        </text>
        <!-- 图片头像：不同形状和尺寸 -->
        <view class="demo-row-start">
          <up-avatar :src="avatarSrc" size="40"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :src="avatarSrc" size="40" shape="square"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :src="avatarSrc" size="55" mode="aspectFill"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar src="/invalid-path.png" size="40" default-url="/static/logo.png"></up-avatar>
        </view>
        <!-- 文字头像 -->
        <view class="demo-row-start mt-10px">
          <up-avatar text="U" size="40" bg-color="#2979ff"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar text="A" size="40" bg-color="#19be6b"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :random-bg-color="true" text="张" size="40"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :random-bg-color="true" text="李" size="40" font-size="16"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar :random-bg-color="true" text="王五" size="45" font-size="14"></up-avatar>
        </view>
        <!-- 图标头像 -->
        <view class="demo-row-start mt-10px">
          <up-avatar icon="star-fill" size="40" bg-color="#ffca28" font-size="22"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar icon="heart-fill" size="40" bg-color="#fa3534" font-size="22"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar icon="setting-fill" size="40" bg-color="#909399" font-size="22"></up-avatar>
          <view class="w-15px"></view>
          <up-avatar icon="photo-fill" size="40" bg-color="#19be6b" font-size="22"></up-avatar>
        </view>
        <!-- 头像组 -->
        <view class="demo-row-start mt-10px items-center">
          <text class="text-12px text-[#909399] mr-10px">头像组:</text>
          <up-avatar-group :urls="avatarGroupUrls" size="35" :gap="0.4" :max-count="5" :show-more="true" @show-more="onAvatarGroupMore"></up-avatar-group>
        </view>
        <!-- 可点击头像 -->
        <view class="demo-row-start mt-10px items-center">
          <up-avatar :src="avatarSrc" size="40" @click="onAvatarClick"></up-avatar>
          <text class="text-12px text-[#909399] ml-10px">点击头像可触发事件</text>
        </view>
      </view>

      <!-- Link 超链接 -->
      <view class="demo-block">
        <text class="demo-label">
          up-link 超链接
        </text>
        <!-- 基本使用 -->
        <view class="demo-row-start">
          <up-link href="https://uview-ultra.lingyun.net" text="打开 uview-ultra UI 文档" @click="onLinkClick"></up-link>
        </view>
        <!-- 带下划线 -->
        <view class="demo-row-start mt-8px">
          <up-link href="https://uniapp.dcloud.net.cn" text="uni-app X 官方文档" :under-line="true" @click="onLinkClick"></up-link>
        </view>
        <!-- 自定义颜色 + 下划线颜色 -->
        <view class="demo-row-start mt-8px">
          <up-link href="https://github.com" text="GitHub" color="#19be6b" line-color="#19be6b" :under-line="true" font-size="16" @click="onLinkClick"></up-link>
          <view class="w-20px"></view>
          <up-link href="https://www.baidu.com" text="百度一下" color="#fa3534" line-color="#fa3534" :under-line="true" font-size="16" @click="onLinkClick"></up-link>
          <view class="w-20px"></view>
          <up-link href="https://www.zhihu.com" text="知乎" color="#ff9900" font-size="16" @click="onLinkClick"></up-link>
        </view>
        <!-- 小程序复制提示 -->
        <view class="demo-row-start mt-8px">
          <up-link href="https://uview-ultra.lingyun.net" text="小程序内打开（复制链接到浏览器）" :under-line="true" mp-tips="链接已复制，请在浏览器中打开" font-size="13" color="#909399" @click="onLinkClick"></up-link>
        </view>
      </view>

      <!-- LazyLoad 懒加载 -->
      <view class="demo-block">
        <text class="demo-label">
          up-lazy-load 懒加载
        </text>
        <!-- 基本使用 -->
        <view class="demo-row-start">
          <view class="lazy-load-item">
            <up-lazy-load
              image="https://gtd.alicdn.com/sns_logo/i1/TB124_3NXXXXXasXVXXSutbFXXX.jpg_240x240xz.jpg"
              loading-img="/static/logo.png"
              :height="1020"
              :border-radius="8"
              index="img1"
              @click="onLazyLoadClick"
              @error="onLazyLoadError"
            ></up-lazy-load>
          </view>
          <view class="lazy-load-item">
            <up-lazy-load
              image="https://picsum.photos/240/240?random=22"
              loading-img="/static/logo.png"
              :height="120"
              :border-radius="8"
              index="img2"
              @click="onLazyLoadClick"
              @error="onLazyLoadError"
            ></up-lazy-load>
          </view>
          <view class="lazy-load-item">
            <up-lazy-load
              image="https://picsum.photos/240/240?random=23"
              loading-img="/static/logo.png"
              :height="120"
              :border-radius="8"
              index="img3"
              @click="onLazyLoadClick"
              @error="onLazyLoadError"
            ></up-lazy-load>
          </view>
        </view>
        <!-- 占位图 + 错误图 -->
        <view class="demo-row-start mt-10px items-center">
          <view class="lazy-load-item">
            <up-lazy-load
              image="https://invalid-url-test/not-exist.png"
              loading-img="/static/logo.png"
              error-img="/static/logo.png"
              :height="100"
              :border-radius="8"
              index="error-img"
            ></up-lazy-load>
          </view>
          <text class="text-12px text-[#909399] ml-10px">加载失败自动展示 error-img 占位图</text>
        </view>
      </view>

      <!-- mp-html 富文本 -->
      <view class="demo-block">
        <text class="demo-label">
          mp-html 富文本
        </text>
        <mp-html
          :content="mpHtmlContent"
          :preview-img="true"
          :show-img-menu="true"
          :selectable="true"
          @load="onMpHtmlLoad"
          @linktap="onMpHtmlLinktap"
          @imgtap="onMpHtmlImgtap"
          @error="onMpHtmlError"
        ></mp-html>
      </view>

      <!-- Loadmore 加载更多 -->
      <view class="demo-block">
        <text class="demo-label">
          up-loadmore
        </text>
        <view class="flex-col items-center">
          <up-loadmore :status="loadmoreStatus" :is-dot="loadmoreIsDot" :line="true"></up-loadmore>
          <view class="demo-row mt-10px">
            <up-button type="primary" text="加载更多" size="mini" @click="loadmoreStatus = 'loadmore'; loadmoreIsDot = false"></up-button>
            <up-button type="warning" text="加载中" size="mini" @click="loadmoreStatus = 'loading'; loadmoreIsDot = false"></up-button>
            <up-button type="info" text="没有更多" size="mini" @click="loadmoreStatus = 'nomore'; loadmoreIsDot = false"></up-button>
            <up-button type="error" text="显示圆点" size="mini" @click="loadmoreStatus = 'nomore'; loadmoreIsDot = true"></up-button>
          </view>
        </view>
      </view>

      <!-- Album 相册 -->
      <view class="demo-block">
        <text class="demo-label">
          up-album
        </text>
        <up-album
          :urls="albumUrls"
          multiple-size="72"
          space="6"
          :max-count="9"
          :show-more="true"
          row-count="3"
          radius="6"
        ></up-album>
      </view>

      <!-- IndexList 索引列表 -->
      <view class="demo-block">
        <text class="demo-label">
          up-index-list
        </text>
        <view class="index-list-demo-wrapper">
          <up-index-list :index-list="indexList" :sticky="true">
            <template v-for="(item, index) in itemArr" :key="index">
              <up-index-item>
                <up-index-anchor :text="indexList[index]"></up-index-anchor>
                <view v-for="(cell, cellIndex) in item" :key="cellIndex" class="list-cell">
                  <text class="list-cell-text">{{ cell as string }}</text>
                </view>
              </up-index-item>
            </template>
          </up-index-list>
        </view>
      </view>

      <!-- Navbar 导航栏 -->
      <view class="demo-block">
        <text class="demo-label">
          up-navbar
        </text>
        <up-navbar
          title="自定义导航栏"
          :fixed="false"
          :auto-back="false"
          :safe-area-inset-top="false"
          bg-color="#2979ff"
        ></up-navbar>
        <view class="h-10px"></view>

        <up-navbar
          title="浅色主题"
          :fixed="false"
          :auto-back="false"
          :safe-area-inset-top="false"
          bg-color="#ffffff"
          :border="true"
        ></up-navbar>

        <view class="h-10px"></view>

        <up-navbar
          title="带返回按钮"
          :fixed="false"
          :auto-back="true"
          :safe-area-inset-top="false"
          bg-color="#f5f5f5"
        ></up-navbar>

        <view class="h-10px"></view>

        <up-navbar
          title="自定义标题"
          :fixed="false"
          :auto-back="false"
          :safe-area-inset-top="false"
          bg-color="#ffffff"
          :border="true"
          left-text="返回"
          right-text="更多"
        ></up-navbar>

        <view class="h-10px"></view>

        <up-navbar
          title="自定义图标"
          :fixed="false"
          :auto-back="false"
          :safe-area-inset-top="false"
          bg-color="#ffffff"
          :border="true"
          left-text="返回"
          left-icon="arrow-left"
          right-icon="setting"
        ></up-navbar>

        <view class="h-10px">
        </view>
        <up-navbar
          :fixed="false"
          left-text="返回"
          title="个人中心"
          :safe-area-inset-top="false"
        >
          <template #left>
            <view
              class="u-nav-slot"
            >
              <up-icon
                name="arrow-left"
                size="19"
              ></up-icon>
              <up-line
                direction="column"
                :hairline="false"
                length="16"
                margin="0 8px"
              ></up-line>
              <up-icon
                name="home"
                size="20"
              ></up-icon>
            </view>
          </template>
        </up-navbar>
      </view>

      <!-- Subsection 分段器 -->
      <view class="demo-block">
        <text class="demo-label">
          up-subsection
        </text>
        <up-subsection :list="subsectionList" :current="subsectionCurrent" @change="onSubsectionChange"></up-subsection>
      </view>

      <!-- Waterfall 瀑布流 -->
      <view class="demo-block">
        <text class="demo-label">up-waterfall</text>
        <view class="waterfall-container">
          <view class="waterfall-column">
            <view v-for="item in waterfallLeftList" :key="item.getString('id')" class="waterfall-card">
              <image :src="item.getString('image')" mode="widthFix" class="waterfall-image"></image>
              <view class="waterfall-info">
                <text class="waterfall-title">{{ item.getString('title') }}</text>
                <text class="waterfall-price">{{ item.getString('price') }}</text>
              </view>
            </view>
          </view>
          <view class="waterfall-column waterfall-column-right">
            <view v-for="item in waterfallRightList" :key="item.getString('id')" class="waterfall-card">
              <image :src="item.getString('image')" mode="widthFix" class="waterfall-image"></image>
              <view class="waterfall-info">
                <text class="waterfall-title">{{ item.getString('title') }}</text>
                <text class="waterfall-price">{{ item.getString('price') }}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="demo-row mt-10px">
          <up-button type="primary" text="加载更多" size="mini" @click="loadMoreWaterfall"></up-button>
          <up-button type="info" text="清空" size="mini" @click="clearWaterfall"></up-button>
        </view>
      </view>

      <!-- Dropdown 下拉菜单 -->
      <view class="demo-block">
        <text class="demo-label">up-dropdown 下拉菜单</text>

        <!-- 1. 基本使用：多列选项 -->
        <text class="demo-sub-label">1. 基本使用（多列选项）</text>
        <up-dropdown>
          <up-dropdown-item v-model="value1" title="距离" :options="options1"></up-dropdown-item>
          <up-dropdown-item v-model="value2" title="温度" :options="options2"></up-dropdown-item>
        </up-dropdown>
      </view>

      <!-- 2. 自定义颜色 + 圆角 + 图标 -->
      <view class="demo-block">
        <text class="demo-sub-label">2. 自定义颜色、圆角、图标、字号</text>
        <up-dropdown
          active-color="#19be6b"
          inactive-color="#909399"
          :border-radius="12"
          menu-icon="arrow-down-fill"
          menu-icon-size="22"
          title-size="26"
          :border-bottom="true"
        >
          <up-dropdown-item v-model="dropdownGreenValue1" title="区域" :options="dropdownRegionOptions1"></up-dropdown-item>
          <up-dropdown-item v-model="dropdownGreenValue2" title="排序" :options="dropdownRegionOptions2"></up-dropdown-item>
        </up-dropdown>
      </view>

      <!-- 3. 禁用某个选项卡 -->
      <view class="demo-block">
        <text class="demo-sub-label">3. 禁用某个选项卡</text>
        <up-dropdown>
          <up-dropdown-item v-model="dropdownDisValue1" title="正常项" :options="options1"></up-dropdown-item>
          <up-dropdown-item title="已禁用" :options="options2" :disabled="true"></up-dropdown-item>
        </up-dropdown>
      </view>

      <!-- 4. 选项点击事件 + 控制关闭行为 -->
      <view class="demo-block">
        <text class="demo-sub-label">4. 点击遮罩/自身标题不关闭，选项 change 事件</text>
        <text class="text-12px text-[#909399] mb-6px">当前选中值: {{ dropdownEventValue }}</text>
        <up-dropdown :close-on-click-mask="false" :close-on-click-self="false">
          <up-dropdown-item
            v-model="dropdownEventValue"
            title="选项（不自动关）"
            :options="options1"
            @change="(value: string | number) => onDropdownChange(value)"
          ></up-dropdown-item>
        </up-dropdown>
      </view>

      <!-- 5. 自定义 Slot 内容 -->
      <view class="demo-block">
        <text class="demo-sub-label">5. 自定义 Slot 内容（带按钮关闭）</text>
        <up-dropdown ref="uDropdownRef1">
          <up-dropdown-item title="自定义">
            <view class="dropdown-slot-content">
              <view class="text-14px text-[#606266] text-center py-15px">
                其他自定义内容
              </view>
              <view class="text-12px text-[#909399] text-center pb-15px">
                可以放任意组件或表单
              </view>
              <up-button type="primary" text="确定" size="mini" @click="closeDropdown('uDropdownRef1')"></up-button>
            </view>
          </up-dropdown-item>
        </up-dropdown>
      </view>

      <!-- 6. Slot 内嵌 scroll-view 滚动 -->
      <view class="demo-block">
        <text class="demo-sub-label">6. Slot 内嵌 scroll-view 滚动内容</text>
        <up-dropdown ref="uDropdownRef2">
          <up-dropdown-item title="滚动列表">
            <view class="dropdown-slot-content" style="background-color: #ffffff;">
              <scroll-view scroll-y="true" style="height: 180px;">
                <view
                  v-for="i in 15"
                  :key="i"
                  class="dropdown-scroll-item"
                  @click="onDropdownScrollSelect(i); closeDropdown('uDropdownRef2')"
                >
                  <text class="text-14px text-[#303133]">选项 {{ i }}</text>
                  <text class="text-12px text-[#909399]">这是第 {{ i }} 项的描述信息</text>
                </view>
              </scroll-view>
              <view class="dropdown-scroll-footer">
                <up-button type="info" text="关闭" size="mini" @click="closeDropdown('uDropdownRef2')"></up-button>
              </view>
            </view>
          </up-dropdown-item>
        </up-dropdown>
        <text class="text-12px text-[#909399] mt-6px">已选滚动项: {{ dropdownScrollSelected }}</text>
      </view>

      <!-- 7. 保持菜单高亮 -->
      <view class="demo-block">
        <text class="demo-sub-label">7. 手动控制菜单高亮（open / close 事件 + highlight 方法）</text>
        <up-dropdown ref="uDropdownRef3" @open="onDropdownOpen" @close="onDropdownClose">
          <up-dropdown-item v-model="dropdownHLValue1" title="距离" :options="options1"></up-dropdown-item>
          <up-dropdown-item v-model="dropdownHLValue2" title="温度" :options="options2"></up-dropdown-item>
        </up-dropdown>
      </view>

      <!-- 8. 自定义 Slot 多列宫格布局 -->
      <view class="demo-block">
        <text class="demo-sub-label">8. 自定义 Slot 多列宫格布局（模拟服务分类菜单）</text>
        <up-dropdown ref="uDropdownRefGrid1">
          <up-dropdown-item title="分类">
            <view class="dropdown-grid-panel">
              <up-row gutter="10" justify="space-between">
                <up-col v-for="item in dropdownGridItems" :key="item.getString('text')" span="6">
                  <view
                    class="dropdown-grid-item"
                    @click="onDropdownGridSelect(item.getString('text') ?? ''); closeDropdown('uDropdownRefGrid1')"
                  >
                    <view class="dropdown-grid-icon">
                      <up-icon :name="item.getString('icon')" size="24" :color="item.getString('color') ?? '#2979ff'"></up-icon>
                    </view>
                    <text class="dropdown-grid-label">{{ item.getString('text') }}</text>
                  </view>
                </up-col>
              </up-row>
            </view>
          </up-dropdown-item>
          <up-dropdown-item title="筛选">
            <view class="dropdown-grid-panel">
              <up-row gutter="10" justify="space-between">
                <up-col v-for="item in dropdownGridFilterItems" :key="item.getString('text')" span="6">
                  <view
                    class="dropdown-grid-item"
                    @click="onDropdownGridSelect(item.getString('text') ?? ''); closeDropdown('uDropdownRefGrid1')"
                  >
                    <view class="dropdown-grid-icon">
                      <up-icon :name="item.getString('icon')" size="24" :color="item.getString('color') ?? '#19be6b'"></up-icon>
                    </view>
                    <text class="dropdown-grid-label">{{ item.getString('text') }}</text>
                  </view>
                </up-col>
              </up-row>
            </view>
          </up-dropdown-item>
        </up-dropdown>
        <text class="text-12px text-[#909399] mt-6px">已选宫格项: {{ dropdownGridSelected }}</text>
      </view>

      <!-- 9. 自定义 Slot 卡片式布局 -->
      <view class="demo-block">
        <text class="demo-sub-label">9. 自定义 Slot 卡片式布局（带图片 + 标题 + 描述）</text>
        <up-dropdown ref="uDropdownRefCard">
          <up-dropdown-item title="热门推荐">
            <view class="dropdown-card-panel">
              <view class="dropdown-card-grid">
                <view
                  v-for="card in dropdownCardItems"
                  :key="card.getString('id')"
                  class="dropdown-card"
                  @click="onDropdownCardSelect(card.getString('title') ?? ''); closeDropdown('uDropdownRefCard')"
                >
                  <image
                    :src="card.getString('image')"
                    mode="aspectFill"
                    class="dropdown-card-img"
                  ></image>
                  <view class="dropdown-card-body">
                    <text class="dropdown-card-title">{{ card.getString('title') }}</text>
                    <text class="dropdown-card-desc">{{ card.getString('desc') }}</text>
                    <view class="dropdown-card-footer">
                      <text class="dropdown-card-price">{{ card.getString('price') }}</text>
                      <view class="dropdown-card-tag">
                        <text class="dropdown-card-tag-text">{{ card.getString('tag') }}</text>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </up-dropdown-item>
          <up-dropdown-item title="新品上市">
            <view class="dropdown-card-panel">
              <view class="dropdown-card-grid">
                <view
                  v-for="card in dropdownCardItems2"
                  :key="card.getString('id')"
                  class="dropdown-card"
                  @click="onDropdownCardSelect(card.getString('title') ?? ''); closeDropdown('uDropdownRefCard')"
                >
                  <image
                    :src="card.getString('image')"
                    mode="aspectFill"
                    class="dropdown-card-img"
                  ></image>
                  <view class="dropdown-card-body">
                    <text class="dropdown-card-title">{{ card.getString('title') }}</text>
                    <text class="dropdown-card-desc">{{ card.getString('desc') }}</text>
                    <view class="dropdown-card-footer">
                      <text class="dropdown-card-price">{{ card.getString('price') }}</text>
                      <view class="dropdown-card-tag">
                        <text class="dropdown-card-tag-text">{{ card.getString('tag') }}</text>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </up-dropdown-item>
        </up-dropdown>
        <text class="text-12px text-[#909399] mt-6px">已选卡片: {{ dropdownCardSelected }}</text>
      </view>

      <!-- SwipeAction 滑动操作 -->
      <view class="demo-block">
        <text class="demo-label">
          up-swipe-action
        </text>
        <up-swipe-action :auto-close="true">
          <up-swipe-action-item
            v-for="(item, idx) in swipeActionList"
            :key="item.id as string"
            :options="swipeActionOptions"
            :name="idx"
            :close-on-click="true"
            @click="onSwipeActionClick"
          >
            <view class="swipe-action-content">
              <text class="text-14px text-[#303133]">{{ item.title as string }}</text>
            </view>
          </up-swipe-action-item>
        </up-swipe-action>
      </view>

      <!-- Swiper 轮播图 -->
      <up-swiper
        :list="swiperList"
        key-name="image"
        :indicator="true"
        indicator-mode="dot"
        :circular="true"
        :autoplay="true"
        :interval="3000"
        height="180"
        :show-title="true"
      ></up-swiper>

      <!-- ==================== 基础组件 ==================== -->
      <text class="section-title">
        基础组件
      </text>

      <!-- Button 按钮 -->
      <view class="demo-block">
        <text class="demo-label">
          up-button
        </text>
        <view class="demo-row">
          <up-button type="primary" text="主要" size="mini"></up-button>
          <up-button type="success" text="成功" size="mini"></up-button>
          <up-button type="warning" text="警告" size="mini"></up-button>
          <up-button type="error" text="错误" size="mini"></up-button>
          <up-button type="info" text="信息" size="mini"></up-button>
        </view>
        <view class="demo-row">
          <up-button type="primary" text="朴素" :plain="true" size="mini"></up-button>
          <up-button type="primary" text="细边框" :plain="true" :hairline="true" size="mini"></up-button>
          <up-button type="primary" text="圆形" shape="circle" size="mini"></up-button>
          <up-button type="primary" text="禁用" :disabled="true" size="mini"></up-button>
        </view>
        <view class="demo-row">
          <up-button type="primary" text="加载中" :loading="true" size="mini"></up-button>
          <up-button type="primary" text="自定义色" color="#7232dd" size="mini"></up-button>
        </view>
      </view>

      <!-- Icon 图标 -->
