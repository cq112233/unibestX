      :duration="300"
      :bottom="100"
      :right="20"
      :z-index="99"
      :icon-style="{ fontSize: '20px', color: '#ffffff' }"
      :custom-style="{ backgroundColor: '#2979ff' }"
      @click="onBackTopClick"
    ></up-back-top>
