<script setup lang="uts">
function goToDemo(page: string): void {
  uni.navigateTo({
    url: `/src/sub/uview-ultra/demos/${page}/${page}`
  })
}
</script>

<style scoped>
.demo-group-card {
  margin: 0 12px;
  background-color: #ffffff;
  border-radius: 12px;
  padding: 12px 0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
}

.group-title {
  font-size: 14px;
  font-weight: bold;
  color: #1e293b;
  padding: 0 16px 8px 16px;
  border-bottom: 1px solid #f1f5f9;
}
</style>