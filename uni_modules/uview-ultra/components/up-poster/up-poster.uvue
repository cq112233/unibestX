<template>
	<view class="up-poster">
		<canvas
			v-if="showCanvas"
			class="up-poster__canvas"
			:id="canvasId"
			:canvas-id="canvasId"
			:style="canvasStyle"
		></canvas>
	</view>
</template>

<script lang="uts">
import { createQrCells, getQrRenderCount } from '../up-qrcode/qrcode.uts'

type PosterItem = {
	type: string,
	text: string,
	src: string,
	css: UTSJSONObject
}

type GradientStop = {
	color: string,
	offset: number
}

function toObject(value: any | null): UTSJSONObject {
	if (value == null) {
		return {} as UTSJSONObject
	}
	return value as UTSJSONObject
}

function stringValue(value: any | null, fallback: string = ''): string {
	return value == null ? fallback : value.toString()
}

function numberValue(value: any | null, fallback: number = 0): number {
	if (typeof value === 'number') {
		return value
	}
	if (value == null) {
		return fallback
	}
	const text = value.toString()
	if (text.endsWith('rpx')) {
		const parsed = parseFloat(text.substring(0, text.length - 3))
		return isNaN(parsed) ? fallback : parsed * uni.getWindowInfo().windowWidth / 750
	}
	if (text.endsWith('px')) {
		const parsed = parseFloat(text.substring(0, text.length - 2))
		return isNaN(parsed) ? fallback : parsed
	}
	const parsed = parseFloat(text)
	return isNaN(parsed) ? fallback : parsed
}

function colorValue(value: any | null, fallback: string): string {
	const text = stringValue(value, fallback)
	return text.length > 0 ? text : fallback
}

function splitGradientArgs(value: string): Array<string> {
	const result = [] as Array<string>
	let depth = 0
	let start = 0
	for (let i = 0; i < value.length; i++) {
		const char = value.substring(i, i + 1)
		if (char == '(') {
			depth++
		} else if (char == ')') {
			depth--
		} else if (char == ',' && depth == 0) {
			result.push(value.substring(start, i).trim())
			start = i + 1
		}
	}
	const tail = value.substring(start).trim()
	if (tail.length > 0) {
		result.push(tail)
	}
	return result
}

function gradientBody(value: string): string {
	const start = value.indexOf('(')
	const end = value.lastIndexOf(')')
	if (start < 0 || end <= start) {
		return ''
	}
	return value.substring(start + 1, end)
}

function isGradientDirection(value: string): boolean {
	return value.endsWith('deg') || value.startsWith('to ')
}

function parseGradientStop(value: string, index: number, total: number): GradientStop {
	const parts = value.split(' ')
	const color = parts.length > 0 ? parts[0].trim() : '#ffffff'
	let offset = total <= 1 ? 0 : index / (total - 1)
	for (let i = 1; i < parts.length; i++) {
		const part = parts[i].trim()
		if (part.endsWith('%')) {
			const parsed = parseFloat(part.substring(0, part.length - 1))
			if (!isNaN(parsed)) {
				offset = Math.max(0, Math.min(1, parsed / 100))
			}
		}
	}
	return {
		color: color.length > 0 ? color : '#ffffff',
		offset
	} as GradientStop
}

function parseGradientStops(background: string): Array<GradientStop> {
	const args = splitGradientArgs(gradientBody(background))
	const firstColorIndex = args.length > 0 && isGradientDirection(args[0]) ? 1 : 0
	const total = args.length - firstColorIndex
	const stops = [] as Array<GradientStop>
	for (let i = firstColorIndex; i < args.length; i++) {
		stops.push(parseGradientStop(args[i], i - firstColorIndex, total))
	}
	if (stops.length == 0) {
		stops.push({ color: '#ffffff', offset: 0 } as GradientStop)
		stops.push({ color: '#ffffff', offset: 1 } as GradientStop)
	} else if (stops.length == 1) {
		stops.push({ color: stops[0].color, offset: 1 } as GradientStop)
	}
	return stops
}

function gradientAngle(background: string): number {
	const args = splitGradientArgs(gradientBody(background))
	if (args.length == 0) {
		return 135
	}
	const direction = args[0]
	if (direction.endsWith('deg')) {
		const parsed = parseFloat(direction.substring(0, direction.length - 3))
		return isNaN(parsed) ? 135 : parsed
	}
	if (direction == 'to right') return 90
	if (direction == 'to left') return 270
	if (direction == 'to bottom') return 180
	if (direction == 'to top') return 0
	if (direction == 'to right bottom' || direction == 'to bottom right') return 135
	if (direction == 'to left bottom' || direction == 'to bottom left') return 225
	if (direction == 'to right top' || direction == 'to top right') return 45
	if (direction == 'to left top' || direction == 'to top left') return 315
	return 135
}

function createItem(raw: any | null): PosterItem {
	const obj = toObject(raw)
	return {
		type: stringValue(obj['type']),
		text: stringValue(obj['text']),
		src: stringValue(obj['src']),
		css: toObject(obj['css'])
	} as PosterItem
}

function makeId(): string {
	return 'up-poster-canvas-' + Date.now().toString()
}

export default {
	name: 'up-poster',
	props: {
		json: {
			type: Object,
			default(): UTSJSONObject {
				return {} as UTSJSONObject
			}
		}
	},
	emits: ['export', 'error'],
	data() {
		return {
			canvasId: makeId(),
			showCanvas: false,
			canvasWidth: 375,
			canvasHeight: 557,
			canvasContext: null as CanvasContext | null,
			ctx: null as CanvasRenderingContext2D | null
		}
	},
	computed: {
		canvasStyle(): UTSJSONObject {
			return {
				width: this.canvasWidth.toString() + 'px',
				height: this.canvasHeight.toString() + 'px'
			} as UTSJSONObject
		}
	},
	methods: {
		getJson(): UTSJSONObject {
			return toObject(this.json)
		},
		getPosterCss(): UTSJSONObject {
			return toObject(this.getJson()['css'])
		},
		getViews(): Array<any> {
			const views = this.getJson()['views']
			if (views == null) {
				return [] as Array<any>
			}
			return views as Array<any>
		},
		prepareSize(): void {
			const css = this.getPosterCss()
			this.canvasWidth = numberValue(css['width'], 375)
			this.canvasHeight = numberValue(css['height'], 557)
		},
		initCanvas(): Promise<void> {
			return new Promise((resolve, reject) => {
				uni.createCanvasContextAsync({
					id: this.canvasId.toString() as string.IDString,
					component: this,
					success: (context: CanvasContext) => {
						this.canvasContext = context
						this.ctx = context.getContext('2d')
						resolve()
					},
					fail: (error: UniError) => {
						reject(error)
					}
				})
			})
		},
		exportImage(): Promise<UTSJSONObject> {
			return new Promise((resolve, reject) => {
				this.generatePoster().then((path: string) => {
					const result = {
						width: this.canvasWidth,
						height: this.canvasHeight,
						path
					} as UTSJSONObject
					this.$emit('export', result)
					resolve(result)
				}).catch((error: any | null) => {
					this.$emit('error', error)
					reject(error)
				})
			})
		},
		generatePoster(): Promise<string> {
			return new Promise((resolve, reject) => {
				this.prepareSize()
				this.showCanvas = true
				this.$nextTick(() => {
					this.initCanvas().then(() => {
						this.drawPoster().then(() => {
							const canvas = this.canvasContext
							if (canvas == null) {
								reject(new Error('Canvas is not ready'))
								return
							}
							const dataUrl = canvas.toDataURL('image/png', 1)
							this.showCanvas = false
							resolve(dataUrl)
						})
					}).catch((error: any | null) => {
						this.showCanvas = false
						reject(error)
					})
				})
			})
		},
		drawPoster(): Promise<void> {
			return new Promise((resolve) => {
				this.drawPosterSync().then(() => {
					const context = this.ctx
					if (context != null) {
						context.draw()
					}
					resolve()
				})
			})
		},
		drawPosterSync(): Promise<void> {
			return new Promise((resolve) => {
				const context = this.ctx
				if (context == null) {
					resolve()
					return
				}
				const css = this.getPosterCss()
				context.clearRect(0, 0, this.canvasWidth, this.canvasHeight)
				this.fillBackground(css['background'], 0, 0, this.canvasWidth, this.canvasHeight, 0, '#ffffff')
				const views = this.getViews()
				this.drawItems(views, 0).then(() => {
					resolve()
				})
			})
		},
		drawItems(views: Array<any>, index: number): Promise<void> {
			return new Promise((resolve) => {
				if (index >= views.length) {
					resolve()
					return
				}
				this.drawItem(createItem(views[index])).then(() => {
					this.drawItems(views, index + 1).then(() => {
						resolve()
					})
				})
			})
		},
		drawItem(item: PosterItem): Promise<void> {
			return new Promise((resolve) => {
				if (item.type == 'view') {
					this.drawView(item)
					resolve()
				} else if (item.type == 'text') {
					this.drawText(item)
					resolve()
				} else if (item.type == 'image') {
					this.drawImageBox(item).then(() => {
						resolve()
					})
				} else if (item.type == 'qrcode') {
					this.drawQrCode(item)
					resolve()
				} else {
					resolve()
				}
			})
		},
		drawView(item: PosterItem): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			const css = item.css
			const x = numberValue(css['left'], 0)
			const y = numberValue(css['top'], 0)
			const width = numberValue(css['width'], 0)
			const height = numberValue(css['height'], 0)
			this.fillBackground(css['background'], x, y, width, height, numberValue(css['radius'], 0), '#ffffff')
		},
		drawText(item: PosterItem): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			const css = item.css
			const x = numberValue(css['left'], 0)
			const y = numberValue(css['top'], 0)
			const width = numberValue(css['width'], this.canvasWidth - x)
			const fontSize = numberValue(css['fontSize'], 14)
			const lineHeight = numberValue(css['lineHeight'], fontSize + 6)
			const lineClamp = numberValue(css['lineClamp'], 1)
			context.fillStyle = colorValue(css['color'], '#333333')
			context.font = stringValue(css['fontWeight']) == 'bold' ? 'bold ' + fontSize.toString() + 'px sans-serif' : fontSize.toString() + 'px sans-serif'
			const lines = this.wrapText(item.text, width, lineClamp)
			for (let i = 0; i < lines.length; i++) {
				context.fillText(lines[i], x, y + fontSize + i * lineHeight)
			}
		},
		wrapText(text: string, maxWidth: number, maxLines: number): Array<string> {
			const context = this.ctx
			const lines = [] as Array<string>
			if (context == null || text.length == 0) {
				return lines
			}
			let current = ''
			for (let i = 0; i < text.length; i++) {
				const next = current + text.substring(i, i + 1)
				if (context.measureText(next).width > maxWidth && current.length > 0) {
					lines.push(current)
					current = text.substring(i, i + 1)
					if (lines.length >= maxLines) {
						break
					}
				} else {
					current = next
				}
			}
			if (lines.length < maxLines && current.length > 0) {
				lines.push(current)
			}
			if (lines.length == maxLines && text.length > lines.join('').length) {
				let last = lines[maxLines - 1]
				while (last.length > 0 && context.measureText(last + '...').width > maxWidth) {
					last = last.substring(0, last.length - 1)
				}
				lines[maxLines - 1] = last + '...'
			}
			return lines
		},
		drawImageBox(item: PosterItem): Promise<void> {
			return new Promise((resolve) => {
				const context = this.ctx
				if (context == null) {
					resolve()
					return
				}
				const css = item.css
				const x = numberValue(css['left'], 0)
				const y = numberValue(css['top'], 0)
				const width = numberValue(css['width'], 0)
				const height = numberValue(css['height'], 0)
				uni.getImageInfo({
					src: item.src,
					success: (res: GetImageInfoSuccess) => {
						const canvas = this.canvasContext
						if (canvas == null) {
							this.drawImageFallback(x, y, width, height, numberValue(css['radius'], 0))
							resolve()
							return
						}
						const image = canvas.createImage()
						image.onload = () => {
							context.drawImage(image, x, y, width, height)
							resolve()
						}
						image.onerror = () => {
							this.drawImageFallback(x, y, width, height, numberValue(css['radius'], 0))
							resolve()
						}
						image.src = res.path
					},
					fail: () => {
						this.drawImageFallback(x, y, width, height, numberValue(css['radius'], 0))
						resolve()
					}
				})
			})
		},
		drawImageFallback(x: number, y: number, width: number, height: number, radius: number): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			context.fillStyle = '#eef2f7'
			this.fillRoundRect(x, y, width, height, radius)
		},
		drawQrCode(item: PosterItem): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			const css = item.css
			const x = numberValue(css['left'], 0)
			const y = numberValue(css['top'], 0)
			const width = numberValue(css['width'], 0)
			const height = numberValue(css['height'], width)
			const value = item.text.length > 0 ? item.text : item.src
			if (value.length == 0 || width <= 0 || height <= 0) {
				this.drawImageFallback(x, y, width, height, numberValue(css['radius'], 0))
				return
			}
			const foreground = colorValue(css['foreground'], '#000000')
			const background = colorValue(css['background'], '#ffffff')
			const pdground = colorValue(css['pdground'], foreground)
			const level = numberValue(css['lv'], 3)
			const count = getQrRenderCount(value, level)
			const cells = createQrCells(value, foreground, background, pdground, level)
			const cellSize = Math.min(width, height) / count
			context.fillStyle = background
			context.fillRect(x, y, width, height)
			for (let row = 0; row < count; row++) {
				for (let col = 0; col < count; col++) {
					const index = row * count + col
					if (index >= cells.length) continue
					const cell = cells[index]
					if ((cell['dark'] as boolean) != true) continue
					context.fillStyle = colorValue(cell['color'], foreground)
					context.fillRect(x + col * cellSize, y + row * cellSize, cellSize + 0.5, cellSize + 0.5)
				}
			}
		},
		fillBackground(value: any | null, x: number, y: number, width: number, height: number, radius: number, fallback: string): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			const background = colorValue(value, fallback)
			if (background.indexOf('gradient') >= 0) {
				this.fillGradient(background, x, y, width, height, radius, fallback)
				return
			}
			context.fillStyle = background
			this.fillRoundRect(x, y, width, height, radius)
		},
		fillGradient(background: string, x: number, y: number, width: number, height: number, radius: number, fallback: string): void {
			if (this.fillCanvasGradient(background, x, y, width, height, radius)) {
				return
			}
			if (background.indexOf('radial-gradient') >= 0) {
				this.fillSteppedRadialGradient(background, x, y, width, height, radius, fallback)
				return
			}
			this.fillSteppedLinearGradient(background, x, y, width, height, radius, fallback)
		},
		fillCanvasGradient(background: string, x: number, y: number, width: number, height: number, radius: number): boolean {
			const context = this.ctx
			if (context == null) {
				return false
			}
			const stops = parseGradientStops(background)
			if (background.indexOf('radial-gradient') >= 0) {
				const centerX = x + width / 2
				const centerY = y + height / 2
				const maxRadius = Math.max(width, height) / 2
				const gradient = context.createRadialGradient(centerX, centerY, 0, centerX, centerY, maxRadius)
				for (let i = 0; i < stops.length; i++) {
					gradient.addColorStop(stops[i].offset, stops[i].color)
				}
				context.fillStyle = gradient
				this.fillRoundRect(x, y, width, height, radius)
				return true
			}
			const angle = gradientAngle(background) % 360
			let startX = x
			let startY = y
			let endX = x + width
			let endY = y + height
			if (angle == 0) {
				startX = x
				startY = y + height
				endX = x
				endY = y
			} else if (angle == 90) {
				startX = x
				startY = y
				endX = x + width
				endY = y
			} else if (angle == 180) {
				startX = x
				startY = y
				endX = x
				endY = y + height
			} else if (angle == 270) {
				startX = x + width
				startY = y
				endX = x
				endY = y
			}
			const gradient = context.createLinearGradient(startX, startY, endX, endY)
			for (let i = 0; i < stops.length; i++) {
				gradient.addColorStop(stops[i].offset, stops[i].color)
			}
			context.fillStyle = gradient
			this.fillRoundRect(x, y, width, height, radius)
			return true
		},
		fillSteppedLinearGradient(background: string, x: number, y: number, width: number, height: number, radius: number, fallback: string): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			const stops = parseGradientStops(background)
			const angle = gradientAngle(background) % 360
			const horizontal = angle == 90 || angle == 270
			const steps = Math.max(1, Math.floor(horizontal ? width : height))
			for (let i = 0; i < steps; i++) {
				const rawProgress = steps <= 1 ? 0 : i / (steps - 1)
				const progress = angle == 270 || angle == 0 ? 1 - rawProgress : rawProgress
				context.fillStyle = this.gradientColorAt(stops, progress, fallback)
				if (horizontal) {
					context.fillRect(x + i, y, 1.5, height)
				} else {
					context.fillRect(x, y + i, width, 1.5)
				}
			}
			if (radius > 0) {
				this.clipRadiusMask(x, y, width, height, radius)
			}
		},
		fillSteppedRadialGradient(background: string, x: number, y: number, width: number, height: number, radius: number, fallback: string): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			const stops = parseGradientStops(background)
			const centerX = x + width / 2
			const centerY = y + height / 2
			const maxRadius = Math.max(width, height) / 2
			const steps = Math.max(1, Math.floor(maxRadius))
			for (let i = steps; i >= 0; i--) {
				const progress = steps <= 0 ? 0 : i / steps
				context.fillStyle = this.gradientColorAt(stops, progress, fallback)
				context.beginPath()
				context.arc(centerX, centerY, i, 0, Math.PI * 2)
				context.closePath()
				context.fill()
			}
			if (radius > 0) {
				this.clipRadiusMask(x, y, width, height, radius)
			}
		},
		gradientColorAt(stops: Array<GradientStop>, progress: number, fallback: string): string {
			if (stops.length == 0) {
				return fallback
			}
			let current = stops[0]
			for (let i = 1; i < stops.length; i++) {
				if (progress <= stops[i].offset) {
					const next = stops[i]
					const span = next.offset - current.offset
					const ratio = span <= 0 ? 0 : (progress - current.offset) / span
					return ratio < 0.5 ? current.color : next.color
				}
				current = stops[i]
			}
			return current.color
		},
		clipRadiusMask(x: number, y: number, width: number, height: number, radius: number): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			context.save()
			context.globalCompositeOperation = 'destination-in'
			context.fillStyle = '#000000'
			this.fillRoundRect(x, y, width, height, radius)
			context.restore()
			context.globalCompositeOperation = 'source-over'
		},
		fillRoundRect(x: number, y: number, width: number, height: number, radius: number): void {
			const context = this.ctx
			if (context == null) {
				return
			}
			if (radius <= 0) {
				context.fillRect(x, y, width, height)
				return
			}
			const r = Math.min(radius, Math.min(width, height) / 2)
			context.beginPath()
			context.moveTo(x + r, y)
			context.lineTo(x + width - r, y)
			context.quadraticCurveTo(x + width, y, x + width, y + r)
			context.lineTo(x + width, y + height - r)
			context.quadraticCurveTo(x + width, y + height, x + width - r, y + height)
			context.lineTo(x + r, y + height)
			context.quadraticCurveTo(x, y + height, x, y + height - r)
			context.lineTo(x, y + r)
			context.quadraticCurveTo(x, y, x + r, y)
			context.closePath()
			context.fill()
		}
	}
}
</script>

<style lang="scss" scoped>
	.up-poster {
		position: fixed;
		left: -9999px;
		top: -9999px;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	.up-poster__canvas {
		display: flex;
	}
</style>
