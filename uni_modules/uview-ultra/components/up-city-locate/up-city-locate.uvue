<template>
	<view class="up-city-locate">
		<up-index-list :indexList="indexList">
			<template #header>
				<view class="up-current-city-wrap">
					<view class="up-current-city-title">定位城市</view>
					<view class="up-current-city-item" @tap="location">
						<view class="up-location-city">{{locationCity}}</view>
					</view>
				</view>
			</template>
			<template :key="index" v-for="(item, index) in cityList">
				<!-- #ifdef APP-NVUE -->
				<up-index-anchor :text="getIndexText(index)"></up-index-anchor>
				<!-- #endif -->
				<up-index-item>
					<up-index-anchor :text="getIndexText(index)"></up-index-anchor>
					<view class="hot-city-list" v-if="index == 0">
						<view class="" v-for="(item1, index1) in getCityGroup(item)" :key="index1" @tap="selectedCity(item1)">
							<view class="hot-city-item">{{ getCityName(item1) }}</view>
						</view>
					</view>
					<view v-else class="item-list" v-for="(item1, index1) in getCityGroup(item)" :key="index1">
						<view class="list__item" @tap="selectedCity(item1)">
							<text class="list__item__city-name">{{getCityName(item1)}}</text>
						</view>
						<up-line></up-line>
					</view>
				</up-index-item>
			</template>
			<template #footer>
				<view class="up-safe-area-inset--bottom">
					<text class="list__footer"></text>
				</view>
			</template>
		</up-index-list>
	</view>
</template>

<script lang="uts">
	import type { PropType } from 'vue'

	export default{
		name: 'up-city-locate',
		props:{
			indexList: {
				type: Array as PropType<Array<string>>,
				default(): Array<string> {
					return ['热']
				}
			},
			cityList:{
				type: Array as PropType<Array<Array<UTSJSONObject>>>,
				default(): Array<Array<UTSJSONObject>> {
					return [
						[{
							name: '北京',
							value: 'beijing'
						} as UTSJSONObject,
						{
							name: '上海',
							value: 'shanghai'
						} as UTSJSONObject,
						{
							name: '广州',
							value: 'guangzhou'
						} as UTSJSONObject,
						{
							name: '深圳',
							value: 'shenzhen'
						} as UTSJSONObject,
						{
							name: '杭州',
							value: 'hangzhou'
						} as UTSJSONObject] as Array<UTSJSONObject>
					] as Array<Array<UTSJSONObject>>
				}
			},
			locationType: {
				type: String,
				default: 'wgs84'
			},
			currentCity: {
				type: String,
				default: ''
			},
			nameKey: {
				type: String,
				default: 'name'
			}
		},
		computed:{
		},
		watch:{
			currentCity(val: string) {
				this.locationCity = val;
			}
		},
		data(){
			return{
				locationCity: '定位中...'
			}
		},
		emits: ['location-success', 'select-city'],
		methods:{
			getIndexText(index: number): string {
				const list = this.indexList as Array<string> | null
				if (list == null || index < 0 || index >= list.length) {
					return ''
				}
				return list[index]
			},
			getCityGroup(item: any | null): Array<UTSJSONObject> {
				const group = item as Array<UTSJSONObject> | null
				if (group == null) {
					return [] as Array<UTSJSONObject>
				}
				return group
			},
			getCityName(city: any | null): string {
				const cityObject = city as UTSJSONObject | null
				if (cityObject == null) {
					return ''
				}
				const value = cityObject[this.nameKey]
				if (value == null) {
					return ''
				}
				return value.toString()
			},
			// 获取城市
			selectedCity(city: any | null): void {
				this.locationCity = this.getCityName(city);
				this.$emit('select-city', {
					locationCity: this.locationCity
				});
			},
			// 定位操作
			location(): void {
				const that = this;
				uni.getLocation({
				    type: this.locationType,
					geocode:true,
				    success(res: any){
						const result = res as UTSJSONObject
						const address = result['address'] as UTSJSONObject | null
						const city = address == null ? null : address['city']
						that.locationCity = city == null ? '' : city.toString();
						result['locationCity'] = that.locationCity
						that.$emit('location-success', result);
				    },
					fail(){
						that.locationCity = '定位失败';
					}
				});
			},
		},
		// 页面挂载后进行异步操作
		created(){
		},
		mounted(){
			this.location();
		}
	}
</script>

<style lang="scss">
	.list__item {
		padding: 8px 1px;
	}
	.up-current-city-title {
		color: grey;
		margin-bottom: 5px;
	}
	.up-current-city-item {
		height: 30px;
	}
	.hot-city-list {
		display: flex !important;
		flex-direction: row !important;
		padding: 12px 0;
		.hot-city-item {
			padding: 6px 12px;
			margin: 5px;
			border: 1px solid #ededed;
		}
	}
</style>
