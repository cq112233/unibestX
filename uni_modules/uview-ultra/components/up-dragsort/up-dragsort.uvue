<template>
    <view
        class="up-dragsort"
        :class="[
            direction == 'horizontal' ? 'up-dragsort--horizontal' : '',
            direction == 'vertical' ? 'up-dragsort--vertical' : '',
            direction == 'all' ? 'up-dragsort--all' : ''
        ]"
        :style="movableAreaStyle"
    >
        <movable-area class="up-dragsort-area">
            <movable-view
                v-for="(item, index) in typedList"
                :key="getItemKey(item, index)"
                :id="`up-dragsort-item-${index}`"
                class="up-dragsort-item"
                :class="{ dragging: dragIndex == index, disabled: !draggable || isItemDisabled(item) }"
                :direction="direction === 'all' ? 'all' : direction"
                :x="getItemX(item)"
                :y="getItemY(item)"
                :inertia="false"
                :disabled="!draggable || (dragIndex != -1 && dragIndex != index) || isItemDisabled(item)"
                @change="onChange(index, $event)"
                @touchstart="onTouchStart(index, $event)"
                @touchend="onTouchEnd"
                @touchcancel="onTouchEnd"
                @touchmove="onTouchMove"
            >
                <view class="up-dragsort-item-content">
                    <view
                        class="ui-dragSort-item-handler"
                        v-if="hasHandlerSlot()"
                        data-action="handler"
                        @touchstart="onTouchStart(index, $event)"
                    >
                        <slot name="handler" :item="item" :index="index"></slot>
                    </view>
                    <slot :item="item" :index="index">
                        {{ getItemLabel(item) }}
                    </slot>
                </view>
            </movable-view>
        </movable-area>
    </view>
</template>

<script>
import type { PropType } from 'vue'
import { mpMixin } from '../../libs/mixin/mpMixin.uts'
import { mixin } from '../../libs/mixin/mixin.uts'
import { sleep } from '../../libs/function/index.uts'

function createDragList(): Array<UTSJSONObject> {
    return [] as Array<UTSJSONObject>
}

function createPosition(): UTSJSONObject {
    const position = {} as UTSJSONObject
    position['x'] = 0
    position['y'] = 0
    return position
}

function copyObject(item: UTSJSONObject): UTSJSONObject {
    const copied = {} as UTSJSONObject
    const keys = UTSJSONObject.keys(item)
    for (let i = 0; i < keys.length; i++) {
        copied[keys[i]] = item[keys[i]]
    }
    return copied
}

function copyList(list: Array<UTSJSONObject>): Array<UTSJSONObject> {
    const copied = [] as Array<UTSJSONObject>
    for (let i = 0; i < list.length; i++) {
        copied.push(copyObject(list[i]))
    }
    return copied
}

function normalizeNumber(value: any | null, defaultValue: number = 0): number {
    if (typeof value === 'number') {
        return value
    }
    if (value == null) {
        return defaultValue
    }
    const parsed = parseFloat(value.toString())
    return isNaN(parsed) ? defaultValue : parsed
}

function stringValue(value: any | null): string {
    return value == null ? '' : value.toString()
}

function isDirectionValid(value: string): boolean {
    const directions = ['vertical', 'horizontal', 'all']
    for (let i = 0; i < directions.length; i++) {
        if (directions[i] == value) {
            return true
        }
    }
    return false
}

export default {
    name: 'up-dragsort',
    mixins: [mpMixin, mixin],
    props: {
        initialList: {
            type: Array as PropType<Array<UTSJSONObject>>,
            required: true,
            default(): Array<UTSJSONObject> {
                return createDragList()
            }
        },
        draggable: {
            type: Boolean,
            default: true
        },
        vibrate: {
            type: Boolean,
            default: true
        },
        direction: {
            type: String,
            default: 'vertical',
            validator(value: string): boolean {
                return isDirectionValid(value)
            }
        },
        columns: {
            type: Number,
            default: 3
        }
    },
    emits: ['drag-end'],
    data() {
        return {
            list: createDragList(),
            dragIndex: -1,
            sortChanged: false,
            itemHeight: 0,
            itemWidth: 0,
            areaWidth: 0,
            areaHeight: 0,
            currentX: 0,
            currentY: 0,
            timer: 0
        }
    },
    computed: {
        movableAreaStyle(): UTSJSONObject {
            const style = {} as UTSJSONObject
            const list = this.typedList
            if (this.direction === 'vertical') {
                style['height'] = this.itemHeight > 0 ? `${list.length * this.itemHeight}px` : 'auto'
                style['width'] = '100%'
                return style
            }
            if (this.direction === 'horizontal') {
                style['height'] = this.itemHeight > 0 ? `${this.itemHeight}px` : 'auto'
                style['width'] = this.itemWidth > 0 ? `${list.length * this.itemWidth}px` : 'auto'
                return style
            }
            const rows = Math.ceil(list.length / this.columns)
            style['height'] = this.itemHeight > 0 ? `${rows * this.itemHeight}px` : 'auto'
            style['width'] = '100%'
            return style
        },
        typedList(): Array<UTSJSONObject> {
            return this.list as Array<UTSJSONObject>
        }
    },
    mounted() {
        this.$nextTick(() => {
            this.initList()
            this.calculateItemSize()
            this.calculateAreaSize()
        })
    },
    methods: {
        getItemKey(item: UTSJSONObject, index: number): string | number {
            if (item['id'] != null) {
                return item['id'] as string | number
            }
            return index
        },
        getItemLabel(item: UTSJSONObject): string {
            return stringValue(item['label'])
        },
        getItemX(item: UTSJSONObject): number {
            return normalizeNumber(item['x'], 0)
        },
        getItemY(item: UTSJSONObject): number {
            return normalizeNumber(item['y'], 0)
        },
        isItemDisabled(item: UTSJSONObject): boolean {
            const draggableValue = item['draggable']
            return draggableValue != null && draggableValue.toString() == 'false'
        },
        getDetailNumber(detail: UTSJSONObject, key: string): number {
            return normalizeNumber(detail[key], 0)
        },
        buildItemPosition(item: UTSJSONObject, index: number): UTSJSONObject {
            const nextItem = copyObject(item)
            let x = 0
            let y = 0
            if (this.direction === 'horizontal' && this.itemWidth > 0) {
                x = index * this.itemWidth
            } else if (this.direction === 'vertical' && this.itemHeight > 0) {
                y = index * this.itemHeight
            } else if (this.itemWidth > 0 && this.itemHeight > 0) {
                const col = index % this.columns
                const row = Math.floor(index / this.columns)
                x = col * this.itemWidth
                y = row * this.itemHeight
            }
            nextItem['x'] = x
            nextItem['y'] = y
            return nextItem
        },
        initList(): void {
            const nextList = [] as Array<UTSJSONObject>
            const source = this.initialList as Array<UTSJSONObject>
            for (let i = 0; i < source.length; i++) {
                nextList.push(this.buildItemPosition(source[i], i))
            }
            this.list = nextList
        },
        async calculateItemSize(): Promise<NodeInfo | null> {
            await sleep(30)
            return new Promise((resolve) => {
                uni.createSelectorQuery()
                    .in(this)
                    .select('.up-dragsort-item-content')
                    .boundingClientRect((res: any) => {
                        const rect = res as NodeInfo | null
                        if (rect != null) {
                            this.itemHeight = rect.height != null ? rect.height : 40
                            this.itemWidth = rect.width != null ? rect.width : 80
                            this.updatePositions()
                        }
                        resolve(rect)
                    })
                    .exec()
            })
        },
        async calculateAreaSize(): Promise<NodeInfo | null> {
            await sleep(30)
            return new Promise((resolve) => {
                uni.createSelectorQuery()
                    .in(this)
                    .select('.up-dragsort-area')
                    .boundingClientRect((res: any) => {
                        const rect = res as NodeInfo | null
                        if (rect != null) {
                            this.areaWidth = rect.width != null ? rect.width : 300
                            this.areaHeight = rect.height != null ? rect.height : 300
                        }
                        resolve(rect)
                    })
                    .exec()
            })
        },
        updatePositions(isDragging: boolean = false): void {
            const nextList = [] as Array<UTSJSONObject>
            const list = this.typedList
            for (let i = 0; i < list.length; i++) {
                const currentItem = list[i]
                if (isDragging && this.dragIndex === i) {
                    nextList.push(copyObject(currentItem))
                } else {
                    nextList.push(this.buildItemPosition(currentItem, i))
                }
            }
            this.list = nextList
        },
        hasHandlerSlot(): boolean {
            return this.$slots['handler'] != null
        },
        onTouchStart(index: number, e: any): void {
            const list = this.typedList
            if (index >= 0 && index < list.length && this.isItemDisabled(list[index])) {
                return
            }
            if (this.timer > 0) {
                clearTimeout(this.timer)
                this.timer = 0
            }
            this.sortChanged = false
            this.dragIndex = index
        },
        onTouchMove(e: any): void {
            if (this.dragIndex != -1) {
                const event = e as UniTouchEvent
                event.stopPropagation()
                event.preventDefault()
            }
        },
        onChange(index: number, event: any): void {
            const customEvent = event as UniCustomEvent<UTSJSONObject>
            if (customEvent.detail == null || stringValue(customEvent.detail['source']) != 'touch') {
                return
            }
            const list = this.typedList
            this.currentX = this.getDetailNumber(customEvent.detail, 'x')
            this.currentY = this.getDetailNumber(customEvent.detail, 'y')
            if (this.direction === 'all') {
                this.handleAllModeChange(index)
                return
            }

            let itemSize = 0
            let targetIndex = index
            if (this.direction === 'vertical') {
                itemSize = this.itemHeight
                if (itemSize > 0) {
                    targetIndex = Math.max(0, Math.min(Math.round(this.currentY / itemSize), list.length - 1))
                }
            } else if (this.direction === 'horizontal') {
                itemSize = this.itemWidth
                if (itemSize > 0) {
                    targetIndex = Math.max(0, Math.min(Math.round(this.currentX / itemSize), list.length - 1))
                }
            }

            if (targetIndex !== index) {
                this.reorderItems(index, targetIndex)
            }
        },
        handleAllModeChange(index: number): void {
            if (this.itemWidth <= 0 || this.itemHeight <= 0) {
                return
            }
            const col = Math.max(0, Math.min(Math.round(this.currentX / this.itemWidth), this.columns - 1))
            const row = Math.max(0, Math.round(this.currentY / this.itemHeight))
            let targetIndex = row * this.columns + col
            const list = this.typedList
            targetIndex = Math.max(0, Math.min(targetIndex, list.length - 1))
            if (targetIndex !== index) {
                this.reorderItems(index, targetIndex)
            }
        },
        reorderItems(fromIndex: number, toIndex: number): void {
            const list = this.typedList
            if (fromIndex < 0 || toIndex < 0 || fromIndex >= list.length || toIndex >= list.length) {
                return
            }
            const movedItems = list.splice(fromIndex, 1) as Array<UTSJSONObject>
            if (movedItems.length == 0) {
                return
            }
            list.splice(toIndex, 0, movedItems[0])
            this.list = list
            this.dragIndex = toIndex
            this.sortChanged = true
            this.updatePositions(true)
        },
        onTouchEnd(): void {
            if (this.dragIndex == -1) {
                return
            }
            const list = this.typedList
            const dragItem = list[this.dragIndex]
            if (this.direction === 'horizontal') {
                dragItem['x'] = this.currentX + 0.001
            } else {
                dragItem['x'] = this.currentX + 0.001
                dragItem['y'] = this.currentY + 0.001
            }
            this.list = list
            sleep(50).then(() => {
                this.updatePositions()
                if (this.sortChanged) {
                    this.$emit('drag-end', copyList(this.typedList))
                    this.sortChanged = false
                }
                this.timer = setTimeout(() => {
                    this.dragIndex = -1
                    this.timer = 0
                }, 600)
            })
        }
    },
    watch: {
        initialList: {
            handler() {
                this.$nextTick(() => {
                    this.initList()
                })
            }
        },
        direction: {
            handler() {
                this.$nextTick(() => {
                    this.initList()
                    this.calculateItemSize()
                    this.calculateAreaSize()
                })
            }
        },
        columns: {
            handler() {
                if (this.direction === 'all') {
                    this.$nextTick(() => {
                        this.initList()
                        this.updatePositions()
                    })
                }
            }
        }
    }
}
</script>

<style scoped lang="scss">
.up-dragsort {
    width: 100%;
    height: auto;

    .up-dragsort-area {
        width: 100%;
        height: 100%;
        position: relative;
    }

    .up-dragsort-item {
        position: absolute;
        width: 100%;
        transition: box-shadow 0.45s ease-out;

        &.dragging {
            z-index: 1000;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        }

        .up-dragsort-item-content {
            position: relative;
            padding: 0;
            box-sizing: border-box;
        }
    }

    &.up-dragsort--vertical {
        .up-dragsort-item {
            height: auto;
        }
    }

    &.up-dragsort--horizontal {
        .up-dragsort-area {
            display: flex;
            white-space: nowrap;
        }

        .up-dragsort-item {
            width: auto;
            height: auto;
        }
    }

    &.up-dragsort--all {
        .up-dragsort-item {
            width: auto;
            height: auto;
        }
    }
}
</style>
