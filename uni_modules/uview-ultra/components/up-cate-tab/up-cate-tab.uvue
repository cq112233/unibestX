<template>
	<view class="up-cate-tab" :style="cateStyle">
		<view class="up-cate-tab__wrap">
			<scroll-view
				class="up-cate-tab__view up-cate-tab__menu-scroll-view"
				scroll-y
				scroll-with-animation
				:scroll-top="scrollTop"
				:scroll-into-view="itemId"
			>
				<view
					v-for="(item, index) in getTabList()"
					:key="index"
					:id="'tab' + index.toString()"
					class="up-cate-tab__item"
					:class="[innerCurrent == index ? 'up-cate-tab__item-active' : '']"
					@tap.stop="swichMenu(index)"
				>
					<slot name="tabItem" :item="item"></slot>
					<text class="up-cate-tab__item-text" :class="[innerCurrent == index ? 'up-cate-tab__item-text-active' : '']">{{ getTabLabel(item) }}</text>
				</view>
			</scroll-view>
			<scroll-view
				scroll-y
				scroll-with-animation
				class="up-cate-tab__right-box"
				:scroll-top="scrollRightTop"
				:scroll-into-view="scrollIntoView"
				@scroll="rightScroll"
			>
				<view class="up-cate-tab__right-top">
					<slot name="rightTop" :tabList="getTabList()"></slot>
				</view>
				<view class="up-cate-tab__page-view">
					<template v-for="(item, index) in getTabList()" :key="index">
						<view
							v-if="mode == 'follow' || (mode == 'tab' && index == innerCurrent)"
							class="up-cate-tab__page-item"
							:id="'item' + index.toString()"
						>
							<slot name="itemList" :item="item"></slot>
							<view class="item-title">
								<text>{{ getTabLabel(item) }}</text>
							</view>
							<view class="item-container">
								<template v-for="(item1, index1) in getChildren(item)" :key="index1">
									<slot name="pageItem" :pageItem="item1"></slot>
									<view class="thumb-box">
										<image class="item-menu-image" :src="getItemIcon(item1)" mode=""></image>
										<text class="item-menu-name">{{ getItemLabel(item1) }}</text>
									</view>
								</template>
							</view>
						</view>
					</template>
				</view>
			</scroll-view>
		</view>
	</view>
</template>

<script lang="uts">
function toText(value: any | null): string {
	return value == null ? '' : value.toString()
}

function addUnit(value: string): string {
	if (value.length == 0) return '0px'
	if (value.endsWith('%') || value.endsWith('px') || value.endsWith('rpx') || value.endsWith('vh')) {
		return value
	}
	return value + 'px'
}

export default {
	name: 'up-cate-tab',
	props: {
		mode: {
			type: String,
			default: 'follow'
		},
		height: {
			type: String,
			default: '100%'
		},
		tabList: {
			type: Array,
			default() {
				return []
			}
		},
		tabKeyName: {
			type: String,
			default: 'name'
		},
		itemKeyName: {
			type: String,
			default: 'name'
		},
		current: {
			type: Number,
			default: 0
		}
	},
	emits: ['update:current'],
	data() {
		return {
			scrollTop: 0,
			scrollIntoView: '',
			oldScrollTop: 0,
			innerCurrent: 0,
			menuHeight: 0,
			menuItemHeight: 0,
			itemId: '',
			menuItemPos: [] as Array<number>,
			rects: [] as Array<NodeInfo>,
			arr: [] as Array<number>,
			scrollRightTop: 0,
			timerActive: false
		}
	},
	watch: {
		tabList: {
			handler() {
				this.deferRefresh()
			},
			immediate: true
		},
		current(nval: number) {
			this.innerCurrent = nval
			this.leftMenuStatus(nval)
			this.deferSwitch(nval)
		},
		height() {
			this.deferRefresh()
		}
	},
	computed: {
		cateStyle(): UTSJSONObject {
			return { height: addUnit(this.height) } as UTSJSONObject
		}
	},
	mounted(): void {
		this.innerCurrent = this.current
		this.leftMenuStatus(this.innerCurrent)
		this.deferRefresh()
		this.deferSwitch(this.innerCurrent)
	},
	methods: {
		getTabList(): Array<UTSJSONObject> {
			return this.tabList as Array<UTSJSONObject>
		},
		getTabLabel(item: UTSJSONObject): string {
			return toText(item[this.tabKeyName])
		},
		getChildren(item: UTSJSONObject): Array<UTSJSONObject> {
			const value = item['children']
			return value == null ? [] as Array<UTSJSONObject> : value as Array<UTSJSONObject>
		},
		getItemLabel(item: UTSJSONObject): string {
			return toText(item[this.itemKeyName])
		},
		getItemIcon(item: UTSJSONObject): string {
			return toText(item['icon'])
		},
		deferRefresh(): void {
			setTimeout(() => {
				this.getMenuItemTop()
				this.leftMenuStatus(this.innerCurrent)
			}, 50)
		},
		deferSwitch(index: number): void {
			setTimeout(() => {
				this.swichMenu(index)
			}, 50)
		},
		swichMenu(index: number): void {
			if (index < 0 || index >= this.getTabList().length) return
			if (this.mode == 'follow') {
				if (this.arr.length == 0) {
					this.getMenuItemTop()
				}
				const target = 'item' + index.toString()
				if (this.scrollIntoView != target) {
					this.scrollIntoView = target
				}
			} else {
				this.scrollRightTop = 0
			}
			if (index == this.innerCurrent) return
			this.innerCurrent = index
			this.leftMenuStatus(index)
			this.$emit('update:current', index)
		},
		getElRect(className: string, dataVal: string): void {
			uni.createSelectorQuery()
				.in(this)
				.select('.' + className)
				.boundingClientRect()
				.exec((res: Array<any>) => {
					if (res.length == 0 || res[0] == null) {
						setTimeout(() => {
							this.getElRect(className, dataVal)
						}, 30)
						return
					}
					const rect = res[0] as NodeInfo
					const height = rect.height ?? 0
					if (dataVal == 'menuHeight') {
						this.menuHeight = height
					} else if (dataVal == 'menuItemHeight') {
						this.menuItemHeight = height
					}
				})
		},
		leftMenuStatus(index: number): void {
			const list = this.getTabList()
			if (list.length == 0) return
			const nextIndex = Math.max(0, Math.min(index, list.length - 1))
			this.innerCurrent = nextIndex
			this.$emit('update:current', nextIndex)
			if (this.menuHeight == 0) {
				this.getElRect('up-cate-tab__menu-scroll-view', 'menuHeight')
			}
			if (this.menuItemHeight == 0) {
				this.getElRect('up-cate-tab__item', 'menuItemHeight')
			}
			if (this.menuHeight > 0 && this.menuItemHeight > 0) {
				this.scrollTop = nextIndex * this.menuItemHeight + this.menuItemHeight / 2 - this.menuHeight / 2
				this.itemId = 'tab' + nextIndex.toString()
			}
		},
		getMenuItemTop(): void {
			uni.createSelectorQuery()
				.in(this)
				.selectAll('.up-cate-tab__page-item')
				.boundingClientRect()
				.exec((res: Array<any>) => {
					if (res.length == 0 || res[0] == null) {
						setTimeout(() => {
							this.getMenuItemTop()
						}, 100)
						return
					}
					const rects = res[0] as Array<NodeInfo>
					if (rects.length == 0) return
					this.rects = rects
					this.arr = [] as Array<number>
					const firstTop = rects[0].top ?? 0
					for (let i = 0; i < rects.length; i++) {
						const top = rects[i].top ?? 0
						this.arr.push(top - firstTop)
					}
				})
		},
		rightScroll(e: UniScrollEvent): void {
			if (this.mode != 'follow') return
			const detail = e.detail as UTSJSONObject
			const scrollTop = detail['scrollTop'] as number
			this.oldScrollTop = scrollTop
			if (this.arr.length == 0) {
				this.getMenuItemTop()
			}
			if (this.timerActive) return
			this.timerActive = true
			setTimeout(() => {
				this.timerActive = false
				const scrollHeight = scrollTop + 1
				for (let i = 0; i < this.arr.length; i++) {
					const height1 = this.arr[i]
					const height2 = i + 1 < this.arr.length ? this.arr[i + 1] : -1
					if (height2 == -1 || (scrollHeight >= height1 && scrollHeight <= height2)) {
						this.leftMenuStatus(i)
						return
					}
				}
			}, 100)
		}
	}
}
</script>

<style lang="scss" scoped>
.up-cate-tab {
	display: flex;
	flex-direction: column;
}

.up-cate-tab__wrap {
	flex: 1;
	display: flex;
	flex-direction: row;
	overflow: hidden;
}

.up-cate-tab__view {
	width: 200rpx;
	height: 100%;
}

.up-cate-tab__item {
	height: 110rpx;
	background: #f6f6f6;
	box-sizing: border-box;
	display: flex;
	align-items: center;
	justify-content: center;
}

.up-cate-tab__item-active {
	background: #ffffff;
	border-left: 4px solid #2979ff;
}

.up-cate-tab__item-text {
	font-size: 26rpx;
	color: #444444;
	font-weight: 400;
	line-height: 1;
}

.up-cate-tab__item-text-active {
	color: #000000;
	font-size: 30rpx;
	font-weight: 600;
}

.up-cate-tab__right-box {
	flex: 1;
	background-color: rgb(250, 250, 250);
}

.up-cate-tab__right-top {
	display: flex;
}

.up-cate-tab__page-view {
	padding: 16rpx;
}

.up-cate-tab__page-item {
	margin-bottom: 30rpx;
	background-color: #ffffff;
	padding: 16rpx;
	border-radius: 8rpx;
}

.item-title {
	font-size: 26rpx;
	color: #303133;
	font-weight: bold;
}

.item-container {
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
}

.thumb-box {
	width: 33.333333%;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-direction: column;
	margin-top: 20rpx;
}

.item-menu-image {
	width: 120rpx;
	height: 120rpx;
}

.item-menu-name {
	font-weight: normal;
	font-size: 24rpx;
	color: #303133;
}
</style>
