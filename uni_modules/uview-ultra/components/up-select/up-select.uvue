<template>
	<view class="up-select">
		<view :class="['up-select__content', disabled ? 'disabled' : '']">
			<view class="up-select__label" @click="openSelect">
				<slot name="text" :currentLabel="currentLabel">
					<text class="up-select__text" v-if="showOptionsLabel">
						{{ currentLabel }}
					</text>
					<text class="up-select__text" v-else>
						{{ label }}
					</text>
				</slot>
				<slot name="icon">
					<up-icon name="arrow-down" :size="iconSize" :color="iconColor"></up-icon>
				</slot>
			</view>
			<up-overlay :show="isOpen" @click="overlayClick" v-if="overlay" :zIndex="zIndex" :duration="duration + 50"
				:customStyle="overlayStyle" :opacity="overlayOpacity" @touchmove.stop.prevent="noop"></up-overlay>
			<view class="up-select__options__wrap"
				:style="optionsWrapStyle">
				<view class="up-select__options" v-if="isOpen">
					<slot name="options">
						<view class="up-select__options_item" :class="getOptionClass(item)"
							:key="index" v-for="(item, index) in options" @click="selectItem(item)">
							<slot name="optionItem" :item="item">
								<text class="up-select__item_text" :style="{color: itemColor}">
									{{ getOptionLabel(item) }}
								</text>
							</slot>
						</view>
					</slot>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
import type { PropType } from 'vue';
import { mpMixin } from '../../libs/mixin/mpMixin.uts';
import { mixin } from '../../libs/mixin/mixin.uts';
import { getWindowInfo } from '../../libs/function/index.uts';

function createOptions(): UTSJSONObject[] {
	return [] as UTSJSONObject[];
}

function createEmptyObject(): UTSJSONObject {
	return {} as UTSJSONObject;
}

function valueToString(value: any | null): string {
	return value == null ? '' : value.toString();
}

function normalizeNumber(value: any | null, fallback: number = 0): number {
	if (typeof value === 'number') {
		return value;
	}
	if (value == null) {
		return fallback;
	}
	const parsed = parseFloat(value.toString());
	return isNaN(parsed) ? fallback : parsed;
}

export default {
	name: 'up-select',
	mixins: [mpMixin, mixin],
	emits: ['update:current', 'select'],
	props: {
		maxHeight: {
			type: String,
			default: '90vh'
		},
		overlay: {
			type: Boolean,
			default: true
		},
		overlayOpacity: {
			type: Number,
			default: 0.01
		},
		overlayStyle: {
			type: Object as PropType<UTSJSONObject>,
			default(): UTSJSONObject {
				return createEmptyObject();
			}
		},
		duration: {
			type: Number,
			default: 300
		},
		label: {
			type: String,
			default: '选项'
		},
		options: {
			type: Array as PropType<UTSJSONObject[]>,
			default(): UTSJSONObject[] {
				return createOptions();
			}
		},
		keyName: {
			type: String,
			default: 'id'
		},
		labelName: {
			type: String,
			default: 'name'
		},
		showOptionsLabel: {
			type: Boolean,
			default: false
		},
		current: {
			type: [String, Number],
			default: ''
		},
		zIndex: {
			type: Number,
			default: 11000
		},
		itemColor: {
			type: String,
			default: '#333333'
		},
		iconColor: {
			type: String,
			default: ''
		},
		iconSize: {
			type: String,
			default: '13px'
		},
		disabled: {
			type: Boolean,
			default: false
		}
	},
	data() {
		return {
			isOpen: false,
			optionsWrapLeft: 'auto',
			optionsWrapRight: 'auto',
			optionsWrapTop: '0px',
			optionsWrapMinWidth: '100px',
			optionsWrapMaxHeight: '90vh'
		}
	},
	mounted() {
		if (this.maxHeight != null && this.maxHeight != '') {
			this.optionsWrapMaxHeight = this.maxHeight
		}
	},
	computed: {
		currentLabel(): string {
			const options = this.options as UTSJSONObject[];
			for (let i = 0; i < options.length; i++) {
				const item = options[i] as UTSJSONObject;
				if (valueToString(item[this.keyName]) == valueToString(this.current)) {
					return valueToString(item[this.labelName]);
				}
			}
			return '';
		},
		optionsWrapStyle(): UTSJSONObject {
			return {
				overflowY: 'auto',
				position: 'fixed',
				zIndex: this.zIndex + 1,
				left: this.optionsWrapLeft,
				right: this.optionsWrapRight,
				top: this.optionsWrapTop,
				minWidth: this.optionsWrapMinWidth,
				maxHeight: this.optionsWrapMaxHeight
			} as UTSJSONObject
		}
	},
	methods: {
		getOptionClass(item: UTSJSONObject): string {
			return valueToString(item[this.keyName]) == valueToString(this.current) ? 'active' : ''
		},
		getOptionLabel(item: UTSJSONObject): string {
			return valueToString(item[this.labelName])
		},
		openSelect(): void {
			if (this.disabled) {
				return;
			}
			this.isOpen = true;
			this.$nextTick(() => {
				if (this.isOpen) {
					this.adjustOptionsWrapPosition();
				}
			});
		},
		closeSelect(): void {
			this.isOpen = false;
		},
		overlayClick(): void {
			this.isOpen = false;
		},
		selectItem(item: UTSJSONObject): void {
			this.isOpen = false;
			this.$emit('update:current', item[this.keyName]);
			this.$emit('select', item);
		},
		adjustOptionsWrapPosition(): void {
			const wi = getWindowInfo();
			const windowWidth = wi.windowWidth;
			const windowHeight = wi.windowHeight;
			this.$uGetRect('.up-select__label').then((rect: NodeInfo) => {
				const left = normalizeNumber(rect.left, 0);
				const top = normalizeNumber(rect.top, 0);
				const width = Math.max(100, normalizeNumber(rect.width, 100));
				const height = normalizeNumber(rect.height, 0);
				const dropdownTop = top + height;
				const availableHeight = Math.max(80, windowHeight - dropdownTop - 8);
				this.optionsWrapTop = dropdownTop.toString() + 'px';
				this.optionsWrapMinWidth = width.toString() + 'px';
				this.optionsWrapMaxHeight = availableHeight.toString() + 'px';
				if (left + width > windowWidth) {
					this.optionsWrapLeft = 'auto';
					this.optionsWrapRight = '0px';
				} else {
					this.optionsWrapLeft = left.toString() + 'px';
					this.optionsWrapRight = 'auto';
				}
			});
		}
	}
}
</script>

<style lang="scss" scoped>
	.up-select__content {
		position: relative;

		.up-select__label {
			display: flex;
			flex-direction: row;
			align-items: center;
			justify-content: space-between;

			/* #ifdef H5 */
			&:hover {
				cursor: pointer;
			}

			/* #endif */
		}

		.up-select__text {
			margin-right: 2px;
		}

		&.disabled {
			opacity: 0.6;
			pointer-events: none;
		}

		.up-select__options__wrap {
			position: fixed;
			top: 0;
			left: 0;
		}

		.up-select__options {
			min-width: 100px;
			box-sizing: border-box;
			border-radius: 4px;
			border: 1px solid #f1f1f1;
			background-color: #fff;

			.up-select__options_item {
				padding: 10px 12px;
				box-sizing: border-box;
				width: 100%;
				height: 100%;

				&:hover {
					background-color: #f7f7f7;
				}

				/* #ifdef H5 */
				&:hover {
					cursor: pointer;
				}

				.up-select__item_text {
					&:hover {
						cursor: pointer;
					}
				}

				/* #endif */
			}
		}
	}
</style>

