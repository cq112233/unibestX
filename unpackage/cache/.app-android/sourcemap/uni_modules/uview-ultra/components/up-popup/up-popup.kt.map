<template>
	<view class="up-popup"  :class="[customClass]">
		<up-overlay
			:show="show && !pageInline"
			@click="overlayClick"
			v-if="overlay && !pageInline"
			:zIndex="zIndex"
			:duration="overlayDuration"
			:customStyle="overlayStyle"
			:opacity="overlayOpacity"
		></up-overlay>
		<up-transition
			:show="pageInline ? true : show"
			:customStyle="transitionStyle"
			:mode="pageInline ? 'none' : position"
			:duration="duration"
			@afterEnter="afterEnter"
			@click="clickHandler"
		>
			<view
				class="up-popup__content"
				:style="[contentStyle]"
				@tap.stop="noop"
			>
				<up-status-bar v-if="safeAreaInsetTop"></up-status-bar>
				<slot></slot>
				<view
					v-if="closeable"
					@tap.stop="close"
					class="up-popup__content__close"
					:class="['up-popup__content__close--' + closeIconPos]"
					hover-class="up-popup__content__close--hover"
					hover-stay-time="150"
				>
					<up-icon
						name="close"
						color="#909399"
						size="18"
						bold
					></up-icon>
				</view>
				<up-safe-bottom v-if="safeAreaInsetBottom"></up-safe-bottom>
			</view>
		</up-transition>
	</view>
</template>

<script>
	import { propsPopup } from './props';
	import { mpMixin } from '../../libs/mixin/mpMixin';
	import { mixin } from '../../libs/mixin/mixin';
	import { addUnit, addStyle, deepMerge, sleep } from '../../libs/function/index';
	/**
	 * popup еЉєз™Ч
	 * @description еЉєеЗЇе±ВеЃєеЩ®пЉМзФ®дЇОе±Хз§ЇеЉєз™ЧгАБдњ°жБѓжПРз§Їз≠ЙеЖЕеЃєпЉМжФѓжМБдЄКгАБдЄЛгАБеЈ¶гАБеП≥еТМдЄ≠йГ®еЉєеЗЇгАВзїДдїґеП™жПРдЊЫеЃєеЩ®пЉМеЖЕйГ®еЖЕеЃєзФ±зФ®жИЈиЗ™еЃЪдєЙ
	 * @tutorial https://ijry.github.io/uview-plus/components/popup.html
	 * @property {Boolean}			show				жШѓеР¶е±Хз§ЇеЉєз™Ч (йїШиЃ§ false )
	 * @property {Boolean}			overlay				жШѓеР¶жШЊз§ЇйБЃзљ© пЉИйїШиЃ§ true пЉЙ
	 * @property {String}			mode				еЉєеЗЇжЦєеРСпЉИйїШиЃ§ 'bottom' пЉЙ
	 * @property {String | Number}	duration			еК®зФїжЧґйХњпЉМеНХдљНms пЉИйїШиЃ§ 300 пЉЙ
	 * @property {String | Number}	overlayDuration		йБЃзљ©е±ВеК®зФїжЧґйХњпЉМеНХдљНms пЉИйїШиЃ§ 350 пЉЙ
	 * @property {Boolean}			closeable			жШѓеР¶жШЊз§ЇеЕ≥йЧ≠еЫЊж†ЗпЉИйїШиЃ§ false пЉЙ
	 * @property {Object | String}	overlayStyle		иЗ™еЃЪдєЙйБЃзљ©зЪДж†ЈеЉП
	 * @property {String | Number}	overlayOpacity		йБЃзљ©йАПжШОеЇ¶пЉМ0-1дєЛйЧіпЉИйїШиЃ§ 0.5пЉЙ
	 * @property {Boolean}			closeOnClickOverlay	зВєеЗїйБЃзљ©жШѓеР¶еЕ≥йЧ≠еЉєз™Ч пЉИйїШиЃ§  true пЉЙ
	 * @property {String | Number}	zIndex				е±ВзЇІ пЉИйїШиЃ§ 10075 пЉЙ
	 * @property {Boolean}			safeAreaInsetBottom	жШѓеР¶дЄЇiPhoneXзХЩеЗЇеЇХйГ®еЃЙеЕ®иЈЭз¶ї пЉИйїШиЃ§ true пЉЙ
	 * @property {Boolean}			safeAreaInsetTop	жШѓеР¶зХЩеЗЇй°ґйГ®еЃЙеЕ®иЈЭз¶їпЉИзКґжАБж†ПйЂШеЇ¶пЉЙ пЉИйїШиЃ§ false пЉЙ
	 * @property {String}			closeIconPos		иЗ™еЃЪдєЙеЕ≥йЧ≠еЫЊж†ЗдљНзљЃпЉИйїШиЃ§ 'top-right' пЉЙ
	 * @property {String | Number}	round				еЬЖиІТеАЉпЉИйїШиЃ§ 0пЉЙ
	 * @property {Boolean}			zoom				ељУmode=centerжЧґ жШѓеР¶еЉАеРѓзЉ©жФЊпЉИйїШиЃ§ true пЉЙ
	 * @property {Object}			customStyle			зїДдїґзЪДж†ЈеЉПпЉМеѓєи±°ељҐеЉП
	 * @event {Function} open еЉєеЗЇе±ВжЙУеЉА
	 * @event {Function} close еЉєеЗЇе±ВжФґиµЈ
	 * @example <up-popup v-model="show"><text>еЗЇжЈ§ж≥•иАМдЄНжЯУпЉМжњѓжЄЕжґЯиАМдЄНе¶Ц</text></up-popup>
	 */
	export default {
		name: 'up-popup',
		mixins: [mpMixin, mixin, propsPopup],
		data() {
			return {
				overlayDuration: 0
			}
		},
		created() {
			// @ts-ignore
			this.overlayDuration = parseInt(this.duration!!.toString()) + 50
		},
		watch: {
			show(newValue, oldValue) {
				if (newValue == true) {




				}
			}
		},
		computed: {
			transitionStyle():any {
				const style = {
					display: 'flex',
				}
				if (!this.pageInline) {
					// @ts-ignore
					style['zIndex'] = parseInt(this.zIndex!!.toString()) + 1
					style['position'] = 'fixed'
				}
				style[this.mode] = 0
				if (this.mode === 'left') {
					return deepMerge(style, {
						bottom: 0,
						top: 0,
					})
				} else if (this.mode === 'right') {
					return deepMerge(style, {
						bottom: 0,
						top: 0,
					})
				} else if (this.mode === 'top') {
					return deepMerge(style, {
						left: 0,
						right: 0
					})
				} else if (this.mode === 'bottom') {
					return deepMerge(style, {
						left: 0,
						right: 0,
					})
				} else if (this.mode === 'center') {
					return deepMerge(style, {
						alignItems: 'center',
						'justify-content': 'center',
						top: 0,
						left: 0,
						right: 0,
						bottom: 0
					})
				}
				return {}
			},
			contentStyle(): any {
				const style = {}
				// йАЪињЗиЃЊе§Здњ°жБѓзЪДsafeAreaInsetsеАЉжЭ•еИ§жЦ≠жШѓеР¶йЬАи¶БйҐДзХЩй°ґйГ®зКґжАБж†ПеТМеЇХйГ®еЃЙеЕ®е±АзЪДдљНзљЃ
				// дЄНдљњзФ®cssжЦєж°ИпЉМжШѓеЫ†дЄЇnvueдЄНжФѓжМБcssзЪДiPhoneXеЃЙеЕ®еМЇжЯ•иѓҐе±ЮжАІ
				const {
					safeAreaInsets
				} = uni.getWindowInfo()
				
				if (this.mode !== 'center') {
					style['flex'] = 1
				}
				// иГМжЩѓиЙ≤пЉМдЄАиИђзФ®дЇОиЃЊзљЃдЄЇtransparentпЉМеОїйЩ§йїШиЃ§зЪДзЩљиЙ≤иГМжЩѓ
				if (this.bgColor != '') {
					style['backgroundColor'] = this.bgColor
				}
				if(this.round != '') {
					const value = addUnit(this.round)
					if(this.mode === 'top') {
						style['borderBottomLeftRadius'] = value
						style['borderBottomRightRadius'] = value
					} else if(this.mode === 'bottom') {
						style['borderTopLeftRadius'] = value
						style['borderTopRightRadius'] = value
					} else if(this.mode === 'center') {
						style['borderRadius'] = value
					} 
				}
				return deepMerge(style, addStyle(this.customStyle))
			},
			position(): string {
				if (this.mode === 'center') {
					return this.zoom ? 'fade-zoom' : 'fade'
				}
				if (this.mode === 'left') {
					return 'slide-left'
				}
				if (this.mode === 'right') {
					return 'slide-right'
				}
				if (this.mode === 'bottom') {
					return 'slide-up'
				}
				if (this.mode === 'top') {
					return 'slide-down'
				}
				return ''
			},
		},
		emits: ["open", "close", "click", "update:show"],
		methods: {
			// зВєеЗїйБЃзљ©
			overlayClick(): void {
				if (this.closeOnClickOverlay) {
					this.$emit('update:show', false)
					this.$emit('close')
				}
			},
			close(e: any): void {
				this.$emit('update:show', false)
				this.$emit('close')
			},
			afterEnter(): void {
				this.$emit('open')
			},
			clickHandler(): void {
				// зФ±дЇОдЄ≠йГ®еЉєеЗЇжЧґпЉМеЕґup-transitionеН†жНЃдЇЖжХідЄ™й°µйЭҐзЫЄељУдЇОйБЃзљ©пЉМж≠§жЧґйЬАи¶БеПСеЗЇйБЃзљ©зВєеЗїдЇЛдїґпЉМжШѓеР¶жЧ†ж≥ХйАЪињЗзВєеЗїйБЃзљ©еЕ≥йЧ≠еЉєз™Ч
				if(this.mode === 'center') {
					this.overlayClick()
				}
				this.$emit('click')
			},



























		}
	}
</script>

<style lang="scss" scoped>
	@import "../../libs/css/components.scss";
	$up-popup-flex:1 !default;
	$up-popup-content-background-color: #fff !default;

	.up-popup {
		flex: $up-popup-flex;

		&__content {
			background-color: $up-popup-content-background-color;
			position: relative;

			&--round-top {
				border-top-left-radius: 0;
				border-top-right-radius: 0;
				border-bottom-left-radius: 10px;
				border-bottom-right-radius: 10px;
			}

			&--round-left {
				border-top-left-radius: 0;
				border-top-right-radius: 10px;
				border-bottom-left-radius: 0;
				border-bottom-right-radius: 10px;
			}

			&--round-right {
				border-top-left-radius: 10px;
				border-top-right-radius: 0;
				border-bottom-left-radius: 10px;
				border-bottom-right-radius: 0;
			}

			&--round-bottom {
				border-top-left-radius: 10px;
				border-top-right-radius: 10px;
				border-bottom-left-radius: 0;
				border-bottom-right-radius: 0;
			}

			&--round-center {
				border-top-left-radius: 10px;
				border-top-right-radius: 10px;
				border-bottom-left-radius: 10px;
				border-bottom-right-radius: 10px;
			}

			&__close {
				position: absolute;

				&--hover {
					opacity: 0.4;
				}
			}

			&__close--top-left {
				top: 15px;
				left: 15px;
			}

			&__close--top-right {
				top: 15px;
				right: 15px;
			}

			&__close--bottom-left {
				bottom: 15px;
				left: 15px;
			}

			&__close--bottom-right {
				right: 15px;
				bottom: 15px;
			}
		}
	}
</style>
