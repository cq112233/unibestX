export function getParentFunc(name = '', instance: ComponentPublicInstance): ComponentPublicInstance | null {
    let parentTmp = instance.$parent
    // 通过while遍历，这里主要是为了H5需要多层解析的问题
    while (parentTmp != null) {
        // 父组件
        let pname: string|null = null
        if (parentTmp?.$options != null && parentTmp?.$options.name != null) {
            pname = parentTmp?.$options.name
        }
        if (pname == name) {
            // 一定要break,return会导致死循环CPU飙升。
            break
        } else {
            // 如果组件的name不相等，继续上一级寻找
            parentTmp = parentTmp?.$parent
        }
    }
    return parentTmp
}
