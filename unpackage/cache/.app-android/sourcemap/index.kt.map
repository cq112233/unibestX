			},
			get: () => {
				return __locale.value;
			}
		} as WritableComputedOptions<string>);

		// 定义回退语言计算属性
		this.fallbackLocale = computed<any>({
			set: (val : any) => {
				_fallbackLocale.value = val;
			},
			get: () => {
				return _fallbackLocale.value ?? false;
			}
		} as WritableComputedOptions<any>);

		// 初始化可用语言列表
		this.availableLocales = getAllKeys(this.messages.value).sort();
		// 设置国际化API可用性
		this.availabilities = availabilities;

		// 初始化方法
		this._initMethods();

		// 增加实例ID
		composerID++;
		this.id = composerID;

		// 定义页面切换拦截器
		const interceptor = {
			complete: (_ : NavigateToComplete) => {
				setTimeout(() => {
					// 切换TabBar时更新TabBar文本
					setTabBarItems(this._tabBars.value.get(this.locale.value));
				}, 50);
			}
		} as Interceptor;

		// 只在全局实例添加拦截器
		if (__root == null) {
			uni.addInterceptor('switchTab', interceptor);
		}
	}

