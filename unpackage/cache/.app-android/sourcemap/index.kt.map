	/**
	 * 设置语言消息
	 * @param locale 语言
	 * @param message 消息对象
	 */
	setLocaleMessage(locale : string, message : UTSJSONObject) : void {
		const map = new Map<string, UTSJSONObject>();
		// 复制现有消息
		this.messages.value.forEach((value, key) => {
			map.set(key, value);
		});
		// 设置新消息
		map.set(locale, message);
		this.messages.value = map;
		// 更新可用语言列表
		this.availableLocales = getAllKeys(map).sort();
	}

	/**
	 * 获取语言消息
	 * @param locale 语言
	 * @returns 消息对象
	 */
	getLocaleMessage(locale : string) : UTSJSONObject {
		return this.messages.value.get(locale) ?? {};
	}

