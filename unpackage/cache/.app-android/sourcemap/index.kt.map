/**
 * @description 打乱数组
 * @param {array} array 需要打乱的数组
 * @returns {array} 打乱后的数组
 */
export function randomArray(array: any[] = []): any[] {
    // 原理是sort排序,Math.random()产生0<= x < 1之间的数,会导致x-0.05大于或者小于0
	array.sort((): number => {
		return Math.random() - 0.5
	})
    return array.sort(() => Math.random() - 0.5)
}

