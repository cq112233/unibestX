// /**
//  * @description 获取某个对象下的属性，用于通过类似'a.b.c'的形式去获取一个对象的的属性的形式
//  * @param {object} obj 对象
//  * @param {string} key 需要获取的属性字段
//  * @returns {*}
//  */
export function getProperty(obj: UTSJSONObject|null, key: string): any {
    if (null == obj) {
        return ''
    }
    if (key === '') {
        return ''
    }
    if (key.indexOf('.') != -1) {
        const keys = key.split('.')
        let currentObj: UTSJSONObject = obj
        for (let i = 0; i < keys.length; i++) {
            const value: any = currentObj[keys[i]] ?? ''
            if (i == keys.length - 1) {
                return value
            }
            if (typeof value != 'object') {
                return ''
            }
            currentObj = value as UTSJSONObject
        }
        return ''
    }
    return obj[key] ?? {}
}

function setNestedValue(obj: any | null, keys: string[], index: number, value: any): void {
    if (obj == null) {
        return
    }
    const k = keys[index]
    if (index === keys.length - 1) {

        if (obj instanceof Map) {
            (obj as Map<string, any>).set(k, value)
        } else {
            (obj as UTSJSONObject)[k] = value
        }




        return
    }
    
    let nextObj: any | null = null

    if (obj instanceof Map) {
        nextObj = (obj as Map<string, any>).get(k)
    } else {
        nextObj = (obj as UTSJSONObject)[k]
    }




    
    if (nextObj == null || typeof nextObj !== 'object') {
        nextObj = {} as UTSJSONObject

        if (obj instanceof Map) {
            (obj as Map<string, any>).set(k, nextObj)
        } else {
            (obj as UTSJSONObject)[k] = nextObj
        }




    }
    
    setNestedValue(nextObj, keys, index + 1, value)
}

export function setProperty(obj: any, key: string, value: any): void {
    if (obj == null || typeof obj !== 'object') {
        return
    }
    if (typeof key !== 'string' || key === '') {
        return
    }
    
    if (key.indexOf('.') != -1) {
        setNestedValue(obj, key.split('.'), 0, value)
    } else {

        if (obj instanceof Map) {
            (obj as Map<string, any>).set(key, value)
        } else {
            (obj as UTSJSONObject)[key] = value
        }




    }
}

