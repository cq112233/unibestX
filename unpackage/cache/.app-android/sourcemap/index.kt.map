	private _formatter : BaseFormatter;
	// 修饰器映射
	private _modifiers : Map<string, LinkedModify>;
	// 复数规则映射
	private _pluralizationRules : Map<string, PluralizationRule>;
	// 数字格式映射
	private _numberFormats : Ref<Map<string, UTSJSONObject>>;
	// 日期时间格式映射
	private _datetimeFormats : Ref<Map<string, UTSJSONObject>>;
	// TabBar映射
	private _tabBars : Ref<Map<string, string[]>>;

	/**
	 * 构造函数
	 * @param options 配置选项
	 * @param __root 根Composer实例
	 */
	constructor(options : UTSJSONObject = {}, __root : ComposerClass | null = null) {
		// 初始化格式化器
		this._formatter = getFormatter(options);
		// 初始化修饰器
		this._modifiers = getModifiers(options);
		// 初始化复数规则
		this._pluralizationRules = getPluralizationRules(options);

		// 是否继承根实例的语言
		const _inheritLocale = options.getBoolean('inheritLocale') ?? true;
		const useRoot = __root != null && _inheritLocale;

		// 初始化语言
		const __locale = ref<string>(
			useRoot
				? __root.locale.value
				: options.getString('locale') ?? DEFAULT_LOCALE
		);

		// 初始化回退语言
		const _fallbackLocale = ref<any | null>(
			useRoot
				? __root.fallbackLocale.value
				: options.get('fallbackLocale')
		);

		// 初始化消息映射
		this.messages = ref<Map<string, UTSJSONObject>>(getLocaleMap(__locale.value, 'messages', options, __root));
		// 初始化数字格式映射
		this._numberFormats = ref<Map<string, UTSJSONObject>>(getLocaleMap(__locale.value, 'numberFormats', options, __root));
		// 初始化日期时间格式映射
		this._datetimeFormats = ref<Map<string, UTSJSONObject>>(getLocaleMap(__locale.value, 'datetimeFormats', options, __root));
		// 初始化TabBar映射
		this._tabBars = ref<Map<string, string[]>>(getLocaleTabbarMap(__locale.value, 'tabBars', options));

		// 定义语言计算属性
		this.locale = computed<string>({
			set: (val : string) => {
				// 设置语言值
				__locale.value = val;
				// 设置缓存 只有全局才会缓存
				if (__root == null) {
					uni.setStorageSync('uVueI18nLocale', val);
				}
				// 设置tabbar
