		const map = new Map<string, UTSJSONObject>();
		// 遍历现有消息
		this.messages.value.forEach((value, key) => {
			if (key == locale) {
				// 合并消息
				map.set(key, UTSJSONObject.assign({}, value, message));
			} else {
				map.set(key, value);
			}
		});
		this.messages.value = map;
		// 更新可用语言列表
		this.availableLocales = getAllKeys(map).sort();
	}

	/**
	 * 设置日期时间格式
	 * @param locale 语言
	 * @param format 格式对象
	 */
	setDateTimeFormat(locale : string, format : UTSJSONObject) : void {
		const map = new Map<string, UTSJSONObject>();
		// 复制现有格式
		this._datetimeFormats.value.forEach((value, key) => {
			map.set(key, value);
		});
		// 设置新格式
		map.set(locale, format);
		this._datetimeFormats.value = map;
	}

	/**
	 * 获取日期时间格式
	 * @param locale 语言
	 * @returns 格式对象
	 */
	getDateTimeFormat(locale : string) : UTSJSONObject {
		return this._datetimeFormats.value.get(locale) ?? {};
	}

	/**
	 * 合并日期时间格式
	 * @param locale 语言
	 * @param format 格式对象
	 */
	mergeDateTimeFormat(locale : string, format : UTSJSONObject) : void {
		const map = new Map<string, UTSJSONObject>();
		// 遍历现有格式
		this._datetimeFormats.value.forEach((value, key) => {
			if (key == locale) {
				// 合并格式
				map.set(key, UTSJSONObject.assign({}, value, format));
			} else {
				map.set(key, value);
			}
		});
		this._datetimeFormats.value = map;
	}

	/**
	 * 设置数字格式
	 * @param locale 语言
	 * @param format 格式对象
	 */
	setNumberFormat(locale : string, format : UTSJSONObject) : void {
		const map = new Map<string, UTSJSONObject>();
		// 复制现有格式
		this._numberFormats.value.forEach((value, key) => {
			map.set(key, value);
		});
		// 设置新格式
		map.set(locale, format);
		this._numberFormats.value = map;
	}

	/**
	 * 获取数字格式
	 * @param locale 语言
	 * @returns 格式对象
	 */
	getNumberFormat(locale : string) : UTSJSONObject {
		return this._numberFormats.value.get(locale) ?? {};
	}

	/**
	 * 合并数字格式
	 * @param locale 语言
	 * @param format 格式对象
	 */
	mergeNumberFormat(locale : string, format : UTSJSONObject) : void {
		const map = new Map<string, UTSJSONObject>();
		// 遍历现有格式
		this._numberFormats.value.forEach((value, key) => {
			if (key == locale) {
				// 合并格式
				map.set(key, UTSJSONObject.assign({}, value, format));
			} else {
				map.set(key, value);
			}
		});
		this._numberFormats.value = map;
	}

	/**
	 * 设置TabBar
	 * @param locale 语言
	 * @param tabbar TabBar文本数组
	 */
	setTabBar(locale : string, tabbar : string[]) : void {
		const map = new Map<string, string[]>();
		// 复制现有TabBar
		this._tabBars.value.forEach((value, key) => {
			map.set(key, value);
		});
		// 设置新TabBar
		map.set(locale, tabbar);
		this._tabBars.value = map;
	}

	/**
	 * 获取TabBar
	 * @param locale 语言
	 * @returns TabBar文本数组
	 */
	getTabBar(locale : string) : string[] {
		return this._tabBars.value.get(locale) ?? [];
	}
}

/**
 * 创建一个Composer实例，用于处理国际化信息。
 * @param {UTSJSONObject} [options={}] - 配置对象，包含语言环境、格式化器等设置。
 * @param {ComposerClass|null} [__root=null] - 根Composer实例，用于继承语言环境等信息。
 * @returns {ComposerClass} 返回一个新的Composer实例。
 */
export function createComposer(options : UTSJSONObject = {}, __root : ComposerClass | null = null) : ComposerClass {
	return new ComposerClass(options, __root);
}