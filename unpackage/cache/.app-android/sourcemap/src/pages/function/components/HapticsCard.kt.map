import Card from '../../basic/components/Card.uvue'
import { ref } from 'vue'

const copyText = ref('Hello unibestX!')

function triggerVibration() {










}

function handleCopy() {
  if (copyText.value === '')
    return
  uni.setClipboardData({
    data: copyText.value,
    success: () => {
      uni.showToast({
        title: '复制成功',
        icon: 'success',
      })
    },
  })
}
