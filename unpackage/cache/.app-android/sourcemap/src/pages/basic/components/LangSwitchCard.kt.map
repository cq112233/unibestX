.text-16px{font-size:16px}
</style>
<template>
  <Card :title="$t('basic.langTitle')">
    <!-- 当前语言预览 -->
    <view class="bg-__f8fafc_ rounded-12px p-16px mb-16px border-width-1px border-style-solid border-color-__e2e8f0_">
      <text class="text-12px text-__94a3b8_ mb-6px">{{ $t('basic.langPreview') }}</text>

      <text class="text-16px font-bold text-__1e293b_">
        {{ $t('message.welcome') }}
      </text>

      <text class="text-14px text-__475569_ mt-8px">
        {{ $t('message.hello', { msg: 'hi' }) }}
      </text>
    </view>

    <!-- 选项列表 -->
    <!-- 简体中文 -->
    <view class="flex-row items-center justify-between py-12px border-bottom-width-1px border-bottom-style-solid border-bottom-color-__f1f5f9_" @click="switchLanguage('zh-CN')">
      <view class="flex-row items-center">
        <text class="text-15px text-__334155_ font-medium">简体中文</text>
      </view>
      <view class="flex-row items-center">
        <uni-icons v-if="isZhCN" type="checkmarkempty" size="20" style="color: #3b82f6;" />
      </view>
    </view>

    <!-- English -->
    <view class="flex-row items-center justify-between py-12px" @click="switchLanguage('en-US')">
      <view class="flex-row items-center">
        <text class="text-15px text-__334155_ font-medium">English</text>
      </view>
      <view class="flex-row items-center">
        <uni-icons v-if="isEnUS" type="checkmarkempty" size="20" style="color: #3b82f6;" />
      </view>
    </view>
  </Card>
</template>

<script setup lang="uts">
import Card from './Card.uvue'
import { useAppStore } from '@/src/store/index.uts'
import { t } from '@/src/utils/i18n'

const appStore = useAppStore()

// 使用 computed 响应式获取当前 i18n 对象的语言环境
const currentLocale = computed((): string => {
  return appStore.state.locale
})

const isZhCN = computed((): boolean => {
  return currentLocale.value == 'zh-CN'
})

const isEnUS = computed((): boolean => {
  return currentLocale.value == 'en-US'
})

function switchLanguage(lang: string) {
  appStore.setLocale(lang)

  uni.showToast({
    title: t('message.switch_success', null),
    icon: 'none',
    duration: 1500,
  })
}
</script>

