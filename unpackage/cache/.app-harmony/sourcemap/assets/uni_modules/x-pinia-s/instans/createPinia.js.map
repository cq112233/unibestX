/**
 * Pinia 根实例
 *
 * createPinia() 创建一个 Pinia，承担：
 * - 维护全部 store 的实例缓存
 * - 维护插件列表
 * - 暴露 Vue 插件 install(app) 接口（app.use(pinia)）
 *
 * 注意：install() 不会自动赋值 app.config.globalProperties.$pinia
 * （因为 globalProperties 要求顶层变量赋值，install 内 this 是局部值）。
 * 如需 this.$pinia 模板访问，请在 main.uts 顶层手动赋值。
 */

import { IPinia, PiniaPlugin, PiniaPluginContext } from './types.uts'
import { setActivePinia } from './rootState.uts'
import { PiniaStoreBase } from './storeBase.uts'

class Pinia implements IPinia {
	override state : UTSJSONObject = {}
	override _stores : Map<string, any> = new Map<string, any>()
	override _plugins : Array<PiniaPlugin> = []
	/**
	 * Pinia 顶层 effect 作用域。
	 * 字段初始化器中调用 `effectScope()` —— 因为 Pinia 必须在 main.uts 顶层 createPinia()
	 * 创建（见 readme），此时 currentScope 为 null，effectScope() 创建出来的就是顶层独立 scope。
	 * 每个 store 在 defineStore 中通过 `pinia._e.run(() => effectScope())` 创建子 scope，
	 * 嵌套在本 scope 下，与组件生命周期完全解耦。
	 */
	override _e : EffectScope = effectScope()
	private _installed : boolean = false

	constructor() { }

	/**
	 * Vue app.use(pinia) 时被调用
	 */
	override install(app : VueApp) : void {
		if (this._installed) {
			console.warn('[x-pinia-s] pinia already installed on a Vue app')
			return
		}
		this._installed = true
		// 设置为活动 pinia（首个 install 的实例自动成为活动实例）
		setActivePinia(this as IPinia)
		// 注意：这里**不会**自动给 app.config.globalProperties.$pinia 赋值。
		// 因为官方规定（见 readme「Options API 接入」章节）：app-android 平台
		// globalProperties 赋值要求顶层变量，install() 内的 this 是运行时局部值，违反规范。
		// 如需 this.$pinia 模板访问，请在 main.uts 顶层手动赋值：
		//   const pinia = createPinia()
		//   app.config.globalProperties.$pinia = pinia
	}

	/**
	 * 注册插件
	 */
	override use(plugin : PiniaPlugin) : IPinia {
		this._plugins.push(plugin)
		// 闭包内捕获 this 在 UTS 严格模式下不可靠，先把 this 引用提到外部
		const piniaRef : IPinia = this
		// 已经实例化的 store 也应用此插件（与 Pinia 行为一致）
		this._stores.forEach((store : any, _id : string) : void => {
			applyPluginToStore(piniaRef, store, plugin)
		})
		return this
	}
}

/**
 * 把单个插件应用到单个 store 上
 * @internal 包内使用
 *
 * store 参数为 any（实际为 PiniaStoreBase 子类实例），
 * 内部 cast 为 PiniaStoreBase 后访问 $id / $state（继承关系，类型安全）。
 */
export function applyPluginToStore(pinia : IPinia, store : any, plugin : PiniaPlugin) : void {
	// store 是 PiniaStoreBase 子类实例（CounterStore extends PiniaStoreBase），
	// 向上 cast 为 PiniaStoreBase 是类型安全的（继承关系），可以直接访问 $id / $state 属性
	const storeBase : PiniaStoreBase = store as any as PiniaStoreBase
	const ctx : PiniaPluginContext = {
		pinia: pinia,
		storeId: storeBase.$id,
		store: store,
		state: storeBase.$state!
	}
	try {
		plugin(ctx)
	} catch (e) {
		console.warn('[x-pinia-s] plugin error on store ' + ctx.storeId + ':', e)
	}
}

/**
 * 创建一个 Pinia 实例
 */
export function createPinia() : IPinia {
	const pinia : IPinia = new Pinia()
	// 自动设置为活动 pinia，方便单实例场景下 useStore() 直接可用
	setActivePinia(pinia)
	return pinia
}
