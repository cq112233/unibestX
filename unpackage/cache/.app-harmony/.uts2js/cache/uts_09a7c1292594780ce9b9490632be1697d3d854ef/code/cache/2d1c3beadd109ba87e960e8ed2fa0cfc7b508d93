{"code":"let firstBackTime = 0;\n/**\n * 退出应用辅助函数。\n * Android: 先 finishAffinity() 播放退出动画，延迟后 System.exit(0) 彻底杀进程，\n * 确保下次启动是干净冷启动，避免 re-entry 时 setupRenderEffect NPE。\n */\nexport function handleBackPressExit() {\n    const now = Date.now();\n    if (firstBackTime == 0 || now - firstBackTime > 2000) {\n        firstBackTime = now;\n        uni.showToast({\n            title: '再按一次退出应用',\n            position: 'bottom',\n        });\n        setTimeout(() => {\n            if (firstBackTime == now) {\n                firstBackTime = 0;\n            }\n        }, 2000);\n        return true;\n    }\n    // 2秒内再次触发，退出应用\n    uni.exit();\n    return false;\n}\n//# sourceMappingURL=/Users/chenqi/Documents/chenqi-front/unibestX/src/utils/backPress.uts.js.map","references":[],"utsMeta":{"uniExtApis":["uni.showToast","uni.exit"]},"map":"{\"version\":3,\"file\":\"backPress.uts.js\",\"sourceRoot\":\"\",\"sources\":[\"backPress.uts\"],\"names\":[],\"mappings\":\"AAAA,IAAI,aAAa,GAAG,CAAC,CAAA;AAErB;;;;GAIG;AACH,MAAM,UAAU,mBAAmB;IACjC,MAAM,GAAG,GAAG,IAAI,CAAC,GAAG,EAAE,CAAA;IACtB,IAAI,aAAa,IAAI,CAAC,IAAI,GAAG,GAAG,aAAa,GAAG,IAAI,EAAE;QACpD,aAAa,GAAG,GAAG,CAAA;QACnB,GAAG,CAAC,SAAS,CAAC;YACZ,KAAK,EAAE,UAAU;YACjB,QAAQ,EAAE,QAAQ;SACnB,CAAC,CAAA;QACF,UAAU,CAAC;YACT,IAAI,aAAa,IAAI,GAAG,EAAE;gBACxB,aAAa,GAAG,CAAC,CAAA;aAClB;QACH,CAAC,EAAE,IAAI,CAAC,CAAA;QACR,OAAO,IAAI,CAAA;KACZ;IAED,eAAe;IAkBf,GAAG,CAAC,IAAI,EAAE,CAAA;IAGV,OAAO,KAAK,CAAA;AACd,CAAC\"}"}
