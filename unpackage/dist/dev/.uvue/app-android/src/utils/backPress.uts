 */
export function handleBackPressExit(): boolean {
    const now = Date.now();
    if (firstBackTime == 0 || now - firstBackTime > 2000) {
        firstBackTime = now;
        uni.showToast({
            title: '再按一次退出应用',
            position: 'bottom',
        });
        setTimeout(() => {
            if (firstBackTime == now) {
                firstBackTime = 0;
            }
