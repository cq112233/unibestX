    // 2秒内再次触发，退出应用
    try {
        const activity = UTSAndroid.getUniActivity();
        if (activity != null) {
            // 先关闭 Activity（带退出动画）
            activity.finishAffinity();
        }
        // 等退出动画播放完毕后，强制杀进程确保彻底退出
        setTimeout(() => {
