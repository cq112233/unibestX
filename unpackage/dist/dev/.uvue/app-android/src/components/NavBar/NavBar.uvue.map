<style data-scoped="oseg14jspo1ju6b2mil">
.border{border-width:var(--un-line-width-default,1px)}
.fixed{position:fixed}
</style>
<template>
  <view>
    <!-- 导航栏外层容器 -->
    <view
      :class="fixed ? 'navbar-container navbar-fixed' : 'navbar-container'"
      :style="{ backgroundColor: bgColor, borderBottom: border ? '1px solid #e2e8f0' : 'none' }"
    >
      <!-- 安全区域：状态栏占位高度 -->
      <view :style="{ height: `${statusBarHeight}px` }"></view>

      <!-- 导航栏内容区 -->
      <view class="navbar-content">
        <!-- 左侧返回按钮区域 -->
        <view class="navbar-left" @click="handleBack">
          <slot name="left">
            <view v-if="showBack" class="back-btn-wrapper">
              <view class="back-arrow" :style="{ borderColor: titleColor }"></view>
            </view>
          </slot>
        </view>

        <!-- 中间标题区域 -->
        <view class="navbar-title">
          <slot>
            <text class="title-text" :style="{ color: titleColor }">{{ title }}</text>
          </slot>
        </view>

        <!-- 右侧操作栏区域 -->
        <view class="navbar-right">
          <slot name="right"></slot>
        </view>
      </view>
    </view>

    <!-- 占位垫高块：当固定在顶部时防内容遮挡 -->
    <view v-if="fixed && placeholder" :style="{ height: `${statusBarHeight + 44}px` }"></view>
  </view>
</template>

<script setup lang="uts">
import { computed } from 'vue'
import { safeAreaInsets, systemInfo } from '@/src/utils/systemInfo'

// 定义组件参数类型
const props = defineProps({
  title: {
    type: String,
    default: '',
  },
  titleColor: {
    type: String,
    default: '#1e293b',
  },
  bgColor: {
    type: String,
    default: '#ffffff',
  },
  showBack: {
    type: Boolean,
    default: true,
  },
  fixed: {
    type: Boolean,
    default: true,
  },
  placeholder: {
    type: Boolean,
    default: true,
  },
  border: {
    type: Boolean,
    default: false,
  },
})

// 计算状态栏高度，优先取安全区域 top 值，再取系统状态栏高度
const statusBarHeight = computed((): number => {
  return safeAreaInsets.value?.top ?? systemInfo.value?.statusBarHeight ?? 0
})

// 返回操作
function handleBack() {
  uni.navigateBack({
    success() {
      console.log('返回成功')
    },
    fail() {
      // 导航返回失败（说明是直接进入页面没有历史），回退到首页
      uni.switchTab({
        url: '/src/pages/index/index',
      })
    },
  })
}
</script>

