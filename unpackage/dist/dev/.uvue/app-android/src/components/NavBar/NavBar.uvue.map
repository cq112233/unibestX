  align-items: center;
  justify-content: center;
  position: relative;
  width: 100%;
}

.navbar-left {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 60px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  z-index: 10;
}

.back-btn-wrapper {
  padding: 10px 15px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 10px;
