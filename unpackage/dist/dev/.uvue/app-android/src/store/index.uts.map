import { createPinia, createPersistPlugin, setActivePinia } from '@/uni_modules/x-pinia-s'
import type { PersistOptions } from '@/uni_modules/x-pinia-s/instans/types.uts'

/**
 * 创建并配置 Pinia 实例（顶层定义，供 main.uts 使用）
 *
 * 使用说明：
 * 1. 在 main.uts 中导入此 pinia 实例，调用 app.use(pinia) 注册
 * 2. setActivePinia 确保在 app.use(pinia) 之前调用 store 也能正常工作（解决 APP 端白屏问题）
 */

const pinia = createPinia()

// 持久化插件配置
pinia.use(createPersistPlugin({
  keyPrefix: 'pinia:',
  includeStores: ['token', 'user', 'app'],  // 持久化 token, user 和 app store
  excludeStores: [] as string[],
  serializer: null,
} as PersistOptions))

// 立即激活 Pinia 实例
setActivePinia(pinia)

export default pinia

// 模块统一导出
export * from './token'
export * from './user'
export * from './app'
