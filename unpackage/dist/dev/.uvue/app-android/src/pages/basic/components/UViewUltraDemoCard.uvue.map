        <view class="mr-6px mb-4px px-10px py-3px rounded-20px bg-__d1fae5_ border-width-1px border-style-solid border-color-__a7f3d0_">
          <text class="text-11px text-__059669_ font-medium">原生 UTS 支持</text>
