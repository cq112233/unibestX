    <!-- 进入演示页面按钮 -->
    <view
      class="w-full h-44px rounded-8px bg-__3b82f6_ flex flex-row items-center justify-center"
      @click="navigateToShowcase"
    >
      <text class="text-__ffffff_ text-14px font-bold">进入 uview-ultra 示例</text>
    </view>
  </Card>
</template>

<script setup lang="uts">
import Card from './Card.uvue'

let isNavigating = false

function copyWebsiteUrl() {
  uni.setClipboardData({
    data: 'https://uview-ultra.lingyun.net/',
    success: () => {
      uni.showToast({
        title: '官网网址已复制到剪贴板',
        icon: 'none',
      })
    },
  })
}

function navigateToShowcase() {
  if (isNavigating) {
    return
  }
  isNavigating = true
  uni.navigateTo({
    url: '/src/sub/uview-ultra/uview-ultra',
    complete: () => {
      setTimeout(() => {
        isNavigating = false
      }, 500)
    },
  })
}
</script>

