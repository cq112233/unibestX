      </view>
      <view class="flex-row justify-between mb-8px">
        <text class="text-14px text-__64748b_">Bottom (底部距离)</text>
        <text class="text-14px font-bold text-__334155_">{{ safeAreaBottom }}</text>
      </view>
      <view class="flex-row justify-between mb-8px">
        <text class="text-14px text-__64748b_">Left (左侧距离)</text>
        <text class="text-14px font-bold text-__334155_">{{ safeAreaLeft }}</text>
      </view>
