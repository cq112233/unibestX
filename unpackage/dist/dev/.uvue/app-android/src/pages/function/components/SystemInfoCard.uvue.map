<template>
  <Card title="设备系统信息">
    <view class="bg-__f8fafc_ rounded-12px p-16px mb-16px border-width-1px border-style-solid border-color-__e2e8f0_">
      <view class="flex-row justify-between mb-10px">
        <text class="text-14px text-__718096_">手机品牌</text>
        <text class="text-14px font-bold text-__2d3748_">{{ sysBrand !== '' ? sysBrand : '暂无数据' }}</text>
      </view>
      <view class="flex-row justify-between mb-10px">
        <text class="text-14px text-__718096_">手机型号</text>
        <text class="text-14px font-bold text-__2d3748_">{{ sysModel !== '' ? sysModel : '暂无数据' }}</text>
      </view>
      <view class="flex-row justify-between mb-10px">
        <text class="text-14px text-__718096_">操作系统</text>
        <text class="text-14px font-bold text-__2d3748_">{{ sysSystem !== '' ? sysSystem : '暂无数据' }}</text>
      </view>
      <view class="flex-row justify-between">
        <text class="text-14px text-__718096_">运行平台</text>
        <text class="text-14px font-bold text-__2d3748_">{{ sysPlatform !== '' ? sysPlatform : '暂无数据' }}</text>
      </view>
    </view>
    <view class="w-full h-44px rounded-8px bg-__3b82f6_ flex flex-row items-center justify-center" @click="fetchSystemInfo">
      <text class="text-__ffffff_ text-14px font-bold">获取系统信息</text>
    </view>
  </Card>
</template>

<script setup lang="uts">
import Card from '../../basic/components/Card.uvue'
import { onMounted, ref } from 'vue'

const sysBrand = ref('')
const sysModel = ref('')
const sysSystem = ref('')
const sysPlatform = ref('')

function fetchSystemInfo() {
  try {
    const info = uni.getSystemInfoSync()
    sysBrand.value = info.brand ?? ''
    sysModel.value = info.model ?? ''
    sysSystem.value = info.system ?? ''
    sysPlatform.value = info.uniPlatform ?? ''
  }
  catch (err) {
    console.error(err)
  }
}

onMounted(() => {
  fetchSystemInfo()
})
</script>

