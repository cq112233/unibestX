</style>
<template>
  <AppKu>

  <LayoutComponent :navigation-style="'custom'" :navigation-bar-title-text="'up-transition 动画'">

  <view class="page-container bg-__f8fafc_ min-h-screen pb-30px">
    <NavBar title="Transition 动画" :auto-back="true" :safe-area-inset-top="true" bg-color="#ffffff"></NavBar>
    <view class="p-16px">
      <view class="demo-block">
        <text class="demo-label">内置过渡动画</text>
        <view class="transition-demo-wrapper">
          <up-transition :show="transitionShow" mode="fade">
            <view class="transition-demo-box transition-demo-blue">
              <text class="text-14px text-white font-500">fade 淡入淡出</text>
            </view>
          </up-transition>
          <view class="mt-10px">
            <up-button type="primary" :text="transitionShow ? '隐藏动画' : '显示动画'" size="mini" @click="transitionShow = !transitionShow"></up-button>
          </view>
        </view>
      </view>
      <view class="demo-block mt-12px">
        <text class="demo-label">缩放动画</text>
        <view class="transition-demo-wrapper">
          <up-transition :show="transitionShow" mode="zoom">
            <view class="transition-demo-box bg-__19be6b_">
              <text class="text-14px text-white font-500">zoom 缩放</text>
            </view>
          </up-transition>
        </view>
      </view>
      <view class="demo-block mt-12px">
        <text class="demo-label">滑动动画</text>
        <view class="transition-demo-wrapper">
          <up-transition :show="slideShow" :mode="slideMode">
            <view class="transition-demo-box bg-__f56c6c_">
              <text class="text-14px text-white font-500">slide 滑动</text>
            </view>
          </up-transition>
        </view>
        <view class="flex-row items-center justify-around mt-10px">
          <up-button type="primary" text="上滑" size="mini" @click="triggerSlide('slide-up')" custom-style="margin: 0 4px;"></up-button>
          <up-button type="success" text="下滑" size="mini" @click="triggerSlide('slide-down')" custom-style="margin: 0 4px;"></up-button>
          <up-button type="warning" text="左滑" size="mini" @click="triggerSlide('slide-left')" custom-style="margin: 0 4px;"></up-button>
          <up-button type="error" text="右滑" size="mini" @click="triggerSlide('slide-right')" custom-style="margin: 0 4px;"></up-button>
        </view>
      </view>
    </view>
  </view>

  </LayoutComponent>

  </AppKu>
</template>

<script setup lang="uts">
import AppKu from '@/App.ku.uvue'
import LayoutComponent from '@/src/layouts/default.uvue'
import { ref } from 'vue'

const transitionShow = ref(true)

const slideMode = ref('slide-up')
const slideShow = ref(false)

function triggerSlide(mode: string) {
  slideMode.value = mode
  slideShow.value = true
  setTimeout(() => {
    slideShow.value = false
  }, 1500)
}
</script>

