import { useTokenStore } from '../store/token'
import { tabbarList, isPageTabbar, setCurIdxByPath } from '../tabbar/store'
import { EXCLUDE_LOGIN_PATH_LIST, isNeedLoginMode, LOGIN_PAGE } from './config'











/**
 * URL 解析结构体
 */
export type UrlObj = {
  /** 页面路由路径（不含参数） */
  path: string
  /** 路由参数键值对 Map */
  query: Map<string, string>
}

/**
 * 解析 URL 字符串为路径与参数键值对
 * 例如: "/src/pages/login?redirect=index" -> { path: "/src/pages/login", query: { redirect: "index" } }
 */
export function parseUrlToObj(url: string): UrlObj {
  const parts = url.split('?')
  const path = parts[0]
  const query = new Map<string, string>()

  if (parts.length > 1) {
    const queryStr = parts[1]
    const pairs = queryStr.split('&')
    for (let i = 0; i < pairs.length; i++) {
      const pair = pairs[i].split('=')
      if (pair.length > 1) {
        const key = pair[0]
        let value = pair[1]
        // 解码包含百分号转义的参数值
        if (value.indexOf('%') >= 0) {
          value = decodeURIComponent(value) ?? ''
        }
        query.set(key, value)
      } else if (pair.length > 0) {
        query.set(pair[0], '')
      }
    }
  }
  return { path, query } as UrlObj
}



/**
 * 判断路径是否符合排除登录校验名单 (EXCLUDE_LOGIN_PATH_LIST)
 */
export function judgeIsExcludePath(path: string): boolean {
  let normalizedPath = path
  if (normalizedPath.startsWith('src/')) {
    normalizedPath = '/' + normalizedPath
  }
  return EXCLUDE_LOGIN_PATH_LIST.indexOf(normalizedPath) >= 0
}

/**
 * 核心拦截业务逻辑函数
 */
function doIntercept(url: string): boolean {
  __f__('log','at src/router/interceptor.uts:72','doIntercept url:', url)
  if (url == null || url == '') {
    return true
  }

  const urlObj = parseUrlToObj(url)
  let path = urlObj.path
  const query = urlObj.query

  // 1. 规范化路径：如果以 'src/' 开头，补充前导 '/' 使其变为 '/src/'
  if (path.startsWith('src/')) {
    path = '/' + path
  }

  // 相对路径解析：将 "subpage" 转换为基于当前页面所在目录的绝对路径 "/src/pages/.../subpage"
  if (!path.startsWith('/') && !path.startsWith('plugin://') && !path.startsWith('http://') && !path.startsWith('https://')) {
    const pages = getCurrentPages()
    let currentPath = ''
    if (pages.length > 0) {
      currentPath = pages[pages.length - 1].route
    }
    let normalizedCurrentPath = currentPath
    if (normalizedCurrentPath.startsWith('src/')) {
      normalizedCurrentPath = '/' + normalizedCurrentPath
    }
    if (!normalizedCurrentPath.startsWith('/')) {
      normalizedCurrentPath = '/' + normalizedCurrentPath
    }
    const lastSlashIdx = normalizedCurrentPath.lastIndexOf('/')
    let baseDir = ''
    if (lastSlashIdx >= 0) {
      baseDir = normalizedCurrentPath.substring(0, lastSlashIdx)
    }
    path = `${baseDir}/${path}`
  }

  // 确保最终 path 也是以 '/' 开头的绝对路径形式，便于后面和 LOGIN_PAGE 及排除列表匹配
  if (path.startsWith('src/')) {
    path = '/' + path
  }

  __f__('log','at src/router/interceptor.uts:113','doIntercept normalized path:', path)

  // 检查 Token 登录有效性
  const tokenStore = useTokenStore()
  const hasLogin = tokenStore.hasValidLogin()
  __f__('log','at src/router/interceptor.uts:118','doIntercept login status - hasLogin:', hasLogin)

  if (hasLogin) {
    // 已经登录的情况下，如果目标不是登录页直接放行
    if (path !== LOGIN_PAGE) {
      return true
    } else {
      // 如果已登录但尝试再次进入登录页，则重定向到 redirect 对应的目的页或首页
      const redirect = query.get('redirect')
      const redirectUrl = (redirect != null && redirect != '') ? redirect : '/src/pages/index/index'
      if (isPageTabbar(redirectUrl)) {
        setCurIdxByPath(redirectUrl)
        uni.switchTab({ url: redirectUrl })
      } else {
        uni.navigateTo({ url: redirectUrl })
      }
      return false
    }
  }

  // 未登录情况下，记录想要跳转的完整 fullPath 并在登录成功后跳转回去
  let fullPath = path
  if (query.size > 0) {
    const paramsList: string[] = []
    query.forEach((val, key) => {
      paramsList.push(`${key}=${val}`)
    })
    fullPath += `?${paramsList.join('&')}`
  }
  const redirectUrl = `${LOGIN_PAGE}?redirect=${encodeURIComponent(fullPath)}`

  // 1. 默认需要登录模式（白名单策略）：EXCLUDE_LOGIN_PATH_LIST 中存放免登录页面
  if (isNeedLoginMode) {
    if (judgeIsExcludePath(path)) {
      return true
    } else {
      // 目标是登录页本身，放行以防无限重定向
      if (path === LOGIN_PAGE) {
        return true
      }
      __f__('log','at src/router/interceptor.uts:158','doIntercept: redirecting to login page', redirectUrl)
      uni.navigateTo({ url: redirectUrl })
      return false
    }
  }
  // 2. 默认无需登录模式（黑名单策略）：EXCLUDE_LOGIN_PATH_LIST 中存放必须登录的页面
  else {
    if (judgeIsExcludePath(path)) {
      __f__('log','at src/router/interceptor.uts:166','doIntercept: blacklisted path, redirecting to login page', redirectUrl)
      uni.navigateTo({ url: redirectUrl })
      return false
    }
    return true
  }
}

/**
 * 各路由跳转 API 独立拦截器，保证在 App (Android/Kotlin) 原生端能够正确将 options 强转为对应的 Options 类型
 */
export const navigateToInterceptor: Interceptor = {
  invoke: function (options: any): boolean {
    // debugger
    let url = ''
    if (options != null) {

      const opt = options as NavigateToOptions
      url = opt.url





    }
    return doIntercept(url)
  }
}

export const redirectToInterceptor: Interceptor = {
  invoke: function (options: any): boolean {
    let url = ''
    if (options != null) {

      const opt = options as RedirectToOptions
      url = opt.url





    }
    return doIntercept(url)
  }
}

export const reLaunchInterceptor: Interceptor = {
  invoke: function (options: any): boolean {
    let url = ''
    if (options != null) {

      const opt = options as ReLaunchOptions
      url = opt.url





    }
    return doIntercept(url)
  }
}

export const switchTabInterceptor: Interceptor = {
  invoke: function (options: any): boolean {
    let url = ''
    if (options != null) {

      const opt = options as SwitchTabOptions
      url = opt.url





    }
    return doIntercept(url)
  }
}

/**
 * 地图选点调用拦截器（默认直接放行）
 */
export const chooseLocationInterceptor: Interceptor = {
  invoke: function (options: any): boolean {
    return true
  }
}

/**
 * 全局路由拦截安装器
 */
export const installRouteInterceptor = () => {
  uni.addInterceptor('navigateTo', navigateToInterceptor)
  uni.addInterceptor('reLaunch', reLaunchInterceptor)
  uni.addInterceptor('redirectTo', redirectToInterceptor)
  uni.addInterceptor('switchTab', switchTabInterceptor)
  uni.addInterceptor('chooseLocation', chooseLocationInterceptor)
}

/**
 * 校验并处理直接进入（如 H5 直链、小程序分享链接等）的路由场景，补充权限校验
 */
export function checkDirectEntry(options: UTSJSONObject | null) {
  if (options != null) {
    const pathVal = options['path'] as string | null
    if (pathVal != null && pathVal != '') {
      let url = `/${pathVal}`















      navigateToInterceptor.invoke({ url } as any)
    }
  }
}
