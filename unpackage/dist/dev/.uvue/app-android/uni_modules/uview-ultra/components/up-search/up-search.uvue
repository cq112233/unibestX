            let focused = this.$data['focused'] as boolean;
            let keyword = this.$data['keyword'] as string;
            let onlyClearableOnFocused = this.$props['onlyClearableOnFocused'] as boolean;
            if (!clearabled) {
                return false;
            }
            if (onlyClearableOnFocused) {
