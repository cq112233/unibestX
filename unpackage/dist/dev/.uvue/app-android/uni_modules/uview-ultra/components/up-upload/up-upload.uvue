            // const oversize = Array.isArray(file) ?
            // 	file.some((item) => item.size > maxSize) :
            // 	file.size > maxSize;
            const even = (item: UPUploadFileChoosed | null): boolean => {
                let tmp: number = (item != null && item.size != null) ? item.size! : 0;
                return tmp > maxSize;
            };
            const oversize = file.some(even);
            if (oversize) {
                uni.showToast({
                    title: $t("up.upload.sizeExceed", {} as UTSJSONObject)
                });
                this.$emit('oversize', UTSJSONObject.assign({
                    file: this.convertFileToUTSJSON(file)
