                if (item != null) {
                    const obj = UTSAndroid.consoleDebugError(JSON.parseObject(JSON.stringify(item)), " at uni_modules/uview-ultra/components/up-upload/up-upload.uvue:600");
                    if (obj != null) {
                        result.push(obj);
                    }
                }
            });
            return result;
        },
