        emitAfterAutoUpload(res: UTSJSONObject | null, index: number, defaultUrl: string = '', defaultThumb: string = '') {
            const payload = UTSJSONObject.assign(res != null ? res : {} as UTSJSONObject, {
                url: defaultUrl,
                thumb: defaultThumb,
                callback: (r: UTSJSONObject) => {
                    const url = r.getString('url') ?? defaultUrl;
                    if (url == '') {
                        return;
                    }
                    const thumb = r.getString('thumb') ?? defaultThumb;
                    this.succcessUpload(index, url, thumb);
                }
            });
            this.$emit('afterAutoUpload', payload);
        },
        updateUpload(index: number, param: UTSJSONObject) {
            const fileList = this.fileList as Array<UTSJSONObject>;
            let item = fileList[index];
            // @ts-ignore
            fileList.splice(index, 1, {
                ...item as UTSJSONObject,
                // 注意这里不判断会出现succcessUpload先执行又被覆盖的问题
                status: param['progress'] as number == 100 ? 'success' : 'uploading',
                message: '',
                progress: param['progress'] as number
            });
            this.$emit('update:fileList', fileList);
        },
        succcessUpload(index: number, url: string, thumb: string = '') {
            const fileList = this.fileList as Array<UTSJSONObject>;
            let item = fileList[index];
            // @ts-ignore
            fileList.splice(index, 1, {
                ...item as UTSJSONObject,
                status: 'success',
                message: '',
                url: url,
                progress: 100,
                thumb: thumb
            });
            this.$emit('update:fileList', fileList);
        },
        deleteItem(index: number) {
            const fileList = this.fileList as Array<UTSJSONObject>;
            if (this.autoDelete) {
                // @ts-ignore
                fileList.splice(index, 1);
                this.$emit('update:fileList', fileList);
            }
            else {
                this.$emit('delete', UTSJSONObject.assign(UTSJSONObject.assign({}, this.getDetail(index)), {
                    file: fileList[index],
                }));
            }
        },
        // 预览图片
        onPreviewImage(previewItem: UPUploadListItem, index: number) {
