        return {
            isConnected: true,
            networkType: "none",
            isIOS: false
        };
    },
    mounted() {
        this.isIOS = (getDeviceInfo().platform === 'ios');
        uni.onNetworkStatusChange((res: OnNetworkStatusChangeCallbackResult) => {
            this.isConnected = res.isConnected;
            this.networkType = res.networkType;
            this.emitEvent(this.networkType);
        });
        uni.getNetworkType({
            success: (res: GetNetworkTypeSuccess) => {
                this.networkType = res.networkType;
                this.emitEvent(this.networkType);
                if (res.networkType == 'none') {
                    this.isConnected = false;
                }
                else {
                    this.isConnected = true;
                }
            }
        });
    },
    emits: ["disconnected", "connected", "retry"],
    methods: {
        t(s: string): string {
            return t(s);
        },
        retry() {
            // 重新检查网络
            uni.getNetworkType({
                success: (res: GetNetworkTypeSuccess) => {
                    this.networkType = res.networkType;
                    this.emitEvent(this.networkType);
                    if (res.networkType == 'none') {
                        toast(t("up.noNetwork.disconnect"));
                        this.isConnected = false;
                    }
                    else {
                        toast(t("up.noNetwork.connect"));
                        this.isConnected = true;
                    }
                }
            });
            this.$emit('retry');
        },
        // 发出事件给父组件
        emitEvent(networkType: string) {
            this.$emit(networkType === 'none' ? 'disconnected' : 'connected');
        },
