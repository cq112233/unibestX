                }
                else if (typeof value === 'string') {
                    // 尝试解析字符串为时间戳
                    const numValue = parseInt((value as string).toString());
                    if (!isNaN(numValue)) {
                        timestamp = numValue;
                    }
                    else {
                        // 尝试解析日期字符串
                        const date = new Date(value as string);
                        if (!isNaN(date.getTime())) {
                            timestamp = date.getTime();
