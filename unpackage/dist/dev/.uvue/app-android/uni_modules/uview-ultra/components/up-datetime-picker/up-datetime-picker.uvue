            const isDateMode = props.mode !== 'time' && props.mode !== 'timesecond';
            if (isDateMode && (value == null || value == '')) {
                // 如果是日期类型，但是又没有设置值的话，使用当前时间为默认时间
                value = new Date().getTime();
