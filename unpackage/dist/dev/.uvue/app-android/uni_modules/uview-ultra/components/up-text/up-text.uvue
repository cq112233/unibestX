            return addStyle(style);
        },
        clickHandler() {
            // 如果为手机号模式，拨打电话
            if (isTruthy(this.call) && this.mode === 'phone') {
                // todo
                // uni.makePhoneCall({
                //     phoneNumber: this.text
                // })
            }
            this.$emit('click');
        },
        // 默认的姓名脱敏规则
        formatName(name: string): string {
            let value = '';
            if (name.length == 2) {
                value = name.substring(0, 1) + '*';
            }
            else if (name.length > 2) {
                let char = '';
                for (let i = 0, len = name.length - 2; i < len; i++) {
                    char += '*';
                }
                value = name.substring(0, 1) + char + name.substring(-1, 1);
            }
            else {
                value = name;
            }
            return value;
        },
        onGetUserInfo(): void {
        },
        onContact(): void {
        },
