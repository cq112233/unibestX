    height: 40px;
    flex-direction: row;
    align-items: center;
    justify-content: center;
}
.zpx-r-image.data-v-7ff87102 {
    width: 34rpx;
    height: 34rpx;
    transition-duration: .2s;
    transition-property: transform;
    transform: rotate(0deg);
}
.zpx-r-arrow-top.data-v-7ff87102 {
    transform: rotate(0deg);
}
.zpx-r-arrow-down.data-v-7ff87102 {
    transform: rotate(180deg);
}
.zpx-r-text-container.data-v-7ff87102 {
