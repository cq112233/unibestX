  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: auto;
  align-items: stretch;
  align-content: flex-start;
}
.up-keyboard.data-v-d09600de {
  display: flex;
  flex-direction: row;
  flex-direction: row;
  justify-content: space-around;
  background-color: #e0e4e6;
  flex-wrap: wrap;
  padding: 8px 10rpx 8px 10rpx;
}
.up-keyboard__button-wrapper.data-v-d09600de {
  box-shadow: 0 2px 0px #BBBCBE;
  margin: 4px 6rpx;
  border-top-left-radius: 4px;
  border-top-right-radius: 4px;
  border-bottom-left-radius: 4px;
  border-bottom-right-radius: 4px;
}
.up-keyboard__button-wrapper__button.data-v-d09600de {
  width: 222rpx;
  height: 90rpx;
  background-color: #FFFFFF;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  border-top-left-radius: 4px;
  border-top-right-radius: 4px;
  border-bottom-left-radius: 4px;
  border-bottom-right-radius: 4px;
}
.up-keyboard__button-wrapper__button__text.data-v-d09600de {
  font-size: 20px;
  font-weight: 400;
  color: #303133;
}
.up-keyboard__button-wrapper__button--gray.data-v-d09600de {
