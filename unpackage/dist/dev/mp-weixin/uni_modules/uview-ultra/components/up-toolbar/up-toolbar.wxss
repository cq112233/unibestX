.u-empty.data-v-fc1fa64b,
.u-empty__wrap.data-v-fc1fa64b,
.u-tabs.data-v-fc1fa64b,
.u-tabs__wrapper.data-v-fc1fa64b,
.u-tabs__wrapper__scroll-view-wrapper.data-v-fc1fa64b,
.u-tabs__wrapper__scroll-view.data-v-fc1fa64b,
.u-tabs__wrapper__nav.data-v-fc1fa64b,
.u-tabs__wrapper__nav__line.data-v-fc1fa64b,
.up-empty.data-v-fc1fa64b,
.up-empty__wrap.data-v-fc1fa64b,
.up-tabs.data-v-fc1fa64b,
.up-tabs__wrapper.data-v-fc1fa64b,
.up-tabs__wrapper__scroll-view-wrapper.data-v-fc1fa64b,
.up-tabs__wrapper__scroll-view.data-v-fc1fa64b,
.up-tabs__wrapper__nav.data-v-fc1fa64b,
.up-tabs__wrapper__nav__line.data-v-fc1fa64b {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: auto;
  align-items: stretch;
  align-content: flex-start;
}
.up-toolbar.data-v-fc1fa64b {
  height: 42px;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.up-toolbar__wrapper__cancel.data-v-fc1fa64b {
  color: #909193;
  font-size: 15px;
  padding: 0 15px;
}
.up-toolbar__title.data-v-fc1fa64b {
  color: #303133;
  padding: 0 60rpx;
  font-size: 16px;
  flex: 1;
  text-align: center;
}
.up-toolbar__wrapper__left.data-v-fc1fa64b, .up-toolbar__wrapper__right.data-v-fc1fa64b {
  display: flex;
  flex-direction: row;
}
.up-toolbar__wrapper__confirm.data-v-fc1fa64b {
  color: var(--theme-color, #0957de);
  font-size: 15px;
  padding: 0 15px;
}