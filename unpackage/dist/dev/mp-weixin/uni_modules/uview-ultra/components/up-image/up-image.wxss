.u-empty.data-v-efb2adde,
.u-empty__wrap.data-v-efb2adde,
.u-tabs.data-v-efb2adde,
.u-tabs__wrapper.data-v-efb2adde,
.u-tabs__wrapper__scroll-view-wrapper.data-v-efb2adde,
.u-tabs__wrapper__scroll-view.data-v-efb2adde,
.u-tabs__wrapper__nav.data-v-efb2adde,
.u-tabs__wrapper__nav__line.data-v-efb2adde,
.up-empty.data-v-efb2adde,
.up-empty__wrap.data-v-efb2adde,
.up-tabs.data-v-efb2adde,
.up-tabs__wrapper.data-v-efb2adde,
.up-tabs__wrapper__scroll-view-wrapper.data-v-efb2adde,
.up-tabs__wrapper__scroll-view.data-v-efb2adde,
.up-tabs__wrapper__nav.data-v-efb2adde,
.up-tabs__wrapper__nav__line.data-v-efb2adde {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: auto;
  align-items: stretch;
  align-content: flex-start;
}
.up-image.data-v-efb2adde {
  position: relative;
  transition: opacity 0.5s ease-in-out;
}
.up-image__image.data-v-efb2adde {
  width: 100%;
  height: 100%;
}
.up-image__loading.data-v-efb2adde, .up-image__error.data-v-efb2adde {
  position: absolute;
  top: 0px;
  left: 0px;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background-color: #f3f4f6;
}