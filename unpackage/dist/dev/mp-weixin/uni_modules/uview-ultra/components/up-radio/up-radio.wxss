.up-tabs__wrapper__nav__line.data-v-45813f6f {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: auto;
  align-items: stretch;
  align-content: flex-start;
}
.up-radio.data-v-45813f6f {
  display: flex;
  flex-direction: row;
  overflow: hidden;
  flex-direction: row;
  align-items: center;
  margin-bottom: 5px;
  margin-top: 5px;
}
.up-radio-label--left.data-v-45813f6f {
  flex-direction: row;
}
.up-radio-label--right.data-v-45813f6f {
  flex-direction: row-reverse;
  justify-content: space-between;
}
.up-radio__icon-wrap.data-v-45813f6f {
  box-sizing: border-box;
  transition-property: border-color, background-color, color;
  transition-duration: 0.2s;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-right: 6px;
  border-width: 1px;
  border-color: #c8c9cc;
  border-style: solid;
}
.up-radio__icon-wrap--circle.data-v-45813f6f {
  border-radius: 50px;
}
.up-radio__icon-wrap--square.data-v-45813f6f {
  border-radius: 3px;
}
.up-radio__icon-wrap--checked.data-v-45813f6f {
  background-color: red;
  border-color: #2979ff;
}
.up-radio__icon-wrap--active.data-v-45813f6f {
  background-color: var(--theme-color, #0957de);
  border-color: var(--theme-color, #0957de);
}
.up-radio__icon-wrap--disabled.data-v-45813f6f {
  background-color: #ebedf0 !important;
}
.up-radio__label.data-v-45813f6f {
  margin-left: 5px;
  margin-right: 12px;
  color: #606266;
  font-size: 15px;
}
.up-radio__label--disabled.data-v-45813f6f {
  color: #c8c9cc;
}