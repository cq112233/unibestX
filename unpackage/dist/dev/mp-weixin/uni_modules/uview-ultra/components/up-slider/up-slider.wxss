.up-slider.data-v-66aa6fc7 {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
}
.up-slider__native.data-v-66aa6fc7 {
  flex: 1;
}
.up-slider-inner.data-v-66aa6fc7 {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  border-radius: 999px;
  padding: 10px 18px;
  justify-content: center;
}
.up-slider__show-value.data-v-66aa6fc7 {
  margin: 10px 18px 10px 0px;
}
.up-slider__show-range-value.data-v-66aa6fc7 {
  padding-top: 2px;
  font-size: 12px;
  line-height: 12px;
  position: absolute;
  bottom: 0;
}
.up-slider__base.data-v-66aa6fc7 {
  background-color: #ebedf0;
}
.up-slider-inner.data-v-66aa6fc7:before {
  position: absolute;
  right: 0;
  left: 0;
  top: -8px;
  bottom: -8px;
  z-index: -1;
}
.up-slider__gap.data-v-66aa6fc7 {
  position: relative;
  border-radius: 999px;
  transition: width 0.2s;
  background-color: var(--theme-color, #0957de);
  align-self: flex-start;
}
.up-slider__button.data-v-66aa6fc7 {
  width: 24px;
  height: 24px;
  border-radius: 999px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  background-color: #fff;
}
.up-slider__button-wrap.data-v-66aa6fc7 {
  position: absolute;
}
.up-slider--disabled.data-v-66aa6fc7 {
  opacity: 0.5;
}