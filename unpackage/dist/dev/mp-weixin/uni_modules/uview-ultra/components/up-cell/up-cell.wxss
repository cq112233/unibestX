.u-empty.data-v-7b2bd41d,
.u-empty__wrap.data-v-7b2bd41d,
.u-tabs.data-v-7b2bd41d,
.u-tabs__wrapper.data-v-7b2bd41d,
.u-tabs__wrapper__scroll-view-wrapper.data-v-7b2bd41d,
.u-tabs__wrapper__scroll-view.data-v-7b2bd41d,
.u-tabs__wrapper__nav.data-v-7b2bd41d,
.u-tabs__wrapper__nav__line.data-v-7b2bd41d,
.up-empty.data-v-7b2bd41d,
.up-empty__wrap.data-v-7b2bd41d,
.up-tabs.data-v-7b2bd41d,
.up-tabs__wrapper.data-v-7b2bd41d,
.up-tabs__wrapper__scroll-view-wrapper.data-v-7b2bd41d,
.up-tabs__wrapper__scroll-view.data-v-7b2bd41d,
.up-tabs__wrapper__nav.data-v-7b2bd41d,
.up-tabs__wrapper__nav__line.data-v-7b2bd41d {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: auto;
  align-items: stretch;
  align-content: flex-start;
}
.up-cell__body.data-v-7b2bd41d {
  display: flex;
  flex-direction: row;
  box-sizing: border-box;
  padding: 10px 15px !important;
  align-items: center;
}
.up-cell__body__content.data-v-7b2bd41d {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
}
.up-cell__body--large.data-v-7b2bd41d {
  padding-top: 13px !important;
  padding-bottom: 13px !important;
}
.up-cell__left-icon-wrap.data-v-7b2bd41d, .up-cell__right-icon-wrap.data-v-7b2bd41d {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.up-cell__left-icon-wrap.data-v-7b2bd41d {
  margin-right: 4px !important;
}
.up-cell__right-icon-wrap.data-v-7b2bd41d {
  margin-left: 4px !important;
  transition: transform 0.3s;
}
.up-cell__right-icon-wrap--up.data-v-7b2bd41d {
  transform: rotate(-90deg);
}
.up-cell__right-icon-wrap--down.data-v-7b2bd41d {
  transform: rotate(90deg);
}
.up-cell__title.data-v-7b2bd41d {
  flex: 1 !important;
}
.up-cell__title-text.data-v-7b2bd41d {
  font-size: 15px !important;
  line-height: 22px !important;
  color: #303133 !important;
}
.up-cell__title-text--large.data-v-7b2bd41d {
  font-size: 16px !important;
}
.up-cell__label.data-v-7b2bd41d {
  margin-top: 5px !important;
  font-size: 12px !important;
  color: #909193 !important;
  line-height: 18px !important;
}
.up-cell__label--large.data-v-7b2bd41d {
  font-size: 14px !important;
}
.up-cell__value.data-v-7b2bd41d {
  text-align: right;
  margin-left: auto;
  font-size: 14px !important;
  line-height: 24px !important;
  color: #606266 !important;
}
.up-cell__value--large.data-v-7b2bd41d {
  font-size: 15px !important;
}
.up-cell--clickable.data-v-7b2bd41d {
  background-color: #f3f4f6 !important;
}
.up-cell--disabled.data-v-7b2bd41d {
  color: #c8c9cc !important;
}
.up-cell--center.data-v-7b2bd41d {
  align-items: center;
}