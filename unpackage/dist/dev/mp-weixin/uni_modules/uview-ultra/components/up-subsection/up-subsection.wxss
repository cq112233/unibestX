.u-empty.data-v-d80a85c3,
.u-empty__wrap.data-v-d80a85c3,
.u-tabs.data-v-d80a85c3,
.u-tabs__wrapper.data-v-d80a85c3,
.u-tabs__wrapper__scroll-view-wrapper.data-v-d80a85c3,
.u-tabs__wrapper__scroll-view.data-v-d80a85c3,
.u-tabs__wrapper__nav.data-v-d80a85c3,
.u-tabs__wrapper__nav__line.data-v-d80a85c3,
.up-empty.data-v-d80a85c3,
.up-empty__wrap.data-v-d80a85c3,
.up-tabs.data-v-d80a85c3,
.up-tabs__wrapper.data-v-d80a85c3,
.up-tabs__wrapper__scroll-view-wrapper.data-v-d80a85c3,
.up-tabs__wrapper__scroll-view.data-v-d80a85c3,
.up-tabs__wrapper__nav.data-v-d80a85c3,
.up-tabs__wrapper__nav__line.data-v-d80a85c3 {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: auto;
  align-items: stretch;
  align-content: flex-start;
}
.up-subsection.data-v-d80a85c3 {
  display: flex;
  flex-direction: row;
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}
.up-subsection--button.data-v-d80a85c3 {
  height: 34px;
  background-color: #eeeeef;
  padding: 3px;
  border-radius: 4px;
  align-items: stretch;
}
.up-subsection--button__bar.data-v-d80a85c3 {
  background-color: #ffffff;
  border-radius: 4px !important;
}
.up-subsection--subsection.data-v-d80a85c3 {
  height: 32px;
}
.up-subsection__bar.data-v-d80a85c3 {
  position: absolute;
  left: 0;
  transition-property: transform, color;
  transition-duration: 0.3s;
  transition-timing-function: ease-in-out;
  display: flex;
  flex-direction: row;
  align-items: stretch;
}
.up-subsection__bar__inner.data-v-d80a85c3 {
  flex: 1;
  align-self: stretch;
  background-color: var(--theme-color, #0957de);
}
.up-subsection__bar__inner--button.data-v-d80a85c3 {
  margin: 3px;
  background-color: #ffffff;
}
.up-subsection__bar--first.data-v-d80a85c3 {
  border-top-left-radius: 4px;
  border-bottom-left-radius: 4px;
  border-top-right-radius: 0px;
  border-bottom-right-radius: 0px;
}
.up-subsection__bar--center.data-v-d80a85c3 {
  border-top-left-radius: 0px;
  border-bottom-left-radius: 0px;
  border-top-right-radius: 0px;
  border-bottom-right-radius: 0px;
}
.up-subsection__bar--last.data-v-d80a85c3 {
  border-top-left-radius: 0px;
  border-bottom-left-radius: 0px;
  border-top-right-radius: 4px;
  border-bottom-right-radius: 4px;
}
.up-subsection__item.data-v-d80a85c3 {
  display: flex;
  flex-direction: row;
  flex: 1;
  justify-content: center;
  align-items: center;
  position: relative;
  border-color: var(--theme-color, #0957de);
}
.up-subsection__item--no-border-right.data-v-d80a85c3 {
  border-right-width: 0 !important;
}
.up-subsection__item--first.data-v-d80a85c3 {
  border-top-left-radius: 4px;
  border-bottom-left-radius: 4px;
}
.up-subsection__item--last.data-v-d80a85c3 {
  border-top-right-radius: 4px;
  border-bottom-right-radius: 4px;
}
.up-subsection__item__text.data-v-d80a85c3 {
  font-size: 12px;
  line-height: 14px;
  transition-property: color;
  transition-duration: 0.3s;
}
.up-subsection__item__text--disabled.data-v-d80a85c3 {
  color: #c8c9cc !important;
}
.up-subsection__item__text--active.data-v-d80a85c3 {
  color: var(--theme-color, #0957de);
}