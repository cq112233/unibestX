.u-empty.data-v-be09750b,
.u-empty__wrap.data-v-be09750b,
.u-tabs.data-v-be09750b,
.u-tabs__wrapper.data-v-be09750b,
.u-tabs__wrapper__scroll-view-wrapper.data-v-be09750b,
.u-tabs__wrapper__scroll-view.data-v-be09750b,
.u-tabs__wrapper__nav.data-v-be09750b,
.u-tabs__wrapper__nav__line.data-v-be09750b,
.up-empty.data-v-be09750b,
.up-empty__wrap.data-v-be09750b,
.up-tabs.data-v-be09750b,
.up-tabs__wrapper.data-v-be09750b,
.up-tabs__wrapper__scroll-view-wrapper.data-v-be09750b,
.up-tabs__wrapper__scroll-view.data-v-be09750b,
.up-tabs__wrapper__nav.data-v-be09750b,
.up-tabs__wrapper__nav__line.data-v-be09750b {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: auto;
  align-items: stretch;
  align-content: flex-start;
}
.up-steps-item.data-v-be09750b {
  flex: 1;
  display: flex;
  flex-direction: row;
}
.up-steps-item--row.data-v-be09750b {
  flex-direction: column;
  align-items: center;
  position: relative;
}
.up-steps-item--column.data-v-be09750b {
  position: relative;
  flex-direction: row;
  justify-content: flex-start;
  padding-bottom: 5px;
}
.up-steps-item__wrapper.data-v-be09750b {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  position: relative;
  background-color: #fff;
  border-radius: 50px;
}
.up-steps-item__wrapper--column.data-v-be09750b {
  width: 20px;
  height: 20px;
}
.up-steps-item__wrapper--column--dot.data-v-be09750b {
  height: 20px;
  width: 20px;
}
.up-steps-item__wrapper--row.data-v-be09750b {
  width: 20px;
  height: 20px;
}
.up-steps-item__wrapper--row--dot.data-v-be09750b {
  width: 20px;
  height: 20px;
}
.up-steps-item__wrapper__circle.data-v-be09750b {
  width: 20px;
  height: 20px;
  box-sizing: border-box;
  flex-shrink: 0;
  border-radius: 100px;
  border-width: 1px;
  border-style: solid;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
.up-steps-item__wrapper__circle--wait.data-v-be09750b {
  border-color: #909193;
  background-color: transparent;
}
.up-steps-item__wrapper__circle--active.data-v-be09750b {
  background-color: var(--theme-color, #0957de);
  border-color: var(--theme-color, #0957de);
}
.up-steps-item__wrapper__circle--finish.data-v-be09750b {
  border-color: var(--theme-color, #0957de);
  background-color: transparent;
}
.up-steps-item__wrapper__circle--error.data-v-be09750b {
  border-color: #f56c6c;
  background-color: transparent;
}
.up-steps-item__wrapper__circle__text.data-v-be09750b {
  color: #909193;
  font-size: 11px;
  text-align: center;
}
.up-steps-item__wrapper__circle__text--active.data-v-be09750b {
  color: #ffffff;
}
.up-steps-item__wrapper__dot.data-v-be09750b {
  width: 10px;
  height: 10px;
  border-radius: 100px;
  background-color: #606266;
}
.up-steps-item__wrapper__dot--active.data-v-be09750b {
  background-color: var(--theme-color, #0957de);
}
.up-steps-item__content.data-v-be09750b {
  display: flex;
  flex-direction: row;
  flex: 1;
}
.up-steps-item__content--row.data-v-be09750b {
  flex-direction: column;
  align-items: center;
}
.up-steps-item__content--column.data-v-be09750b {
  flex-direction: column;
  margin-left: 6px;
}
.up-steps-item__line.data-v-be09750b {
  position: absolute;
  background-color: #909193;
}
.up-steps-item__line--active.data-v-be09750b {
  background-color: var(--theme-color, #0957de);
}
.up-steps-item__line--row.data-v-be09750b {
  top: 10px;
  height: 1px;
}
.up-steps-item__line--column.data-v-be09750b {
  width: 1px;
  left: 10px;
}