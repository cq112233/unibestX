.up-button.data-v-0816b018 {
  height: 40px;
  position: relative;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
.up-button__text.data-v-0816b018 {
  font-size: 15px;
  color: #fff;
}
.up-button__loading-text.data-v-0816b018 {
  font-size: 15px;
  margin-left: 4px;
}
.up-button--large.data-v-0816b018 {
  width: 100%;
  height: 50px;
  padding: 0 15px;
}
.up-button--normal.data-v-0816b018 {
  padding: 0 12px;
}
.up-button--normal .up-button__text.data-v-0816b018 {
  font-size: 14px;
}
.up-button--small.data-v-0816b018 {
  min-width: 60px;
  height: 30px;
  padding: 0px 8px;
}
.up-button--small .up-button__text.data-v-0816b018 {
  font-size: 12px;
}
.up-button--mini.data-v-0816b018 {
  height: 22px;
  min-width: 50px;
  padding: 0px 8px;
}
.up-button--mini .up-button__text.data-v-0816b018 {
  font-size: 10px;
}
.up-button--disabled.data-v-0816b018 {
  opacity: 0.5;
}
.up-button--active.data-v-0816b018 {
  opacity: 0.75;
}
.up-button--info.data-v-0816b018 {
  background-color: #fff !important;
  border-color: #ebedf0 !important;
  border-width: 1px !important;
  border-style: solid !important;
}
.up-button--info .up-button__text.data-v-0816b018 {
  color: #323233;
}
.up-button--success.data-v-0816b018 {
  background-color: #5ac725 !important;
  border-color: #5ac725 !important;
  border-width: 1px !important;
  border-style: solid !important;
}
.up-button--success .up-button__text.data-v-0816b018 {
  color: #fff;
}
.up-button--primary.data-v-0816b018 {
  background-color: var(--theme-color, #0957de) !important;
  border-color: var(--theme-color, #0957de) !important;
  border-width: 1px !important;
  border-style: solid !important;
}
.up-button--primary .up-button__text.data-v-0816b018 {
  color: #fff;
}
.up-button--error.data-v-0816b018 {
  background-color: #f56c6c !important;
  border-color: #f56c6c !important;
  border-width: 1px !important;
  border-style: solid !important;
}
.up-button--error .up-button__text.data-v-0816b018 {
  color: #fff;
}
.up-button--warning.data-v-0816b018 {
  background-color: #f9ae3d !important;
  border-color: #f9ae3d !important;
  border-width: 1px !important;
  border-style: solid !important;
}
.up-button--warning .up-button__text.data-v-0816b018 {
  color: #fff;
}
.up-button--block.data-v-0816b018 {
  display: flex;
  flex-direction: row;
  width: 100%;
}
.up-button--circle.data-v-0816b018 {
  border-top-right-radius: 100px;
  border-top-left-radius: 100px;
  border-bottom-left-radius: 100px;
  border-bottom-right-radius: 100px;
}
.up-button--square.data-v-0816b018 {
  border-bottom-left-radius: 3px;
  border-bottom-right-radius: 3px;
  border-top-left-radius: 3px;
  border-top-right-radius: 3px;
}
.up-button__icon.data-v-0816b018 {
  min-width: 4px;
}
.up-button--plain.data-v-0816b018 {
  background-color: #fff !important;
}
.up-button--plain.up-button--primary .up-button__text.data-v-0816b018 {
  color: var(--theme-color, #0957de);
}
.up-button--plain.up-button--info .up-button__text.data-v-0816b018 {
  color: #000000;
}
.up-button--plain.up-button--success .up-button__text.data-v-0816b018 {
  color: #5ac725;
}
.up-button--plain.up-button--error .up-button__text.data-v-0816b018 {
  color: #f56c6c;
}
.up-button--plain.up-button--warning .up-button__text.data-v-0816b018 {
  color: #f56c6c;
}
.up-button--hairline.data-v-0816b018 {
  border-width: 0.5px !important;
}
.up-button.data-v-0816b018:before {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  transform: translate(-50%, -50%);
  opacity: 0;
  background-color: #000 !important;
  border-color: #000 !important;
}
.up-button__button--active.data-v-0816b018 {
  opacity: 0.2 !important;
}
.up-button__button--active.data-v-0816b018:before {
  opacity: 0.15;
}
.up-button__loading-text.data-v-0816b018 {
  margin-left: 4px;
}