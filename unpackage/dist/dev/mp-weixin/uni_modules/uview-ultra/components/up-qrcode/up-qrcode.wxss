.up-qrcode.data-v-d075c714 {
  display: flex;
  position: relative;
}
.up-qrcode__matrix.data-v-d075c714 {
  position: relative;
  overflow: hidden;
}
.up-qrcode__canvas.data-v-d075c714 {
  position: absolute;
  left: 0;
  top: 0;
}
.up-qrcode__icon.data-v-d075c714 {
  position: absolute;
  border-radius: 4px;
  background-color: #ffffff;
}
.up-qrcode__loading.data-v-d075c714 {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.8);
}
.up-qrcode__error.data-v-d075c714 {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
}
.up-qrcode__error-text.data-v-d075c714 {
  color: #fa3534;
  font-size: 14px;
}