:host{display:flex;flex-direction:column}

.tabbar-placeholder {
  /* 高度通过 :style 动态绑定 */
}

/* 固定在底部的容器，内部级联展示三个层 */
.tabbar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1;
  background-color: transparent;
  flex-direction: column;
}

/* 【底板层】覆盖「固定高度 + 安全区」的白色底板，绑定高度动态设定 */
.tabbar-bg {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-top-width: 1rpx;
  border-top-style: solid;
  border-top-color: #eeeeee;
  z-index: 1;
}

/* 【固定高度层】tab 图标按鈕区，与底板同高；鼓包由 TabbarItem 内绝对定位向上突出 */
.tabbar-inner {
  flex-direction: row;
  height: 80px;
  align-items: flex-end;
  z-index: 2;
}
.tabbar-item {
  flex: 1;
  align-items: center;
  justify-content: center;
  height: 50px;
}
.tabbar-item-bulge {
  height: 80px;
}

/* 【安全区层】底部安全区白色填充，高度动态设定 */
.safe-area-bg {
  z-index: 1;
  background-color: #ffffff;
}