:host{display:flex;flex-direction:column}

.tabbar-item-inner {
  align-items: center;
  justify-content: center;
  position: relative;
}
.icon-normal {
  width: 24px;
  height: 24px;
}
.tabbar-text {
  font-size: 10px;
  margin-top: 2px;
  text-align: center;
}
.badge-dot {
  position: absolute;
  top: 0;
  right: 0;
  width: 8px;
  height: 8px;
  border-radius: 8px;
  background-color: #f56c6c;
}
.badge-count {
  position: absolute;
  top: 0;
  right: -6px;
  height: 16px;
  padding-left: 4px;
  padding-right: 4px;
  border-radius: 16px;
  background-color: #f56c6c;
  align-items: center;
  justify-content: center;
}
.badge-count-text {
  font-size: 10px;
  color: #ffffff;
  text-align: center;
}

/* 鼓包容器：充满父级的 tabbar-item */
.bulge-item {
  position: relative;
  width: 100%;
  height: 80px;
  align-items: center;
}
.bulge-btn {
  position: absolute;
  top: 18px;
  width: 52px;
  height: 52px;
  border-radius: 26px;
  background-image: linear-gradient(135deg, #0ea5e9, #2563eb);
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.5);
  align-items: center;
  justify-content: center;
  box-shadow: 0px 3px 8px rgba(37, 99, 235, 0.25);
}
.ai-btn-text {
  color: #ffffff;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 1px;
  text-align: center;
}