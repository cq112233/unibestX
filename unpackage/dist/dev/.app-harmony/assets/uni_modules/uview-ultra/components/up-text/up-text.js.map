<template>
    <view
        class="up-text"
        :class="[customClass]"
        v-if="show"
        :style="{
            margin: margin,
			justifyContent: align === 'left' ? 'flex-start' : align === 'center' ? 'center' : 'flex-end'
        }"
        @tap="clickHandler"
    >
        <text
            :class="['up-text__price', `up-text__value--${type}`]"
            v-if="mode === 'price'"
            :style="[valueStyle]"
            >пҝҘ</text
        >
        <view class="up-text__prefix-icon" v-if="prefixIcon">
            <up-icon
                :name="prefixIcon"
                :customStyle="addStyle(iconStyle)"
            ></up-icon>
        </view>
        <up-link
            v-if="mode === 'link'" class="up-text__value"
            :style="{fontWeight: valueStyle['fontWeight'], wordWrap: valueStyle['wordWrap'], fontSize: valueStyle['fontSize']}"
            :class="[`up-text__value--${type}`,	`up-line-${lines}`]" :text="value"
            :href="href"
            underLine
        ></up-link>
        <template v-else-if="openType != '' && isMp">
            <button
                class="up-reset-button up-text__value"
                :style="[valueStyle]"
                data-index="index"
                :openType="openType"
                @getuserinfo="onGetUserInfo"
                @contact="onContact"
                @getphonenumber="onGetPhoneNumber"
                @error="onError"
                @launchapp="onLaunchApp"
                @opensetting="onOpenSetting"
                :lang="lang"
                :session-from="sessionFrom"
                :send-message-title="sendMessageTitle"
                :send-message-path="sendMessagePath"
                :send-message-img="sendMessageImg"
                :show-message-card="showMessageCard"
                :app-parameter="appParameter"
            >
                {{ value }}
            </button>
        </template>
        <text
            v-else
            class="up-text__value"
            :style="[valueStyle]"
            :class="[
                `up-text__value--${type}`,
                `up-line-${lines}`
            ]"
            >{{ value }}</text
        >
        <view class="up-text__suffix-icon" v-if="suffixIcon != ''">
            <up-icon
                :name="suffixIcon"
                :customStyle="addStyle(iconStyle)"
            ></up-icon>
        </view>
    </view>
</template>

<script lang="uts">
import { propsText } from './props'
import { mpMixin } from '../../libs/mixin/mpMixin';
import { mixin } from '../../libs/mixin/mixin';
import { buttonMixin } from '../../libs/mixin/button';
import { openType } from '../../libs/mixin/openType';
import { addStyle, addUnit, deepMerge } from '../../libs/function/index';
import { error, priceFormat, timeFormat } from '../../libs/function/index';
import {
	func as testFunc,
	date as testDate,
	url as testUrl,
} from '../../libs/function/test';
/**
 * Text ж–Үжң¬
 * @description жӯӨз»„д»¶йӣҶжҲҗдәҶж–Үжң¬зұ»еңЁйЎ№зӣ®дёӯзҡ„еёёз”ЁеҠҹиғҪпјҢеҢ…жӢ¬зҠ¶жҖҒпјҢжӢЁжү“з”өиҜқпјҢж јејҸеҢ–ж—ҘжңҹпјҢ*жӣҝжҚўпјҢи¶…й“ҫжҺҘ...зӯүеҠҹиғҪгҖӮ жӮЁеӨ§еҸҜдёҚеҝ…еңЁдҪҝз”Ёзү№ж®Ҡж–Үжң¬ж—¶иҮӘе·ұе®ҡд№үпјҢtextз»„д»¶еҮ д№Һж¶өзӣ–жӮЁиғҪдҪҝз”Ёзҡ„еӨ§йғЁеҲҶеңәжҷҜгҖӮ
 * @tutorial https://ijry.github.io/uview-plus/components/loading.html
 * @property {String} 					type		дё»йўҳйўңиүІ
 * @property {Boolean} 					show		жҳҜеҗҰжҳҫзӨәпјҲй»ҳи®Ө true пјү
 * @property {String | Number}			text		жҳҫзӨәзҡ„еҖј
 * @property {String}					prefixIcon	еүҚзҪ®еӣҫж Ү
 * @property {String} 					suffixIcon	еҗҺзҪ®еӣҫж Ү
 * @property {String} 					mode		ж–Үжң¬еӨ„зҗҶзҡ„еҢ№й…ҚжЁЎејҸ text-жҷ®йҖҡж–Үжң¬пјҢprice-д»·ж јпјҢphone-жүӢжңәеҸ·пјҢname-е§“еҗҚпјҢdate-ж—ҘжңҹпјҢlink-и¶…й“ҫжҺҘ
 * @property {String} 					href		mode=linkдёӢпјҢй…ҚзҪ®зҡ„й“ҫжҺҘ
 * @property {String | Function} 		format		ж јејҸеҢ–и§„еҲҷ
 * @property {Boolean} 					call		mode=phoneж—¶пјҢзӮ№еҮ»ж–Үжң¬жҳҜеҗҰжӢЁжү“з”өиҜқпјҲй»ҳи®Ө false пјү
 * @property {String} 					openType	е°ҸзЁӢеәҸзҡ„жү“ејҖж–№ејҸ
 * @property {Boolean} 					bold		жҳҜеҗҰзІ—дҪ“пјҢй»ҳи®ӨnormalпјҲй»ҳи®Ө false пјү
 * @property {Boolean} 					block		жҳҜеҗҰеқ—зҠ¶пјҲй»ҳи®Ө false пјү
 * @property {String | Number} 			lines		ж–Үжң¬жҳҫзӨәзҡ„иЎҢж•°пјҢеҰӮжһңи®ҫзҪ®пјҢи¶…еҮәжӯӨиЎҢж•°пјҢе°ҶдјҡжҳҫзӨәзңҒз•ҘеҸ·
 * @property {String} 					color		ж–Үжң¬йўңиүІпјҲй»ҳи®Ө '#303133' пјү
 * @property {String | Number} 			size		еӯ—дҪ“еӨ§е°ҸпјҲй»ҳи®Ө 15px пјү
 * @property {Object | String} 			iconStyle	еӣҫж Үзҡ„ж ·ејҸ пјҲй»ҳи®Ө {fontSize: '15px'} пјү
 * @property {String} 					decoration	ж–Үеӯ—иЈ…йҘ°пјҢдёӢеҲ’зәҝпјҢдёӯеҲ’зәҝзӯүпјҢеҸҜйҖүеҖј none|underline|line-throughпјҲй»ҳи®Ө 'none' пјү
 * @property {Object | String | Number}	margin		еӨ–иҫ№и·қпјҢеҜ№иұЎгҖҒеӯ—з¬ҰдёІпјҢж•°еҖјеҪўејҸеқҮеҸҜпјҲй»ҳи®Ө 0px пјү
 * @property {String | Number} 			lineHeight	ж–Үжң¬иЎҢй«ҳ
 * @property {String} 					align		ж–Үжң¬еҜ№йҪҗж–№ејҸпјҢеҸҜйҖүеҖјleft|center|rightпјҲй»ҳи®Ө 'left' пјү
 * @property {String} 					wordWrap	ж–Үеӯ—жҚўиЎҢпјҢеҸҜйҖүеҖјbreak-word|normal|anywhereпјҲй»ҳи®Ө 'normal' пјү
 * @event {Function} click  зӮ№еҮ»и§ҰеҸ‘дәӢд»¶
 * @example <up-text text="жҲ‘з”ЁеҚҒе№ҙйқ’жҳҘ,иөҙдҪ жңҖеҗҺд№ӢзәҰ"></up-text>
 */
export default {
    name: 'up-text',




    mixins: [mpMixin, mixin, propsText],

	emits: ['click'],
    computed: {
        valueStyle(): UTSJSONObject {
            let style = {
                textDecoration: this.decoration,
                fontWeight: this.bold ? 'bold' : 'normal',
                wordWrap: this.wordWrap,
                fontSize: addUnit(this.size)
            }
			if (this.type == '') {
				style['color'] = this.color
			}
			if (this.lines != '') {
				style['lines'] = this.lines
			}
			if (this.lineHeight != '') {
				style['lineHeight'] = addUnit(this.lineHeight)
			}
			if (this.block) {
				style['display'] = 'block'
			}
			return deepMerge(style, addStyle(this.customStyle)) as UTSJSONObject
        },
        // з»ҸеӨ„зҗҶеҗҺйңҖиҰҒжҳҫзӨәзҡ„еҖј
        value(): string {
            let {
                text,
                mode,
                format,
                href
            } = this

			// @ts-ignore
            let textStr = text.toString()

            // д»·ж јзұ»еһӢ
            if (mode === 'price') {
                // еҰӮжһңtextдёҚдёәйҮ‘йўқиҝӣиЎҢжҸҗзӨә
                if (!/^\d+(\.\d+)?$/.test(textStr)) {
                    error('йҮ‘йўқжЁЎејҸдёӢпјҢtextеҸӮж•°йңҖиҰҒдёәйҮ‘йўқж јејҸ');
                }
                // иҝӣиЎҢж јејҸеҢ–пјҢеҲӨж–ӯз”ЁжҲ·дј е…Ҙзҡ„formatеҸӮж•°дёәжӯЈеҲҷпјҢжҲ–иҖ…еҮҪж•°пјҢеҰӮжһңжІЎжңүдј е…ҘformatпјҢеҲҷдҪҝз”Ёй»ҳи®Өзҡ„йҮ‘йўқж јејҸеҢ–еӨ„зҗҶ
                // todo
				// if (testFunc(format)) {
                //     // еҰӮжһңз”ЁжҲ·дј е…Ҙзҡ„жҳҜеҮҪж•°пјҢдҪҝз”ЁеҮҪж•°ж јејҸеҢ–
                //     return format(text)
                // }
                // еҰӮжһңformatйқһжӯЈеҲҷпјҢйқһеҮҪж•°пјҢеҲҷдҪҝз”Ёй»ҳи®Өзҡ„йҮ‘йўқж јејҸеҢ–ж–№жі•иҝӣиЎҢж“ҚдҪң
                return priceFormat(textStr, 2)
            } if (mode === 'date') {
                // еҲӨж–ӯжҳҜеҗҰеҗҲжі•зҡ„ж—ҘжңҹжҲ–иҖ…ж—¶й—ҙжҲі
				if (!testDate(textStr)) {
					error('ж—ҘжңҹжЁЎејҸдёӢпјҢtextеҸӮж•°йңҖиҰҒдёәж—ҘжңҹжҲ–ж—¶й—ҙжҲіж јејҸ' + textStr)
				}
                // иҝӣиЎҢж јејҸеҢ–пјҢеҲӨж–ӯз”ЁжҲ·дј е…Ҙзҡ„formatеҸӮж•°дёәжӯЈеҲҷпјҢжҲ–иҖ…еҮҪж•°пјҢеҰӮжһңжІЎжңүдј е…ҘformatпјҢеҲҷдҪҝз”Ёй»ҳи®Өзҡ„ж јејҸеҢ–еӨ„зҗҶ
                // todo
                // if (testFunc(format)) {
                //     // еҰӮжһңз”ЁжҲ·дј е…Ҙзҡ„жҳҜеҮҪж•°пјҢдҪҝз”ЁеҮҪж•°ж јејҸеҢ–
                //     return format(textStr)
                // }
				if (format != '') {
                    // еҰӮжһңformatйқһжӯЈеҲҷпјҢйқһеҮҪж•°пјҢеҲҷдҪҝз”Ёй»ҳи®Өзҡ„ж—¶й—ҙж јејҸеҢ–ж–№жі•иҝӣиЎҢж“ҚдҪң
					// @ts-ignore
                    return timeFormat(textStr, format.toString())
                }
                // еҰӮжһңжІЎжңүи®ҫзҪ®formatпјҢеҲҷи®ҫзҪ®дёәй»ҳи®Өзҡ„ж—¶й—ҙж јејҸеҢ–еҪўејҸ
                return timeFormat(textStr, 'yyyy-mm-dd')
            } if (mode === 'phone') {
                // еҲӨж–ӯжҳҜеҗҰеҗҲжі•зҡ„жүӢжңәеҸ·
                // !testMobile(text) && error('жүӢжңәеҸ·жЁЎејҸдёӢпјҢtextеҸӮж•°йңҖиҰҒдёәжүӢжңәеҸ·з Ғж јејҸ')
                // todo
                // if (testFunc(format)) {
                //     // еҰӮжһңз”ЁжҲ·дј е…Ҙзҡ„жҳҜеҮҪж•°пјҢдҪҝз”ЁеҮҪж•°ж јејҸеҢ–
                //     return format(text)
                // }
				if (format === 'encrypt') {
                    // еҰӮжһңformatдёәencryptпјҢеҲҷе°ҶжүӢжңәеҸ·иҝӣиЎҢжҳҹеҸ·еҠ еҜҶеӨ„зҗҶ
                    return `${textStr.substring(0, 3)}****${textStr.substring(7)}`
                }
                return textStr
            } if (mode === 'name') {
                // еҲӨж–ӯжҳҜеҗҰеҗҲжі•зҡ„еӯ—з¬ҰзІ—
				if (!(typeof (textStr) === 'string')) {
					error('е§“еҗҚжЁЎејҸдёӢпјҢtextеҸӮж•°йңҖиҰҒдёәеӯ—з¬ҰдёІж јејҸ')
				}
                // if (testFunc(format)) {
                //     // еҰӮжһңз”ЁжҲ·дј е…Ҙзҡ„жҳҜеҮҪж•°пјҢдҪҝз”ЁеҮҪж•°ж јејҸеҢ–
                //     return format(textStr)
                // }
				if (format === 'encrypt') {
                    // еҰӮжһңformatдёәencryptпјҢеҲҷе°Ҷе§“еҗҚиҝӣиЎҢжҳҹеҸ·еҠ еҜҶеӨ„зҗҶ
                    return this.formatName(textStr)
                }
                return textStr
            } if (mode === 'link') {
                // еҲӨж–ӯжҳҜеҗҰеҗҲжі•зҡ„еӯ—з¬ҰзІ—
				if (!testUrl(href)) {
					error('и¶…й“ҫжҺҘжЁЎејҸдёӢпјҢhrefеҸӮж•°йңҖиҰҒдёәURLж јејҸ')
				}
                return textStr
            }
            return textStr
        },
        isMp(): Boolean {
            let mp = false



            return mp
        }
    },
    data() {
        return {}
    },
    methods: {
        addStyle(style: any): any {
			return addStyle(style)
		},
        clickHandler() {
            // еҰӮжһңдёәжүӢжңәеҸ·жЁЎејҸпјҢжӢЁжү“з”өиҜқ
            if (this.call && this.mode === 'phone') {
				// todo
                // uni.makePhoneCall({
                //     phoneNumber: this.text
                // })
            }
            this.$emit('click')
        },
        // й»ҳи®Өзҡ„е§“еҗҚи„ұж•Ҹи§„еҲҷ
        formatName(name: string): string {
            let value = ''
            if (name.length == 2) {
                value = name.substring(0, 1) + '*'
            } else if (name.length > 2) {
                let char = ''
                for (let i = 0, len = name.length - 2; i < len; i++) {
                    char += '*'
                }
                value = name.substring(0, 1) + char + name.substring(-1, 1)
            } else {
                value = name
            }
            return value
        },
		onGetUserInfo(): void {
		},
		onContact(): void {
		},
		onGetPhoneNumber(): void {
		},
		onError(): void {
		},
		onLaunchApp(): void {
		},
		onOpenSetting(): void {
		},
    }
}
</script>

<style lang="scss" scoped>
@import '../../libs/css/components.scss';

.up-text {
    @include flex(row);
    align-items: center;
    flex-wrap: nowrap;
    flex: 1;
	width: 100%;

    &__price {
        font-size: 14px;
        color: $up-content-color;
    }

    &__value {
        font-size: 14px;
        color: $up-content-color;
        text-overflow: ellipsis;

        &--primary {
            color: $up-primary;
        }

        &--warning {
            color: $up-warning;
        }

        &--success {
            color: $up-success;
        }

        &--info {
            color: $up-info;
        }

        &--error {
            color: $up-error;
        }

        &--main {
            color: $up-main-color;
        }

        &--content {
            color: $up-content-color;
        }

        &--tips {
            color: $up-tips-color;
        }

        &--light {
            color: $up-light-color;
        }
    }
}
</style>
