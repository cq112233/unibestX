<template>
  <Card title="触感与工具">
    <view class="rounded-12px p-16px mb-16px border-width-1px border-style-solid border-color-__e2e8f0_">
      <text class="text-12px text-__94a3b8_ mb-8px">剪贴板测试文本</text>
      <input
        v-model="copyText"
        placeholder="请输入要复制的文本"
        class="h-38px bg-white rounded-6px px-12px border-width-1px border-style-solid border-color-__cbd5e1_ text-14px text-__334155_ mb-12px"
      />
      <view class="w-full h-38px rounded-8px bg-__10b981_ flex flex-row items-center justify-center" @click="handleCopy">
        <text class="text-__ffffff_ text-14px font-bold">复制测试文本</text>
      </view>
    </view>

    <view class="w-full h-44px rounded-8px bg-__f59e0b_ flex flex-row items-center justify-center" @click="triggerVibration">
      <text class="text-__ffffff_ text-14px font-bold">短震动反馈</text>
    </view>
  </Card>
</template>

<script setup lang="uts">
import Card from '../../basic/components/Card.uvue'
import { ref } from 'vue'












const copyText = ref('Hello unibestX!')









































































function triggerVibration() {










  uni.showToast({
    title: '当前环境不支持震动',
    icon: 'none',
  })

}

function handleCopy() {
  if (copyText.value === '')
    return
  uni.setClipboardData({
    data: copyText.value,
    success: () => {
      uni.showToast({
        title: '复制成功',
        icon: 'success',
      })
    },
  })
}
</script>

