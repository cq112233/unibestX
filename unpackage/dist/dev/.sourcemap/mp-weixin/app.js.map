<style>

</style>
<script setup lang="uts">
import { checkDirectEntry } from './src/router/interceptor'
import { loadFont } from '@/uni_modules/uview-ultra/index.uts'

onLaunch(() => {
  loadFont()

  // 微信小程序真机 @font-face 不生效，使用 uni.loadFontFace 加载 uni-icons 字体
  uni.loadFontFace({
    global: true,
    family: 'UniIconsFontFamily',
    source: 'url(\'/static/uniicons.ttf\')',
    success() {
      uni.__f__('log','at App.uvue:14','global loadFontFace uniicons.ttf success')
    },
    fail(error) {
      uni.__f__('warn','at App.uvue:17','global loadFontFace uniicons.ttf fail', error.errMsg)
    },
  })

})


onShow((options?) => {
  checkDirectEntry(options)
})

</script>

<style lang="scss">
/* uni.scss */
@import '@/uni_modules/uview-ultra/index.scss';
@import './src/style/index.scss';
@import './js_sdk/a-hua-unocss/temp.scss';


/* 微信小程序真机：在全局 app.wxss 中注册字体，确保组件内可用 */
@import '@/uni_modules/uni-icons/components/uni-icons/uniicons_mp.css';
@import '@/uni_modules/uview-ultra/components/up-icon/upicon_mp.css';

</style>
