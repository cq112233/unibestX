              <up-icon name="arrow-right" color="#c0c4cc" size="16"></up-icon>
            </view>
          </up-form-item>
          <up-form-item label="年龄" prop="age" :border-bottom="true">
            <up-input v-model="formModel.age" type="number" placeholder="请输入年龄" border="none" :custom-style="{ backgroundColor: '#f2f3f5', padding: '4px 10px', borderRadius: '4px', width: '100%' }"></up-input>
          </up-form-item>
          <up-form-item label="水果" prop="fruit" :border-bottom="true">
            <up-radio-group v-model="formModel.fruit" placement="row">
              <up-radio name="apple" label="苹果" shape="circle"></up-radio>
