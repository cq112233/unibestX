  height: 40px;
  border-radius: 6px;
  background-color: #f3f4f6;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 12px;
}
.mock-input-text {
  font-size: 15px;
  color: #333333;
}
.mock-input-placeholder {
  font-size: 15px;
  color: #9ca3af;
}
</style>
