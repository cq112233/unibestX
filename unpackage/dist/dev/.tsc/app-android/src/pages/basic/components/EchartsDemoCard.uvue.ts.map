.bg-__3b82f6_{background:#3b82f6}
.bg-__d1fae5_{background:#d1fae5}
.bg-__e0edff_{background:#e0edff}
.bg-__f59e0b_{background:#f59e0b}
.bg-__fef3c7_{background:#fef3c7}
.flex{display:flex}
