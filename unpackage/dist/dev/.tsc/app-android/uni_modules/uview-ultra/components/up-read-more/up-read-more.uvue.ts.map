<template>
	<view class="up-read-more">
		<view
		    class="up-read-more__content"
		    :style="{
				height: isLongContent && status === 'close' ? addUnit(showHeight) : 'auto'
			}"
		>
			<view
			    class="up-read-more__content__inner"
			    ref="up-read-more__content__inner"
			    :class="[elId]"
			>
				<slot></slot>
			</view>
		</view>
		<view
		    class="up-read-more__toggle"
		    :style="[innerShadowStyle]"
		    v-if="isLongContent"
		>
			<slot name="toggle">
				<view
				    class="up-read-more__toggle__text"
				    @tap="toggleReadMore"
				>
					<up-text
					    :text="status === 'close' ? closeText : openText"
					    :color="color"
					    :size="fontSize"
					    :lineHeight="fontSize"
					    margin="0 5px 0 0"
					></up-text>
					<view class="up-read-more__toggle__icon">
						<up-icon
						    :color="color"
						    :size="parseInt(getPx(fontSize)) + 2"
						    :name="status === 'close' ? 'arrow-down' : 'arrow-up'"
						></up-icon>
					</view>
				</view>
			</slot>
		</view>
	</view>
</template>

<script>
	import { propsReadMore } from './props';
	import { mpMixin } from '../../libs/mixin/mpMixin';
	import { mixin } from '../../libs/mixin/mixin';
	import { addUnit, guid, getPx, sleep } from '../../libs/function/index';
	/**
	 * readMore 阅读更多
	 * @description 该组件一般用于内容较长，预先收起一部分，点击展开全部内容的场景。
	 * @tutorial https://uview-plus.jiangruyi.com/components/readMore.html
	 * @property {String | Number}	showHeight	内容超出此高度才会显示展开全文按钮，单位px（默认 400 ）
	 * @property {Boolean}			toggle		展开后是否显示收起按钮（默认 false ）
	 * @property {String}			closeText	关闭时的提示文字（默认 '展开阅读全文' ）
	 * @property {String}			openText	展开时的提示文字（默认 '收起' ）
	 * @property {String}			color		提示文字的颜色（默认 '#2979ff' ）
	 * @property {String | Number}	fontSize	提示文字的大小，单位px （默认 14 ）
	 * @property {Object}			shadowStyle	显示阴影的样式
	 * @property {String}			textIndent	段落首行缩进的字符个数 （默认 '2em' ）
	 * @property {String | Number}	name		用于在 open 和 close 事件中当作回调参数返回
	 * @event {Function} open 内容被展开时触发
	 * @event {Function} close 内容被收起时触发
	 * @example <up-read-more><rich-text :nodes="content"></rich-text></up-read-more>
	 */
	export default {
		name: 'up-read-more',
		mixins: [mpMixin, mixin, propsReadMore],
		data() {
			return {
				isLongContent: true, // 默认折叠，测量确认内容短再展开
				status: 'close', // 当前隐藏与显示的状态，close-收起状态，open-展开状态
				elId: guid(), // 生成唯一class
				contentHeight: 0, // 内容高度
				initRetryCount: 0 // 高度测量重试次数
			}
		},
		computed: {
			// 展开后无需阴影，收起时才需要阴影样式
			innerShadowStyle() {
				if (this.status === 'open') return {}

				// APP 端 linear-gradient 不渲染，替换为半透明白色背景
				const appStyle = {} as UTSJSONObject
				appStyle['backgroundColor'] = 'rgba(255, 255, 255, 0.85)'
				appStyle['paddingTop'] = this.shadowStyle['paddingTop'] ?? '100px'
				appStyle['marginTop'] = this.shadowStyle['marginTop'] ?? '-100px'
				return appStyle




			}
		},
		mounted() {
			this.init()
		},
		emits: ["open", "close"],
		methods: {
			addUnit(e: any) {
				return addUnit(e)
			},
			getPx(e: any): string {
				return getPx(e)
			},
			async init() {
				await sleep(150)
				this.getContentHeight().then((size: NodeInfo) => {
					this.contentHeight = size.height ?? 0
					if (this.contentHeight <= 0) {
						// 测量失败，重试（最多3次）
						this.initRetryCount = this.initRetryCount + 1
						if (this.initRetryCount <= 3) {
							setTimeout(() => { this.init() }, 200)
						}
						// 重试耗尽，保持 isLongContent = true（默认折叠状态）
						return
					}
					// 判断高度，如果真实内容高度 小于等于 占位高度，内容太短不需要折叠
					if (this.contentHeight <= parseFloat(getPx(this.showHeight))) {
						this.isLongContent = false
						this.status = 'close'
					}
					// 否则保持 isLongContent = true（默认折叠状态，无需额外操作）
				})
			},
			// 获取内容的高度
			async getContentHeight(): Promise<NodeInfo> {
				return new Promise(resolve => {
					// @ts-ignore
					this.upGetRect('.' + this.elId).then((res: NodeInfo) => {
						resolve(res)
					})
				})
			},
			// 展开或者收起
			toggleReadMore() {
				this.status = this.status === 'close' ? 'open' : 'close'
				// 如果toggle为false，隐藏"收起"部分的内容
				if (this.toggle == false) this.isLongContent = false
				// 发出打开或者收齐的事件
				// @ts-ignore
				this.$emit(this.status, this.name)
			}
		}
	}
</script>

<style lang="scss" scoped>
.up-read-more {

	&__content {
		overflow: hidden;
	}

	&__toggle {
		@include flex;
		justify-content: center;
		position: relative;

		&__text {
			@include flex;
			align-items: center;
			justify-content: center;
			margin-top: 5px;
		}
	}
}
</style>
