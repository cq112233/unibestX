    emits: ['update:modelValue', 'change'],
    methods: {
        addStyle(e: any): any {
            return addStyle(e);
        },
        addUnit(e: any): string {
            return addUnit(e);
        },
        toNumber(value: any, fallback: number = 0): number {
            if (value == null)
                return fallback;
            const num = parseFloat(value.toString());
            return isNaN(num) ? fallback : num;
        },
        getMinCountValue(): number {
            return this.toNumber(this.minCount, 0);
        },
        getCountValue(): number {
            return this.toNumber(this.count, 0);
