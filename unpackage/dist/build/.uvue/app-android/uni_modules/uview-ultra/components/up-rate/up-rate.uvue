            this.activeIndex = this.normalizeActiveIndex(this.modelValue);
            sleep().then(() => {
                this.getRateItemRect();
                this.getRateIconWrapRect();
            });
        },
        // 获取评分组件盒子的布局信息
        async getRateItemRect(): Promise<void> {
            await sleep();
            // @ts-ignore
            this.upGetRect("#" + this.elId).then((res: NodeInfo) => {
                const left = res.left ?? NaN;
