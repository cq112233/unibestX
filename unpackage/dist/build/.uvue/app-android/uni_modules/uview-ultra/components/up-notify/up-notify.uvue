        icon(): string {
            let icon = '';
            if (this.tmpConfig['type'] === 'success') {
                icon = 'checkmark-circle';
            }
            else if (this.tmpConfig['type'] === 'error') {
                icon = 'close-circle';
            }
            else if (this.tmpConfig['type'] === 'warning') {
                icon = 'error-circle';
            }
