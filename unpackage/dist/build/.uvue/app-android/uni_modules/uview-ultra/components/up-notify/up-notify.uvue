                    const complete = this.tmpConfig['complete'];
                    if (typeof complete === 'function') {
                        ;
                        (complete as () => void)();
                    }
                }, parseInt((this.tmpConfig['duration'] as any).toString()));
            }
        },
        // 关闭notify
        close() {
            this.clearTimer();
        },
        clearTimer() {
            this.open = false;
            // 清除定时器
            clearTimeout(this.timer ?? 0);
            this.timer = null;
        }
    },
    beforeUnmount() {
        this.clearTimer();
    }
});
