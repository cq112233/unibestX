            const isTopZero = topValue != null && parseFloat(topValue.toString()) == 0;
            if (isTopZero) {
            }
            const style = {
                top: addUnit(isTopZero ? top : topValue),
                // 因为组件底层为up-transition组件，必须将其设置为fixed定位
                // 让其出现在导航栏底部
                position: 'fixed',
                left: 0,
                right: 0,
                zIndex: 10076
            } as UTSJSONObject;
            return style;
