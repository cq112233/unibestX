            return addUnit(e);
        },
        primary(message: string) {
            this.show({
                type: 'primary',
                message
            });
        },
        success(message: string) {
            this.show({
                type: 'success',
                message
            });
        },
        error(message: string) {
            this.show({
                type: 'error',
                message
            });
        },
        warning(message: string) {
            this.show({
                type: 'warning',
                message
            });
